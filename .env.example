SITE_URL=https://dajilin.net
PUBLIC_GN_API_BASE_URL=https://api.renban.xyz
PUBLIC_GN_SITE_ID=dajilin
PUBLIC_GN_AI_SESSION_ENDPOINT=
PUBLIC_GN_AI_CHAT_ENDPOINT=
PUBLIC_GN_AI_RECOMMENDED_QUESTIONS_ENDPOINT=
PUBLIC_GN_AI_HANDOFF_ENDPOINT=

# Baidu Analytics (百度统计) — register at https://tongji.baidu.com/
# Leave empty to disable. Format: 32-character hex string (e.g. a1b2c3d4...)
PUBLIC_BAIDU_ANALYTICS_ID=

# Ghost CMS (dajilin dedicated instance)
GHOST_API_URL=https://cms.dajilin.net
GHOST_CONTENT_API_KEY=
GHOST_ADMIN_API_KEY=
GHOST_WEBHOOK_SECRET=

# n8n Workflow Webhooks (dajilin-specific)
# Station Application - Route 331 partnership applications
PUBLIC_GN_N8N_STATION_APPLY_WEBHOOK_URL=https://n.n8n.wang/webhook/dajilin-station-application

# Cooperation Form - Lead generation from /cooperation page
PUBLIC_GN_N8N_COOPERATION_WEBHOOK_URL=https://n.n8n.wang/webhook/dajilin-cooperation

# Order Processing - E-commerce checkout orders
PUBLIC_GN_N8N_ORDER_PROCESSING_WEBHOOK_URL=https://n.n8n.wang/webhook/dajilin-order-processing

# AI Handoff - Human support requests from AI assistant
PUBLIC_GN_N8N_AI_HANDOFF_WEBHOOK_URL=https://n.n8n.wang/webhook/dajilin-ai-handoff

# Existing Radar/Booking workflows (shared with other GN sites)
GN_N8N_MONITOR_TRIGGER_URL=https://n.n8n.wang/webhook/radar-monitor-trigger
GN_N8N_BOOKING_SUBMIT_URL=https://n.n8n.wang/webhook/booking-submit
GN_N8N_SITE_ASSESSMENT_URL=https://n.n8n.wang/webhook/radar-site-assessment
GN_N8N_SITE_ONBOARDING_URL=https://n.n8n.wang/webhook/radar-site-onboarding
GN_N8N_FAILURE_NOTIFY_URL=https://n.n8n.wang/webhook/radar-failure-notify
GN_N8N_DAILY_SUMMARY_URL=https://n.n8n.wang/webhook/radar-daily-summary

# ===========================================
# PAYMENT CONFIGURATION (WeChat + Alipay)
# Uncomment and fill in when ready for production
# ===========================================

# WeChat Pay
# WECHAT_MCHID=your_merchant_id
# WECHAT_MCHKEY=your_32_character_api_key
# WECHAT_APPID=wx_your_appid
# WECHAT_CERT_PATH=/path/to/apiclient_cert.pem

# Alipay
# ALIPAY_APP_ID=your_app_id
# ALIPAY_PRIVATE_KEY=your_private_key_base64
# ALIPAY_PUBLIC_KEY=alipay_public_key_base64
# ALIPAY_SIGN_TYPE=RSA2

# Payment Callback URLs
# PUBLIC_PAYMENT_CALLBACK_URL=https://dajilin.net/api/payment/callback
# AI video pipeline
# Images are generated through Codex-controlled web UI, not OpenAI API.

# fal.ai Kling image-to-video
# Keep FAL_KEY only in .env.local; never commit it.
# FAL_KEY=your-fal-key
VIDEO_GENERATION_PROVIDER=fal-kling-v2.1-standard
FAL_KLING_CFG_SCALE=0.5

# Optional generic image-to-video provider bridge. Keep unset to generate request files only.
# VIDEO_GENERATION_API_URL=https://your-provider.example/v1/image-to-video
# VIDEO_GENERATION_API_KEY=your-video-provider-key
