---
import '@/styles/index.css';
import PageAIWidget from '@/components/astro/PageAIWidget.astro';
import { getHtmlLang, getLocaleFromPathname } from '@/lib/i18n';

interface Props {
  title: string;
  description: string;
  schemas?: Array<Record<string, unknown>>;
  locale?: 'zh' | 'en' | 'ja' | 'ko';
  /** Open Graph image URL. Defaults to /images/home/hero-jilin.jpg */
  ogImage?: string;
  /** Twitter card type. Defaults to 'summary_large_image' */
  twitterCard?: 'summary' | 'summary_large_image';
}

const ogLocaleMap: Record<string, string> = {
  zh: 'zh_CN',
  en: 'en_US',
  ja: 'ja_JP',
  ko: 'ko_KR',
};

const { title, description, schemas = [], locale, ogImage, twitterCard = 'summary_large_image' } = Astro.props;
const resolvedLocale = locale ?? getLocaleFromPathname(Astro.url.pathname);
const htmlLang = getHtmlLang(resolvedLocale);
const ogLocale = ogLocaleMap[resolvedLocale] ?? 'zh_CN';
const siteUrl = Astro.url.origin;
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.url).href
  : `${siteUrl}/images/home/hero-jilin.jpg`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const connectSources = new Set(["'self'"]);
const publicApiBaseUrl = String(import.meta.env.PUBLIC_GN_API_BASE_URL || '').trim();

if (publicApiBaseUrl) {
  try {
    connectSources.add(new URL(publicApiBaseUrl).origin);
  } catch {
    // Ignore invalid values.
  }
}

const csp = [
  "default-src 'self'",
  "img-src 'self' data:",
  "style-src 'self' 'unsafe-inline'",
  "script-src 'self' 'unsafe-inline'",
  `connect-src ${Array.from(connectSources).join(' ')}`,
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
].join('; ');
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="dajilin.net" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="theme-color" content="#1e5f8a" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
    <PageAIWidget pageUrl={Astro.url.pathname} />
    <script>
      import { initScrollAnimations } from '@/scripts/scroll-animations';
      initScrollAnimations();
    </script>
  </body>
</html>
