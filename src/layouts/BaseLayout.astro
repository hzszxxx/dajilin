---
import '@/styles/index.css';
import PageAIWidget from '@/components/astro/PageAIWidget.astro';
import { getHtmlLang, getLocaleFromPathname, supportedLocales, stripLocalePrefix, localizePath } from '@/lib/i18n';

const baiduAnalyticsId = String((import.meta as any).env?.PUBLIC_BAIDU_ANALYTICS_ID || '').trim();

interface Props {
  title: string;
  description: string;
  schemas?: Array<Record<string, unknown>>;
  locale?: 'zh' | 'en' | 'ja' | 'ko';
  /** Open Graph image URL. Defaults to /images/home/hero-jilin.jpg */
  ogImage?: string;
  /** Twitter card type. Defaults to 'summary_large_image' */
  twitterCard?: 'summary' | 'summary_large_image';
}

const ogLocaleMap: Record<string, string> = {
  zh: 'zh_CN',
  en: 'en_US',
  ja: 'ja_JP',
  ko: 'ko_KR',
};

const { title, description, schemas = [], locale, ogImage, twitterCard = 'summary_large_image' } = Astro.props;
const resolvedLocale = locale ?? getLocaleFromPathname(Astro.url.pathname);
const htmlLang = getHtmlLang(resolvedLocale);
const ogLocale = ogLocaleMap[resolvedLocale] ?? 'zh_CN';
const siteUrl = Astro.url.origin;
const resolvedOgImage = ogImage
  ? new URL(ogImage, Astro.url).href
  : `${siteUrl}/images/home/hero-jilin.jpg`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);

const cleanPath = stripLocalePrefix(Astro.url.pathname);
const alternateLinks = supportedLocales.map((loc) => ({
  lang: getHtmlLang(loc),
  href: new URL(localizePath(cleanPath, loc), Astro.site).href
}));
// Add x-default pointing to the default locale (zh)
alternateLinks.push({
  lang: 'x-default',
  href: new URL(localizePath(cleanPath, 'zh'), Astro.site).href
});

const connectSources = new Set(["'self'"]);
const publicApiBaseUrl = String(import.meta.env.PUBLIC_GN_API_BASE_URL || '').trim();

if (publicApiBaseUrl) {
  try {
    connectSources.add(new URL(publicApiBaseUrl).origin);
  } catch {
    // Ignore invalid values.
  }
}

// Baidu Analytics domain
const baiduHm = 'https://hm.baidu.com';

const cspScriptSrc = baiduAnalyticsId
  ? `script-src 'self' 'unsafe-inline' 'unsafe-eval' ${baiduHm}`
  : `script-src 'self' 'unsafe-inline' 'unsafe-eval'`;

const cspConnectSrc = baiduAnalyticsId
  ? `connect-src 'self' ${baiduHm} ${[...connectSources].filter(s => s !== "'self'").join(' ')}`
  : `connect-src 'self' ${[...connectSources].filter(s => s !== "'self'").join(' ')}`;

const csp = [
  "default-src 'self'",
  "img-src 'self' data:",
  "style-src 'self' 'unsafe-inline'",
  cspScriptSrc,
  cspConnectSrc,
  "object-src 'none'",
  "base-uri 'self'",
  "form-action 'self'",
].join('; ');
---

<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="baidu-site-verification" content="codeva-LmtgvnvTvU" />
    <meta http-equiv="Content-Security-Policy" content={csp} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonicalUrl} />
    {alternateLinks.map(({ lang, href }) => (
      <link rel="alternate" hreflang={lang} href={href} />
    ))}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="dajilin.net" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="theme-color" content="#1e5f8a" />
    <meta property="og:image" content={resolvedOgImage} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <slot />
    <PageAIWidget pageUrl={Astro.url.pathname} />
    <script>
      import { initScrollAnimations } from '@/scripts/scroll-animations';
      initScrollAnimations();
    </script>
    {baiduAnalyticsId && (
      <script is:inline define:vars={{ baiduAnalyticsId }}>
        var _hmt = window._hmt || [];
        (function() {
          var hm = document.createElement('script');
          hm.src = 'https://hm.baidu.com/hm.js?' + baiduAnalyticsId;
          var s = document.getElementsByTagName('script')[0];
          s.parentNode.insertBefore(hm, s);
        })();
        // Track pageviews on navigation
        window._hmt = window._hmt || [];
      </script>
    )}
  </body>
</html>
