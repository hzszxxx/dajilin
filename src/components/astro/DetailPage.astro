---
import type { DetailPage } from '@/lib/content-pages';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';

type Props = {
  page: DetailPage;
};

const { page } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);
const isZh = locale === 'zh';

const copy: Record<
  Locale,
  {
    whatIsThis: string;
    audience: string;
    highlights: string;
    notes: string;
    faq: string;
    continueRead: string;
    quickConsult: string;
    askAi: string;
    submitConsult: string;
    fallbackTitle: string;
    fallbackDesc: string;
  }
> = {
  zh: {
    whatIsThis: '这是什么',
    audience: '适合哪些用户',
    highlights: '核心看点',
    notes: '注意事项',
    faq: '常见问题',
    continueRead: '建议继续浏览',
    quickConsult: '快速咨询',
    askAi: '先问 AI 助手',
    submitConsult: '提交咨询',
    fallbackTitle: '',
    fallbackDesc: '',
  },
  en: {
    whatIsThis: 'Overview',
    audience: 'Suitable Audience',
    highlights: 'Key Highlights',
    notes: 'Important Notes',
    faq: 'FAQ',
    continueRead: 'Continue Reading',
    quickConsult: 'Quick Consultation',
    askAi: 'Ask AI Assistant',
    submitConsult: 'Submit Consultation',
    fallbackTitle: 'Localized content is being expanded',
    fallbackDesc: 'You are viewing the multilingual structure for this page. Detailed localized content is being updated in phases.',
  },
  ja: {
    whatIsThis: '概要',
    audience: '対象ユーザー',
    highlights: '主要ポイント',
    notes: '注意事項',
    faq: 'よくある質問',
    continueRead: '続けて閲覧',
    quickConsult: 'ご相談',
    askAi: '先に AIアシスタントへ',
    submitConsult: '相談を送信',
    fallbackTitle: '多言語コンテンツを段階的に拡充中',
    fallbackDesc: '現在は多言語構造を先行適用しています。詳細な現地語コンテンツは順次反映します。',
  },
  ko: {
    whatIsThis: '개요',
    audience: '적합 대상',
    highlights: '핵심 포인트',
    notes: '유의사항',
    faq: '자주 묻는 질문',
    continueRead: '계속 보기',
    quickConsult: '상담 안내',
    askAi: 'AI 도우미 먼저',
    submitConsult: '상담 제출',
    fallbackTitle: '다국어 콘텐츠를 단계적으로 확장 중입니다',
    fallbackDesc: '현재는 다국어 구조를 우선 적용했습니다. 상세 현지어 콘텐츠는 순차 반영됩니다.',
  },
};
const t = copy[locale];
const localizedSectionNames: Record<Locale, Record<DetailPage['section'], string>> = {
  zh: {
    destinations: '目的地',
    'study-tours': '工业研学',
    'self-drive': '自驾攻略',
    'official-services': '官方服务',
    themes: '主题玩法',
    guides: '攻略与资讯',
    shop: '商城',
  },
  en: {
    destinations: 'Destinations',
    'study-tours': 'Study Tours',
    'self-drive': 'Self-Drive Guide',
    'official-services': 'Official Services',
    themes: 'Themes',
    guides: 'Guides',
    shop: 'Shop',
  },
  ja: {
    destinations: '目的地',
    'study-tours': '産業研修',
    'self-drive': '自驾攻略',
    'official-services': '公式サービス',
    themes: 'テーマ',
    guides: 'ガイド情報',
    shop: 'ショップ',
  },
  ko: {
    destinations: '목적지',
    'study-tours': '산업 연수',
    'self-drive': '자가운전 가이드',
    'official-services': '공식 서비스',
    themes: '테마',
    guides: '가이드',
    shop: '샵',
  },
};

const ctaLabelForHref = (href: string): string => {
  if (locale === 'zh') return href;
  const path = href.toLowerCase();
  if (path.includes('/destinations')) return locale === 'ja' ? '目的地を見る' : locale === 'ko' ? '목적지 보기' : 'View destinations';
  if (path.includes('/study-tours')) return locale === 'ja' ? '産業研修を見る' : locale === 'ko' ? '산업 연수 보기' : 'View study tours';
  if (path.includes('/self-drive')) return locale === 'ja' ? '自驾攻略を見る' : locale === 'ko' ? '자가운전 가이드 보기' : 'View Self-Drive Guide';
  if (path.includes('/official-services')) return locale === 'ja' ? '公式サービスを見る' : locale === 'ko' ? '공식 서비스 보기' : 'View official services';
  if (path.includes('/themes')) return locale === 'ja' ? 'テーマを見る' : locale === 'ko' ? '테마 보기' : 'View themes';
  if (path.includes('/guides')) return locale === 'ja' ? 'ガイドを見る' : locale === 'ko' ? '가이드 보기' : 'View guides';
  if (path.includes('/shop')) return locale === 'ja' ? 'ショップを見る' : locale === 'ko' ? '샵 보기' : 'View shop';
  if (path.includes('/cooperation')) return locale === 'ja' ? '協業相談へ' : locale === 'ko' ? '협업 문의로' : 'Go to cooperation';
  if (path.includes('/ai-assistant')) return locale === 'ja' ? 'AIアシスタントへ' : locale === 'ko' ? 'AI 도우미로' : 'Go to AI assistant';
  return locale === 'ja' ? 'ページを見る' : locale === 'ko' ? '페이지 보기' : 'Open page';
};

const sectionLabelByLocaleAndType: Record<Locale, Record<DetailPage['section'], string>> = {
  zh: {
    destinations: '目的地',
    'study-tours': '工业研学',
    'self-drive': '自驾攻略',
    'official-services': '官方服务',
    themes: '主题玩法',
    guides: '攻略与资讯',
    shop: '商城',
  },
  en: {
    destinations: 'destination',
    'study-tours': 'study-tour',
    'self-drive': 'self-drive',
    'official-services': 'official service',
    themes: 'theme',
    guides: 'guide',
    shop: 'shop',
  },
  ja: {
    destinations: '目的地',
    'study-tours': '産業研修',
    'self-drive': '自驾攻略',
    'official-services': '公式サービス',
    themes: 'テーマ',
    guides: 'ガイド情報',
    shop: 'ショップ',
  },
  ko: {
    destinations: '목적지',
    'study-tours': '산업 연수',
    'self-drive': '자가운전 가이드',
    'official-services': '공식 서비스',
    themes: '테마',
    guides: '가이드',
    shop: '샵',
  },
};

const englishTitle = page.eyebrow || 'Jilin Topic';
const englishSectionType = sectionLabelByLocaleAndType.en[page.section];
const englishOverview = {
  description: `This page provides a practical first-phase overview for ${englishTitle}, including scope, planning logic, and next actions.`,
  intro: `${englishTitle} is presented as a structured ${englishSectionType} page in the first phase. It helps users understand scope, planning logic, and the next action path before making detailed decisions.`,
  audience: [
    `Users exploring ${englishTitle} before confirming final itinerary.`,
    'Schools, institutions, teams, or individual travelers who need a readable planning baseline.',
    'Users who prefer understanding service boundaries and official channels first.',
  ],
  highlights: [
    `Clear first-phase explanation framework for ${englishTitle}.`,
    'Practical planning-first structure with consultation-ready output.',
    'Connected navigation to destinations, routes, themes, and official service entries.',
  ],
  sections: [
    {
      title: 'What This Page Covers',
      body: `This page explains the first-phase content scope of ${englishTitle}, including how to read it and where to continue next.`,
      bullets: [
        'Scope and positioning',
        'Who this page is suitable for',
        'How to continue to the next linked module',
      ],
    },
    {
      title: 'How To Use This Information',
      body: 'Use this page as an orientation layer first, then continue to connected routes, destination pages, or official channels based on your travel objective.',
      bullets: [
        'Read summary first',
        'Compare linked modules',
        'Ask AI guide for a route draft',
      ],
    },
    {
      title: 'Service Boundary and Next Step',
      body: 'At this stage, the platform prioritizes explanation and consultation. Final booking and execution should follow official or confirmed partner channels.',
      bullets: [
        'Information-first and consultation-first',
        'Official rules take precedence where applicable',
        'Handoff to consultant for complex cases',
      ],
    },
  ],
  notes: [
    'This page is maintained as a planning and understanding layer.',
    'For policy-sensitive or booking-sensitive topics, official channels are authoritative.',
    'Use cooperation consultation for group or institutional scenarios.',
  ],
  faq: [
    {
      question: `How should I use the ${englishTitle} page effectively?`,
      answer: 'Start with overview and highlights, then open linked modules for detailed routes or service entries, and use AI guide if you need a fast first-draft plan.',
    },
    {
      question: 'Can I complete all actions directly on this page?',
      answer: 'This phase is guidance-first. For official booking or complex coordination, continue to official entries or submit consultation.',
    },
  ],
};

const japaneseTitle = page.eyebrow || '吉林トピック';
const japaneseSectionType = sectionLabelByLocaleAndType.ja[page.section];
