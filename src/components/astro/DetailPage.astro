  ],
  faq: [
    {
      question: `${japaneseTitle}ページはどのように活用するのが効果的ですか？`,
      answer: '概要と主要ポイントを確認し、関連モジュールで詳細を比較したうえで、必要に応じてAIガイドまたは相談へ進む流れが最適です。',
    },
    {
      question: 'このページのみで手続きは完了しますか？',
      answer: '本フェーズはガイド中心です。正式予約や複雑な調整は、公式入口または相談導線をご利用ください。',
    },
  ],
};

const koreanTitle = page.eyebrow || '지린 토픽';
const koreanSectionType = sectionLabelByLocaleAndType.ko[page.section];
const koreanOverview = {
  description: `${koreanTitle} 관련 1단계 안내 페이지입니다. 범위, 계획 기준, 다음 행동 동선을 체계적으로 확인할 수 있습니다.`,
  intro: `${koreanTitle} 페이지는 1단계에서 ${koreanSectionType} 맥락을 이해하기 위한 구조화 안내 페이지입니다. 세부 결정을 하기 전에 핵심과 다음 동선을 파악할 수 있습니다.`,
  audience: [
    `${koreanTitle} 관련 의사결정 전에 전체 구조를 먼저 파악하려는 사용자.`,
    '학교, 기관, 팀, 개인 여행자 중 명확한 계획 기준이 필요한 사용자.',
    '서비스 경계와 공식 채널을 선확인한 뒤 판단하려는 사용자.',
  ],
  highlights: [
    `${koreanTitle} 1단계 설명 프레임을 명확하게 제공합니다.`,
    '설명 중심 구조로 상담 전환이 가능한 판단 기준을 제공합니다.',
    '목적지, 루트, 테마, 공식 서비스 입구와 연계됩니다.',
  ],
  sections: [
    {
      title: '이 페이지에서 확인할 내용',
      body: `${koreanTitle}의 1단계 콘텐츠 범위, 권장 열람 순서, 다음 이동 동선을 설명합니다.`,
      bullets: ['범위와 포지셔닝', '적합 대상', '다음에 볼 연결 모듈'],
    },
    {
      title: '정보 활용 방법',
      body: '먼저 개요를 확인하고, 이후 목적에 따라 루트·목적지·공식 채널로 이동하는 방식이 가장 효율적입니다.',
      bullets: ['개요 우선 확인', '연결 모듈 비교', 'AI 가이드로 1차 루트 생성'],
    },
    {
      title: '서비스 경계와 다음 단계',
      body: '현재 단계는 설명과 상담을 우선합니다. 예약, 구매, 실행은 공식 채널 또는 확인된 협력 채널 기준으로 진행해야 합니다.',
      bullets: ['설명 우선 · 상담 우선', '공식 규정 우선 적용', '복합 요청은 상담사 연계'],
    },
  ],
  notes: [
    '본 페이지는 계획 이해를 위한 설명 레이어로 운영됩니다.',
    '정책·예약 규정 관련 내용은 공식 채널 기준을 따릅니다.',
    '단체·기관 수요는 협업 문의로 연결하는 것을 권장합니다.',
  ],
  faq: [
    {
      question: `${koreanTitle} 페이지를 가장 효율적으로 활용하는 방법은 무엇인가요?`,
      answer: '개요와 핵심 포인트를 먼저 확인한 뒤 연결 모듈에서 세부 내용을 비교하고, 필요 시 AI 가이드 또는 상담으로 이어가면 됩니다.',
    },
    {
      question: '이 페이지에서 모든 절차를 바로 완료할 수 있나요?',
      answer: '현재 단계는 가이드 중심입니다. 공식 예약이나 복잡한 조정은 공식 입구 또는 상담 경로를 이용해 주세요.',
    },
  ],
};

const localizedOverviewByLocale = {
  en: englishOverview,
  ja: japaneseOverview,
  ko: koreanOverview,
} as const;

const localizedOverview = !isZh ? localizedOverviewByLocale[locale as 'en' | 'ja' | 'ko'] : null;

const displayIntro = isZh ? page.intro : localizedOverview?.intro ?? t.fallbackTitle;
const displayAudience = isZh ? page.audience : localizedOverview?.audience ?? [];
const displayHighlights = isZh ? page.highlights : localizedOverview?.highlights ?? [];
const displaySections = isZh ? page.sections : localizedOverview?.sections ?? [];
const displayNotes = isZh ? page.notes : localizedOverview?.notes ?? [];
const displayFaqs = isZh ? page.faqs : localizedOverview?.faq ?? [];
---

<div class="container page-grid">
  <section class="content-card">
    <div class="page-hero">
      <div class="page-copy">
        <div class="eyebrow">{page.eyebrow}</div>
        <h1>{isZh ? page.title : page.eyebrow}</h1>
        <p>{isZh ? page.description : localizedOverview?.description ?? t.fallbackDesc}</p>
      </div>
    </div>

    <div class="detail-block">
      <h2>{t.whatIsThis}</h2>
      <p>{displayIntro}</p>
    </div>

    <div class="detail-block">
      <h2>{t.audience}</h2>
      <ul>
        {displayAudience.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="detail-block">
      <h2>{t.highlights}</h2>
      <ul>
        {displayHighlights.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    {displaySections.map((section) => (
      <div class="detail-block">
        <h2>{section.title}</h2>
        <p>{section.body}</p>
        {section.bullets && (
          <ul>
            {section.bullets.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
      </div>
    ))}

    <div class="detail-block">
      <h2>{t.notes}</h2>
      <ul>
        {displayNotes.map((item) => <li>{item}</li>)}
      </ul>
    </div>

    <div class="detail-block">
      <h2>{t.faq}</h2>
      <div class="faq-list">
        {displayFaqs.map((faq) => (
          <article class="faq-item">
            <h3>{faq.question}</h3>
            <p>{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <aside class="page-card">
    <h3>{t.continueRead}</h3>
    <ul class="page-list">
      {page.ctas.map((cta) => (
        <li>
          <a href={localizePath(cta.href, locale)}>{isZh ? cta.label : ctaLabelForHref(cta.href)}</a>
        </li>
      ))}
    </ul>

    <div class="detail-side-card">
      <h3>{t.quickConsult}</h3>
      <div class="cta-row">
        <button
          class="button"
          type="button"
          data-open-ai-widget
          data-ai-page-url={page.pathname}
        >
          {t.askAi}
        </button>
        <a class="button-secondary" href={localizePath('/cooperation', locale)}>{t.submitConsult}</a>
      </div>
    </div>

</aside>
</div>
