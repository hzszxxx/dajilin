const ctaLabelForHref = (href: string): string => {
  if (locale === 'zh') return href;
  const path = href.toLowerCase();
  if (path.includes('/destinations')) return locale === 'ja' ? '目的地を見る' : locale === 'ko' ? '목적지 보기' : 'View destinations';
  if (path.includes('/study-tours')) return locale === 'ja' ? '産業研修を見る' : locale === 'ko' ? '산업 연수 보기' : 'View study tours';
  if (path.includes('/self-drive')) return locale === 'ja' ? '自驾攻略を見る' : locale === 'ko' ? '자가운전 가이드 보기' : 'View Self-Drive Guide';
  if (path.includes('/official-services')) return locale === 'ja' ? '公式サービスを見る' : locale === 'ko' ? '공식 서비스 보기' : 'View official services';
  if (path.includes('/themes')) return locale === 'ja' ? 'テーマを見る' : locale === 'ko' ? '테마 보기' : 'View themes';
  if (path.includes('/guides')) return locale === 'ja' ? 'ガイドを見る' : locale === 'ko' ? '가이드 보기' : 'View guides';
  if (path.includes('/shop')) return locale === 'ja' ? 'ショップを見る' : locale === 'ko' ? '샵 보기' : 'View shop';
  if (path.includes('/cooperation')) return locale === 'ja' ? '協業相談へ' : locale === 'ko' ? '협업 문의로' : 'Go to cooperation';
  if (path.includes('/ai-assistant')) return locale === 'ja' ? 'AIアシスタントへ' : locale === 'ko' ? 'AI 도우미로' : 'Go to AI assistant';
  return locale === 'ja' ? 'ページを見る' : locale === 'ko' ? '페이지 보기' : 'Open page';
};

