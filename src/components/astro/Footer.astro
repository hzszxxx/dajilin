---
import { getFooterText, getLocaleFromPathname, localizePath } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname);
const footerText = getFooterText(locale);
const currentYear = new Date().getFullYear();

const footerLinks = {
  destinations: [
    { label: footerText.destinationChangchun, href: localizePath('/destinations/changchun', locale) },
    { label: footerText.destinationChangbaishan, href: localizePath('/destinations/changbai-mountain', locale) },
    { label: footerText.destinationYanbian, href: localizePath('/destinations/yanbian', locale) },
  ],
  services: [
    { label: footerText.serviceStudyTours, href: localizePath('/study-tours', locale) },
    { label: footerText.serviceRoute331, href: localizePath('/self-drive', locale) },
    { label: footerText.serviceOfficial, href: localizePath('/official-services', locale) },
  ],
  about: [
    { label: footerText.aboutCooperation, href: localizePath('/cooperation', locale) },
    { label: footerText.aboutAI, href: localizePath('/ai-assistant', locale) },
  ],
};

const socialLinks: Array<{ name: string; icon: string; href: string; label: string }> = [
  { name: footerText.socialWechat, icon: 'wechat', href: '#', label: footerText.socialWechat }, // 微信: 需扫码，关注公众号获取
  { name: footerText.socialWeibo, icon: 'weibo', href: 'https://weibo.com/', label: footerText.socialWeibo }, // TODO: 确认官方微博账号
  { name: footerText.socialXiaohongshu, icon: 'xiaohongshu', href: 'https://www.xiaohongshu.com/', label: footerText.socialXiaohongshu }, // TODO: 确认小红书官方账号
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <!-- Brand Section -->
    <div class="footer-brand">
      <a href={localizePath('/', locale)} class="footer-logo">
        <span class="brand-mark">大</span>
        <span class="brand-text">
          <strong>dajilin.net</strong>
          <small>{footerText.brandSubtitle}</small>
        </span>
      </a>
      <p class="footer-tagline">
        {footerText.tagline}
      </p>
      <div class="footer-social">
        {socialLinks.map((social) => (
          <a aria-label={social.label} title={social.name} href={social.href} class="social-icon-link" target={social.href === "#" ? undefined : "_blank"} rel={social.href === "#" ? undefined : "noopener noreferrer"}>
            {social.icon === 'wechat' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8.5 11.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm7 0c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM12 2C6.48 2 2 6.03 2 11c0 2.76 1.36 5.22 3.5 6.83V22l4.07-2.24c.78.14 1.59.22 2.43.22 5.52 0 10-4.03 10-9s-4.48-9-10-9zm-1.5 12.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm3-2.5c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm5 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm2.5 4h-5v-.83c0-1.2.9-2.17 2-2.17h1c1.1 0 2 .97 2 2.17V16z"/>
              </svg>
            )}
            {social.icon === 'weibo' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10.09 18c-3.69 0-7.09-1.69-7.09-4.28 0-1.35.87-2.91 2.37-4.39 1.83-1.79 3.9-2.73 5.59-2.43.6.11 1.14.43 1.56.88.35-.08.7-.12 1.05-.12 3.62 0 6.1 2.36 6.1 5.64 0 3.05-2.18 5.64-5.64 5.64-.65 0-1.28-.08-1.9-.22-.25-.06-.51-.03-.74.08-.21.11-.38.29-.49.51-.11.23-.15.49-.11.75.04.25.15.48.32.67.17.19.39.32.64.39.25.07.51.07.76.01 1.28-.29 2.73-.96 3.6-1.76-.43-.68-.65-1.46-.65-2.26 0-.26.02-.52.07-.77-.05.01-.11.02-.16.02-.75.01-1.45-.11-2.1-.33-1.03-.35-1.88-.93-2.55-1.66-.68-.73-1.13-1.58-1.36-2.47-.23-.88-.23-1.8-.03-2.68.2-.87.63-1.67 1.25-2.33.61-.66 1.4-1.14 2.3-1.4.89-.26 1.85-.29 2.76-.1.9.19 1.73.59 2.42 1.16.69.57 1.21 1.31 1.52 2.14.31.83.38 1.73.2 2.6-.05.26-.03.52.06.77.09.25.25.46.46.62.21.15.47.24.73.27.26.03.53-.01.77-.11.24-.1.45-.27.61-.49.16-.21.26-.47.29-.74.04-.52-.05-1.06-.27-1.54-.21-.49-.53-.91-.93-1.24-.4-.33-.87-.56-1.37-.68-.5-.12-1.02-.13-1.53-.03-.44.09-.86.26-1.24.51.07.11.13.23.17.36.25.8.22 1.64-.07 2.43-.29.78-.83 1.45-1.56 1.92-.72.47-1.58.75-2.48.81-.9.06-1.8-.09-2.59-.43-.79-.35-1.47-.88-1.97-1.54-.5-.66-.8-1.44-.88-2.26-.08-.82.04-1.65.36-2.4.32-.75.81-1.38 1.44-1.84.62-.46 1.36-.75 2.14-.85.78-.09 1.57 0 2.29.28.37.15.72.35 1.04.58.29-.18.61-.32.94-.4.18-.05.36-.07.55-.06.18.01.36.06.52.14.16.08.3.19.41.32.11.14.19.3.23.47.04.17.04.35-.01.52-.05.17-.14.32-.27.45-.13.13-.29.22-.47.27-.18.05-.37.06-.55.02-.35-.08-.7-.11-1.05-.09-.55.04-1.09.18-1.57.42-.24.12-.46.27-.65.45-.17.16-.31.35-.41.56-.1.21-.16.44-.17.67-.01.23.04.46.14.67.1.21.25.39.43.53.18.14.39.24.61.29.42.09.86.07 1.27-.07.41-.14.77-.39 1.04-.72.13-.16.23-.33.31-.52-.34.02-.68.08-1.01.19-.65.22-1.22.59-1.68 1.06-.46.47-.79 1.04-.98 1.67-.18.63-.21 1.29-.08 1.94.13.65.41 1.25.82 1.76.41.51.94.93 1.55 1.22.61.29 1.29.45 1.98.46h.26c.91-.04 1.78-.34 2.5-.87.72-.53 1.26-1.27 1.55-2.13.13-.39.2-.8.2-1.21 0-.41-.07-.81-.2-1.2-.13-.38-.32-.74-.57-1.06-.25-.32-.55-.59-.89-.8-.34-.21-.71-.36-1.1-.43-.28-.05-.56-.07-.84-.06-.28.01-.55.05-.82.12-.13.04-.25.08-.37.14.1.28.17.56.22.85.09.53.08 1.07-.03 1.6-.11.53-.31 1.03-.6 1.49-.29.46-.66.85-1.09 1.16-.43.31-.92.54-1.44.68-.3.08-.61.13-.92.14h-.29c-.5-.02-.99-.15-1.44-.38-.45-.23-.85-.55-1.17-.94-.32-.39-.56-.84-.72-1.33-.16-.49-.22-1.01-.18-1.53.05-.52.2-1.02.46-1.48.25-.46.59-.85 1-1.16.41-.31.88-.54 1.38-.68.27-.07.54-.12.82-.14.28-.02.56 0 .84.05.27.05.54.14.78.28.24.14.46.32.64.54.18.22.32.47.41.74.09.27.12.56.09.84-.03.29-.11.56-.25.81-.14.25-.32.47-.54.65-.22.18-.48.31-.75.4-.13.04-.26.07-.39.09.22.06.44.15.64.27.47.29.86.68 1.16 1.14.29.46.48.98.56 1.52.08.54.05 1.09-.08 1.62-.13.53-.37 1.03-.71 1.47-.34.44-.77.8-1.27 1.07-.5.27-1.06.43-1.64.48-.32.03-.64.01-.96-.04-.31-.06-.62-.15-.91-.28-.14-.06-.27-.13-.4-.21-.09.09-.18.17-.28.25z"/>
              </svg>
            )}
            {social.icon === 'xiaohongshu' && (
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15v-4H9l3-5 2 3h3l-4 6h-2z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>

    <!-- Links Sections -->
    <div class="footer-links-grid">
      <div class="footer-col">
        <h4>{footerText.destinationsTitle}</h4>
        <ul>
          {footerLinks.destinations.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4>{footerText.servicesTitle}</h4>
        <ul>
          {footerLinks.services.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h4>{footerText.aboutTitle}</h4>
        <ul>
          {footerLinks.about.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Contact Section -->
    <div class="footer-contact">
      <h4>{footerText.contactTitle}</h4>
      <p>电话: <a href={`tel:${footerText.contactPhone}`}>{footerText.contactPhone}</a></p>
      <p>邮箱: <a href={`mailto:${footerText.contactEmail}`}>{footerText.contactEmail}</a></p>
    </div>
  </div>

  <!-- Disclaimer Bar -->
  <div class="footer-disclaimer">
    <div class="container">
      <p>{footerText.disclaimer}</p>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container">
      <p>© {currentYear} dajilin.net · <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener">{footerText.icp}</a></p>
      <div class="footer-legal">
        <a href={localizePath('/privacy', locale)}>{footerText.privacy}</a>
        <a href={localizePath('/terms', locale)}>{footerText.terms}</a>
      </div>
    </div>
  </div>
</footer>
