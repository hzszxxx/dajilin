  },
};

const localizedTitleMap: Record<Locale, Record<string, string>> = {
  zh: {
    default: '吉林文旅 AI 导览助手',
    destinations: '吉林目的地 AI 导览助手',
    industrial_study_tours: '工业研学 AI 导览助手',
    route_331: '331 国道 AI 导览助手',
    official_services: '官方服务说明 AI 助手',
    cooperation: '合作咨询 AI 助手',
  },
  en: {
    default: 'Jilin Travel AI Guide',
    destinations: 'Destination AI Guide',
    industrial_study_tours: 'Study Tour AI Guide',
    route_331: 'Route 331 AI Guide',
    official_services: 'Official Service AI Assistant',
    cooperation: 'Cooperation AI Assistant',
  },
  ja: {
    default: '吉林観光 AIガイド',
    destinations: '目的地 AIガイド',
    industrial_study_tours: '産業研修 AIガイド',
    route_331: '331国道 AIガイド',
    official_services: '公式サービス AIアシスタント',
    cooperation: '協業相談 AIアシスタント',
  },
  ko: {
    default: '지린 관광 AI 가이드',
    destinations: '목적지 AI 가이드',
    industrial_study_tours: '산업 연수 AI 가이드',
    route_331: '331 국도 AI 가이드',
    official_services: '공식 서비스 AI 도우미',
    cooperation: '협업 문의 AI 도우미',
  },
};

const copy = widgetCopyMap[locale];
const resolvedTitle = localizedTitleMap[locale][module] ?? localizedTitleMap[locale].default ?? title;
---

<div
  class="ai-widget"
  data-site-id={siteId}
  data-page-url={pageUrl}
  data-module={module}
  data-title={resolvedTitle}
  data-locale={locale}
  data-fallback-summary={copy.fallbackSummary}
  data-fallback-detail={copy.fallbackDetail}
  data-handoff-label={copy.handoffLabel}
  data-handoff-success={copy.handoffSuccess}
  data-handoff-success-detail={copy.handoffSuccessDetail}
  data-handoff-fail={copy.handoffFail}
  data-handoff-fail-detail={copy.handoffFailDetail}
  data-typing-label={copy.typingLabel}
  data-conversation-title={copy.conversationTitle}
  data-clear-history={copy.clearHistory}
  data-history-restored={copy.historyRestored}
  data-followups-label={copy.followupsLabel}
>
  <button class="ai-widget-trigger" type="button" aria-expanded="false">
    <span class="ai-widget-trigger-main">{copy.triggerMain}</span>
    <span class="ai-widget-trigger-sub">{copy.triggerSub}</span>
  </button>

  <section class="ai-widget-panel" hidden>
    <header class="ai-widget-header">
      <div>
        <strong>{resolvedTitle}</strong>
        <small>{copy.scope}</small>
      </div>
      <div class="ai-widget-header-actions">
        <button type="button" class="ai-widget-clear" aria-label={copy.clearHistory} title={copy.clearHistory}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/>
          </svg>
        </button>
        <button type="button" class="ai-widget-close" aria-label={copy.closeLabel}>×</button>
      </div>
    </header>

    <div class="ai-widget-body">
      <div class="ai-widget-intro">
        <p>{copy.introA}</p>
        <p>{copy.introB}</p>
      </div>

      <div class="ai-widget-recommended"></div>
      <div class="ai-widget-messages"></div>
      <div class="ai-widget-followups"></div>

      <div class="ai-widget-typing" hidden>
        <div class="typing-indicator">
          <span></span>
          <span></span>
          <span></span>
        </div>
        <span class="typing-label">{copy.typingLabel}</span>
      </div>

      <form class="ai-widget-handoff" hidden>
        <h3>{copy.handoffTitle}</h3>
        <p>{copy.handoffDesc}</p>
        <input name="name" type="text" placeholder={copy.namePlaceholder} required />
        <input name="phone_or_wechat" type="text" placeholder={copy.contactPlaceholder} required />
        <input name="organization" type="text" placeholder={copy.orgPlaceholder} />
        <textarea name="message" rows="3" placeholder={copy.messagePlaceholder} required></textarea>
        <div class="ai-widget-handoff-actions">
          <button type="submit" class="button">{copy.submit}</button>
          <button type="button" class="button-secondary" data-close-handoff>{copy.continueBrowsing}</button>
        </div>
      </form>
    </div>

    <form class="ai-widget-input">
      <input type="text" name="message" placeholder={copy.inputPlaceholder} required />
      <button type="submit" class="button">{copy.send}</button>
    </form>
  </section>
</div>

<script>
  import { getGNPublicEndpoints } from '@/lib/gn-public';

  const endpoints = getGNPublicEndpoints();
  const widgets = Array.from(document.querySelectorAll('.ai-widget'));

  // ---------------------------------------------------------------------------
  // Utility functions
  // ---------------------------------------------------------------------------

  const formatTimestamp = (timestamp: number, locale: string): string => {
    const date = new Date(timestamp);
    const now = new Date();
    const isToday = date.toDateString() === now.toDateString();

    if (isToday) {
      return date.toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit' });
    }

    return date.toLocaleDateString(locale, {
      month: 'short',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    });
  };

  const generateId = (): string => `msg-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;

  // ---------------------------------------------------------------------------
  // Session storage management
  // ---------------------------------------------------------------------------

  interface StoredSession {
    sessionId: string;
    messages: Array<{
      id: string;
      role: string;
      content: string;
      timestamp: number;
      summary?: string;
      detail?: string;
    }>;
  }

  const loadSession = (storageKey: string): StoredSession | null => {
    const stored = window.localStorage.getItem(storageKey);
    if (!stored) return null;
    try {
      return JSON.parse(stored);
    } catch {
      return null;
    }
  };

  const saveSession = (storageKey: string, session: StoredSession): void => {
    window.localStorage.setItem(storageKey, JSON.stringify(session));
  };

  const clearSession = (storageKey: string): void => {
    window.localStorage.removeItem(storageKey);
  };

  // ---------------------------------------------------------------------------
  // Main widget initialization
  // ---------------------------------------------------------------------------

  widgets.forEach((root) => {
    const trigger = root.querySelector('.ai-widget-trigger');
    const panel = root.querySelector('.ai-widget-panel');
    const closeButton = root.querySelector('.ai-widget-close');
    const clearButton = root.querySelector('.ai-widget-clear');
    const recommendedEl = root.querySelector('.ai-widget-recommended');
    const messagesEl = root.querySelector('.ai-widget-messages');
    const followupsEl = root.querySelector('.ai-widget-followups');
    const typingEl = root.querySelector('.ai-widget-typing');
    const inputForm = root.querySelector('.ai-widget-input');
    const handoffForm = root.querySelector('.ai-widget-handoff');
    const handoffClose = root.querySelector('[data-close-handoff]');

    if (
      !(trigger instanceof HTMLButtonElement) ||
      !(panel instanceof HTMLElement) ||
      !(recommendedEl instanceof HTMLElement) ||
      !(messagesEl instanceof HTMLElement) ||
      !(followupsEl instanceof HTMLElement) ||
      !(inputForm instanceof HTMLFormElement) ||
      !(handoffForm instanceof HTMLFormElement)
    ) {
      return;
    }

    const rootEl = root as HTMLElement;
    const siteId = rootEl.dataset.siteId || 'dajilin';
    const pageUrl = rootEl.dataset.pageUrl || window.location.pathname;
    const module = rootEl.dataset.module || '';
    const locale = rootEl.dataset.locale || 'zh';
    const fallbackSummary = rootEl.dataset.fallbackSummary || '';
    const fallbackDetail = rootEl.dataset.fallbackDetail || '';
    const handoffLabel = rootEl.dataset.handoffLabel || '';
    const handoffSuccess = rootEl.dataset.handoffSuccess || '';
    const handoffSuccessDetail = rootEl.dataset.handoffSuccessDetail || '';
    const handoffFail = rootEl.dataset.handoffFail || '';
    const handoffFailDetail = rootEl.dataset.handoffFailDetail || '';
    const historyRestored = rootEl.dataset.historyRestored || '';
    const followupsLabel = rootEl.dataset.followupsLabel || '相关问题：';
    const clearHistoryLabel = rootEl.dataset.clearHistory || '清空对话';
    const storageKey = `dajilin-ai-session:${siteId}`;

    let sessionId = '';
    let currentMessages: StoredSession['messages'] = [];
    let suggestedFollowUps: string[] = [];

    // ---------------------------------------------------------------------------
    // UI helpers
    // ---------------------------------------------------------------------------

    const scrollToBottom = () => {
      messagesEl.scrollTop = messagesEl.scrollHeight;
    };

    const showTypingIndicator = () => {
      if (typingEl) typingEl.removeAttribute('hidden');
      scrollToBottom();
    };

    const hideTypingIndicator = () => {
      if (typingEl) typingEl.setAttribute('hidden', '');
    };

    const renderTimestamp = (timestamp: number): string => {
      return `<time class="ai-message-timestamp" datetime="${new Date(timestamp).toISOString()}">${formatTimestamp(timestamp, locale)}</time>`;
    };

    const appendMessage = (role: 'user' | 'assistant', content: string, timestamp: number = Date.now()) => {
      const id = generateId();
      const messageHtml =
        role === 'assistant'
          ? `<div class="ai-message-content"><p>${content}</p></div>${renderTimestamp(timestamp)}`
          : `<div class="ai-message-content"><p>${content}</p></div>${renderTimestamp(timestamp)}`;

      const item = document.createElement('article');
      item.className = `ai-message ai-message-${role}`;
      item.dataset.id = id;
      item.innerHTML = messageHtml;
      messagesEl.appendChild(item);
      scrollToBottom();

      // Save to session
      currentMessages.push({ id, role, content, timestamp });
      saveSession(storageKey, { sessionId, messages: currentMessages });

      return id;
    };

    const appendAssistantAnswer = (payload: {
      summary?: string;
      detail?: string;
      content?: string;
      next_actions?: Array<{ type: string; label: string; target?: string }>;
      suggested_follow_ups?: string[];
    }) => {
      const summary = payload?.summary || '';
      const detail = payload?.detail || payload?.content || '';
      const actions = Array.isArray(payload?.next_actions)
        ? payload?.next_actions
            .map((action) => {
              if (action.type === 'open_page' && action.target) {
                return `<a class="button-secondary" href="${action.target}">${action.label}</a>`;
              }
              if (action.type === 'handoff') {
                return `<button type="button" class="button-secondary" data-handoff-trigger>${action.label}</button>`;
              }
              if (action.type === 'suggested_question' && action.label) {
                return `<button type="button" class="ai-followup-chip" data-followup="${action.label}">${action.label}</button>`;
              }
              return '';
            })
            .join('')
        : '';

      const fullContent = summary ? `<strong>${summary}</strong><p>${detail}</p>` : `<p>${detail}</p>`;
      appendMessage('assistant', `${fullContent}<div class="ai-message-actions">${actions}</div>`);

      // Bind handoff triggers
      root.querySelectorAll('[data-handoff-trigger]').forEach((button) => {
        button.addEventListener('click', () => {
          handoffForm.hidden = false;
          handoffForm.scrollIntoView({ block: 'nearest' });
        });
      });

      // Bind follow-up triggers
      root.querySelectorAll('[data-followup]').forEach((button) => {
        button.addEventListener('click', async () => {
          const question = String(button.getAttribute('data-followup') || '').trim();
          if (question) {
            await submitMessage(question);
          }
        });
      });

      // Update suggested follow-ups
      if (Array.isArray(payload?.suggested_follow_ups) && payload.suggested_follow_ups.length > 0) {
        suggestedFollowUps = payload.suggested_follow_ups;
        renderFollowUps();
      }
    };

    const renderFollowUps = () => {
      if (!followupsEl) return;

      if (suggestedFollowUps.length === 0) {
        followupsEl.innerHTML = '';
        followupsEl.setAttribute('hidden', '');
        return;
      }

      const chips = suggestedFollowUps
        .map(
          (q) =>
            `<button type="button" class="ai-followup-chip" data-followup="${q}">${q}</button>`
        )
        .join('');

      followupsEl.innerHTML = `<span class="followups-label">${followupsLabel}</span>${chips}`;
      followupsEl.removeAttribute('hidden');

      followupsEl.querySelectorAll('[data-followup]').forEach((button) => {
        button.addEventListener('click', async () => {
          const question = String(button.getAttribute('data-followup') || '').trim();
          if (question) {
            await submitMessage(question);
          }
        });
      });
    };

    const restoreConversation = () => {
      const stored = loadSession(storageKey);
      if (stored && stored.messages.length > 0) {
        sessionId = stored.sessionId;
        currentMessages = stored.messages;

        stored.messages.forEach((msg) => {
          const content =
            msg.role === 'assistant' && (msg.summary || msg.detail)
              ? `<strong>${msg.summary || ''}</strong><p>${msg.detail || ''}</p>`
              : `<p>${msg.content}</p>`;
          const item = document.createElement('article');
          item.className = `ai-message ai-message-${msg.role}`;
          item.dataset.id = msg.id;
          item.innerHTML = `${content}${renderTimestamp(msg.timestamp)}`;
          messagesEl.appendChild(item);
        });

        scrollToBottom();

        // Show history restored notification
        const notification = document.createElement('div');
        notification.className = 'ai-history-notification';
        notification.textContent = historyRestored;
        messagesEl.insertBefore(notification, messagesEl.firstChild);

        setTimeout(() => notification.remove(), 3000);
        return true;
      }
      return false;
    };

    // ---------------------------------------------------------------------------
    // Core functions
    // ---------------------------------------------------------------------------

    const openPanel = async () => {
      panel.removeAttribute('hidden');
      trigger.setAttribute('aria-expanded', 'true');

      // Restore previous conversation if exists
      const hasHistory = restoreConversation();
      if (!hasHistory) {
        await ensureSession();
        await loadRecommendedQuestions();
      }
    };

    const closePanel = () => {
      panel.setAttribute('hidden', '');
      trigger.setAttribute('aria-expanded', 'false');
    };

    const clearConversation = () => {
      if (!confirm(clearHistoryLabel + '?')) return;

      currentMessages = [];
      messagesEl.innerHTML = '';
      followupsEl.innerHTML = '';
      followupsEl.setAttribute('hidden', '');
      sessionId = '';
      clearSession(storageKey);

      // Reload recommended questions
      loadRecommendedQuestions();
    };

    const ensureSession = async (): Promise<string> => {
      if (sessionId) {
        return sessionId;
      }

      if (!endpoints.aiSession) {
        console.warn('AI session endpoint not configured');
        return '';
      }

      try {
        const response = await fetch(endpoints.aiSession, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            site_id: siteId,
            page_url: pageUrl,
            source: 'web',
            context: {
              module,
              locale,
            },
          }),
        });

        const result = await response.json().catch(() => null);
        sessionId = result?.data?.session_id || '';

        if (sessionId) {
          saveSession(storageKey, { sessionId, messages: [] });
        }

        return sessionId;
      } catch (err) {
        console.error('Failed to start session:', err);
        return '';
      }
    };

    const loadRecommendedQuestions = async () => {
      if (!endpoints.aiRecommendedQuestions) {
        return;
      }

      const query = new URLSearchParams({
        site_id: siteId,
        page_url: pageUrl,
      });

      if (module) {
        query.set('module', module);
      }

      try {
        const response = await fetch(`${endpoints.aiRecommendedQuestions}?${query.toString()}`);
        const result = await response.json().catch(() => null);
        const questions = result?.data?.questions || [];

        recommendedEl.innerHTML = '';
        questions.forEach((question: string) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'ai-question-chip';
          button.textContent = question;
          button.addEventListener('click', async () => {
            await submitMessage(question);
          });
          recommendedEl.appendChild(button);
        });
      } catch (err) {
        console.error('Failed to load recommended questions:', err);
      }
    };

    const submitMessage = async (message: string) => {
      const clean = String(message || '').trim();
      if (!clean || !endpoints.aiChat) {
        return;
      }

      // Clear recommended questions after first message
      recommendedEl.innerHTML = '';
      followupsEl.innerHTML = '';
      followupsEl.setAttribute('hidden', '');
      suggestedFollowUps = [];

      await ensureSession();
      appendMessage('user', clean);

      const input = inputForm.querySelector('input[name="message"]') as HTMLInputElement;
      if (input) input.value = '';

      showTypingIndicator();

      try {
        const response = await fetch(endpoints.aiChat, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            site_id: siteId,
            session_id: sessionId,
            page_url: pageUrl,
            message: clean,
            context: {
              module,
              locale,
            },
          }),
        });

        const result = await response.json().catch(() => null);
        hideTypingIndicator();

        const answer = result?.data?.answer;
        if (answer) {
          appendAssistantAnswer(answer);

          if (result?.data?.handoff_suggested) {
            handoffForm.hidden = false;
            handoffForm.scrollIntoView({ block: 'nearest' });
          }
        } else {
          throw new Error('Invalid response');
        }
      } catch (err) {
        console.error('Failed to send message:', err);
        hideTypingIndicator();
        appendAssistantAnswer({
          summary: fallbackSummary || '当前无法回答这个问题。',
          detail: fallbackDetail || '你可以尝试换一种问法，或直接提交咨询。',
          next_actions: [{ type: 'handoff', label: handoffLabel || '提交咨询' }],
        });
      }
    };

    // ---------------------------------------------------------------------------
    // Event listeners
    // ---------------------------------------------------------------------------

    trigger.addEventListener('click', async () => {
      const hidden = panel.hasAttribute('hidden');
      if (hidden) {
        await openPanel();
      } else {
        closePanel();
      }
    });

    closeButton?.addEventListener('click', () => {
      closePanel();
    });

    clearButton?.addEventListener('click', () => {
      clearConversation();
    });

    inputForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      const form = new FormData(inputForm);
      const message = String(form.get('message') || '').trim();
      if (!message) {
        return;
      }
      await submitMessage(message);
    });

    handoffClose?.addEventListener('click', () => {
      handoffForm.hidden = true;
    });

    handoffForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!endpoints.aiHandoff) {
        return;
      }

      const submitBtn = handoffForm.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.setAttribute('disabled', '');

      try {
        const formData = new FormData(handoffForm);
        const payload = {
          site_id: siteId,
          session_id: sessionId,
          handoff_type: 'consultation',
          contact: {
            name: String(formData.get('name') || '').trim(),
            phone_or_wechat: String(formData.get('phone_or_wechat') || '').trim(),
            organization: String(formData.get('organization') || '').trim(),
          },
          message: String(formData.get('message') || '').trim(),
        };

        const response = await fetch(endpoints.aiHandoff, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);
        if (result?.success) {
          handoffForm.reset();
          handoffForm.hidden = true;
          appendMessage(
            'assistant',
            `<strong>${handoffSuccess || '咨询已提交'}</strong><p>${handoffSuccessDetail || '我们已经收到你的需求，后续会进一步跟进。'}</p>`,
          );
        } else {
          throw new Error(result?.error || 'Handoff failed');
        }
      } catch (err) {
        console.error('Handoff failed:', err);
        appendMessage(
          'assistant',
          `<strong>${handoffFail || '提交失败'}</strong><p>${handoffFailDetail || '请稍后再试，或通过合作咨询页联系我们。'}</p>`,
        );
      } finally {
        if (submitBtn) submitBtn.removeAttribute('disabled');
      }
    });

    // Handle external trigger buttons
    document.querySelectorAll('[data-open-ai-widget]').forEach((button) => {
      button.addEventListener('click', async () => {
        const question = String(button.getAttribute('data-ai-question') || '').trim();
        const targetPageUrl = String(button.getAttribute('data-ai-page-url') || '').trim();
        const targetModule = String(button.getAttribute('data-ai-module') || '').trim();

        if (targetPageUrl && targetPageUrl !== pageUrl) {
          return;
        }

        if (targetModule && targetModule !== module) {
          return;
        }

        if (panel.hasAttribute('hidden')) {
          await openPanel();
        }

        if (question) {
          await submitMessage(question);
        }
      });
    });
  });
</script>
