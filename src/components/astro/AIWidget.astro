---
import { getLocaleFromPathname, type Locale } from '@/lib/i18n';

interface Props {
  siteId: string;
  pageUrl: string;
  module?: string;
  title?: string;
}

const { siteId, pageUrl, module = '', title = '吉林文旅 AI 导览助手' } = Astro.props;
const locale = getLocaleFromPathname(Astro.url.pathname);

type WidgetCopy = {
  triggerMain: string;
  triggerSub: string;
  scope: string;
  closeLabel: string;
  introA: string;
  introB: string;
  handoffTitle: string;
  handoffDesc: string;
  namePlaceholder: string;
  contactPlaceholder: string;
  orgPlaceholder: string;
  messagePlaceholder: string;
  submit: string;
  continueBrowsing: string;
  inputPlaceholder: string;
  send: string;
  fallbackSummary: string;
  fallbackDetail: string;
  handoffLabel: string;
  handoffSuccess: string;
  handoffSuccessDetail: string;
  handoffFail: string;
  handoffFailDetail: string;
  typingLabel: string;
  conversationTitle: string;
  clearHistory: string;
  historyRestored: string;
  followupsLabel: string;
};

