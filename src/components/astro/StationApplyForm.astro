const t = labels[locale];
const typeOptions = labels[locale].stationTypeOptions;
const serviceOptions = labels[locale].serviceOptions;
---

<form id="station-apply-form" class="station-apply-form">
  <div class="form-success" id="form-success" style="display: none;">
    <p>{t.success}</p>
  </div>

  <div class="form-error" id="form-error" style="display: none;">
    <p>{t.error}</p>
  </div>

  <div class="form-group">
    <label for="stationName">{t.stationName} <span class="required">*</span></label>
    <input
      type="text"
      id="stationName"
      name="stationName"
      placeholder={t.stationNamePlaceholder}
      required
    />
    <span class="error-text" data-error="stationName"></span>
  </div>

  <div class="form-group">
    <label for="stationType">{t.stationType}</label>
    <select id="stationType" name="stationType">
      <option value="">-- {t.selectOption} --</option>
      {typeOptions.map((opt) => (
        <option value={opt}>{opt}</option>
      ))}
    </select>
  </div>

  <div class="form-group">
    <label for="location">{t.location} <span class="required">*</span></label>
    <input
      type="text"
      id="location"
      name="location"
      placeholder={t.locationPlaceholder}
      required
    />
    <span class="error-text" data-error="location"></span>
  </div>

  <div class="form-group">
    <label for="locationDetail">{t.locationDetail}</label>
    <input
      type="text"
      id="locationDetail"
      name="locationDetail"
      placeholder={t.locationDetailPlaceholder}
    />
  </div>

  <div class="form-group">
    <label>{t.services} <span class="required">*</span></label>
    <div class="checkbox-group">
      {serviceOptions.map((service) => (
        <label class="checkbox-label">
          <input
            type="checkbox"
            name="services"
            value={service}
          />
          <span>{service}</span>
        </label>
      ))}
    </div>
    <span class="error-text" data-error="services"></span>
  </div>

  <div class="form-group" id="serviceOtherGroup" style="display: none;">
    <label for="serviceOther">{t.serviceOtherPlaceholder}</label>
    <input
      type="text"
      id="serviceOther"
      name="serviceOther"
      placeholder={t.serviceOtherPlaceholder}
    />
  </div>

  <div class="form-group">
    <label for="contactName">{t.contactName} <span class="required">*</span></label>
    <input
      type="text"
      id="contactName"
      name="contactName"
      placeholder={t.contactNamePlaceholder}
      required
    />
    <span class="error-text" data-error="contactName"></span>
  </div>

  <div class="form-group">
    <label for="contactPhone">{t.contactPhone} <span class="required">*</span></label>
    <input
      type="tel"
      id="contactPhone"
      name="contactPhone"
      placeholder={t.contactPhonePlaceholder}
      required
    />
    <span class="error-text" data-error="contactPhone"></span>
  </div>

  <div class="form-group">
    <label for="contactEmail">{t.contactEmail} <span class="required">*</span></label>
    <input
      type="email"
      id="contactEmail"
      name="contactEmail"
      placeholder={t.contactEmailPlaceholder}
      required
    />
    <span class="error-text" data-error="contactEmail"></span>
  </div>

  <div class="form-group">
    <label for="businessLicense">{t.businessLicense}</label>
    <input
      type="text"
      id="businessLicense"
      name="businessLicense"
      placeholder={t.businessLicensePlaceholder}
    />
  </div>

  <div class="form-group">
    <label for="description">{t.description}</label>
    <textarea
      id="description"
      name="description"
      placeholder={t.descriptionPlaceholder}
      rows="4"
    ></textarea>
  </div>

  <div class="form-group">
    <label for="photos">{t.photos}</label>
    <input
      type="text"
      id="photos"
      name="photos"
      placeholder={t.photosPlaceholder}
    />
  </div>

  <div class="form-group checkbox-terms">
    <label class="checkbox-label">
      <input
        type="checkbox"
        id="agreeTerms"
        name="agreeTerms"
        required
      />
      <span>{t.agreeTerms}</span>
    </label>
    <span class="error-text" data-error="agreeTerms"></span>
  </div>

  <button type="submit" class="submit-button" id="submitBtn">{t.submit}</button>
</form>

<style>
  .station-apply-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-weight: 500;
    font-size: 0.9rem;
  }

  .required {
    color: #dc2626;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  select,
  textarea {
    padding: 0.625rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(11, 79, 108, 0.1);
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    font-weight: normal;
  }

  .checkbox-label input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    cursor: pointer;
  }

  .checkbox-terms {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .error-text {
    color: #dc2626;
    font-size: 0.8rem;
    display: none;
  }

  .form-success {
    padding: 1rem;
    background-color: #dcfce7;
    border: 1px solid #86efac;
    border-radius: 6px;
    color: #166534;
  }

  .form-error {
    padding: 1rem;
    background-color: #fee2e2;
    border: 1px solid #fca5a5;
    border-radius: 6px;
    color: #991b1b;
  }

  .submit-button {
    margin-top: 0.5rem;
    padding: 0.75rem 1.5rem;
    background-color: var(--primary);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .submit-button:hover:not(:disabled) {
    background-color: var(--primary-strong);
  }

  .submit-button:disabled {
    background-color: #9ca3af;
    cursor: not-allowed;
  }
</style>

<script define:vars={{ t }}>
  const form = document.getElementById('station-apply-form');
  const submitBtn = document.getElementById('submitBtn');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const serviceOtherGroup = document.getElementById('serviceOtherGroup');
  const servicesCheckboxes = form.querySelectorAll('input[name="services"]');

  // Show/hide other service input when "其他" is checked
  servicesCheckboxes.forEach((checkbox) => {
    checkbox.addEventListener('change', () => {
      const otherService = Array.from(servicesCheckboxes).find(
        (cb) => cb.value === t.serviceOptions[t.serviceOptions.length - 1]
      );
      if (otherService && otherService.checked) {
        serviceOtherGroup.style.display = 'flex';
      } else {
        serviceOtherGroup.style.display = 'none';
      }
    });
  });

  // Clear error when user types
  form.querySelectorAll('input, textarea, select').forEach((input) => {
    input.addEventListener('input', () => {
      const errorEl = form.querySelector(`[data-error="${input.name}"]`);
      if (errorEl) errorEl.style.display = 'none';
    });
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Clear all errors
    form.querySelectorAll('.error-text').forEach((el) => (el.style.display = 'none'));
    successDiv.style.display = 'none';
    errorDiv.style.display = 'none';

    // Validate
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Get selected services
    const selectedServices = Array.from(form.querySelectorAll('input[name="services"]:checked')).map(
      (cb) => cb.value
    );
    data.services = selectedServices;

    // Validate required fields
    let hasErrors = false;

    if (!data.stationName || !data.stationName.trim()) {
      showError('stationName', t.required);
      hasErrors = true;
    }

    if (!data.location || !data.location.trim()) {
      showError('location', t.required);
      hasErrors = true;
    }

    if (!data.contactName || !data.contactName.trim()) {
      showError('contactName', t.required);
      hasErrors = true;
    }

    if (!data.contactPhone || !data.contactPhone.trim()) {
      showError('contactPhone', t.required);
      hasErrors = true;
    } else if (!/^1[3-9]\d{9}$/.test(data.contactPhone.trim())) {
      showError('contactPhone', t.invalidPhone);
      hasErrors = true;
    }

    if (!data.contactEmail || !data.contactEmail.trim()) {
      showError('contactEmail', t.required);
      hasErrors = true;
    } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.contactEmail.trim())) {
      showError('contactEmail', t.invalidEmail);
      hasErrors = true;
    }

    if (selectedServices.length === 0) {
      showError('services', t.required);
      hasErrors = true;
    }

    if (!form.querySelector('#agreeTerms').checked) {
      showError('agreeTerms', t.termsRequired);
      hasErrors = true;
    }

    if (hasErrors) return;

    // Submit
    submitBtn.disabled = true;
    submitBtn.textContent = t.submitting;

    try {
      const webhookUrl = import.meta.env.PUBLIC_GN_N8N_STATION_APPLY_WEBHOOK_URL || '';

      if (webhookUrl) {
        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: 'dajilin-website',
            stationApplication: {
              ...data,
              submittedAt: new Date().toISOString(),
            },
          }),
        });

        if (!response.ok) throw new Error('Webhook request failed');
      } else {
        // Mock submission when webhook is not configured
        await new Promise((resolve) => setTimeout(resolve, 1500));
      }

      successDiv.style.display = 'block';
      form.reset();
    } catch (err) {
      errorDiv.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = t.submit;
    }
  });

  function showError(fieldName, message) {
    const errorEl = form.querySelector(`[data-error="${fieldName}"]`);
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.style.display = 'block';
    }
  }
</script>
