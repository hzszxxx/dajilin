const t = labels[locale];
const typeOptions = labels[locale].stationTypeOptions;
const serviceOptions = labels[locale].serviceOptions;
---

<form id="station-apply-form" class="station-apply-form" novalidate>
  <!-- Status messages -->
  <div class="form-success" id="form-success" style="display: none;">
    <p>{t.success}</p>
  </div>
  <div class="form-error" id="form-error" style="display: none;">
    <p>{t.error}</p>
  </div>

  <!-- Step indicator -->
  <div class="form-stepper" id="form-stepper">
    <div class="step-indicator" data-step="1">
      <span class="step-number">1</span>
      <span class="step-label">{t.step1Title}</span>
    </div>
    <div class="step-connector"></div>
    <div class="step-indicator" data-step="2">
      <span class="step-number">2</span>
      <span class="step-label">{t.step2Title}</span>
    </div>
    <div class="step-connector"></div>
    <div class="step-indicator" data-step="3">
      <span class="step-number">3</span>
      <span class="step-label">{t.step3Title}</span>
    </div>
    <div class="step-connector"></div>
    <div class="step-indicator" data-step="4">
      <span class="step-number">4</span>
      <span class="step-label">{t.summaryTitle}</span>
    </div>
  </div>

  <!-- Step 1: Basic Info -->
  <div class="form-step" data-step-panel="1">
    <div class="form-group">
      <label for="stationName">{t.stationName} <span class="required">*</span></label>
      <input
        type="text"
        id="stationName"
        name="stationName"
        placeholder={t.stationNamePlaceholder}
      />
      <span class="error-text" data-error="stationName"></span>
    </div>

    <div class="form-group">
      <label for="stationType">{t.stationType} <span class="required">*</span></label>
      <select id="stationType" name="stationType">
        <option value="">-- {t.selectOption} --</option>
        {typeOptions.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
      <span class="error-text" data-error="stationType"></span>
    </div>

    <div class="form-group">
      <label for="location">{t.location} <span class="required">*</span></label>
      <input
        type="text"
        id="location"
        name="location"
        placeholder={t.locationPlaceholder}
      />
      <span class="error-text" data-error="location"></span>
    </div>

    <div class="form-group">
      <label for="locationDetail">{t.locationDetail}</label>
      <input
        type="text"
        id="locationDetail"
        name="locationDetail"
        placeholder={t.locationDetailPlaceholder}
      />
    </div>
  </div>

  <!-- Step 2: Service Details -->
  <div class="form-step" data-step-panel="2" style="display:none;">
    <div class="form-group">
      <label>{t.services} <span class="required">*</span></label>
      <div class="checkbox-group">
        {serviceOptions.map((service) => (
          <label class="checkbox-label">
            <input
              type="checkbox"
              name="services"
              value={service}
            />
            <span>{service}</span>
          </label>
        ))}
      </div>
      <span class="error-text" data-error="services"></span>
    </div>

    <div class="form-group" id="serviceOtherGroup" style="display: none;">
      <label for="serviceOther">{t.serviceOtherPlaceholder}</label>
      <input
        type="text"
        id="serviceOther"
        name="serviceOther"
        placeholder={t.serviceOtherPlaceholder}
      />
    </div>

    <div class="form-group">
      <label for="description">{t.description}</label>
      <textarea
        id="description"
        name="description"
        placeholder={t.descriptionPlaceholder}
        rows="4"
      ></textarea>
    </div>

    <div class="form-group">
      <label for="photos">{t.photos}</label>
      <input
        type="text"
        id="photos"
        name="photos"
        placeholder={t.photosPlaceholder}
      />
    </div>
  </div>

  <!-- Step 3: Contact Info -->
  <div class="form-step" data-step-panel="3" style="display:none;">
    <div class="form-group">
      <label for="contactName">{t.contactName} <span class="required">*</span></label>
      <input
        type="text"
        id="contactName"
        name="contactName"
        placeholder={t.contactNamePlaceholder}
      />
      <span class="error-text" data-error="contactName"></span>
    </div>

    <div class="form-group">
      <label for="contactPhone">{t.contactPhone} <span class="required">*</span></label>
      <input
        type="tel"
        id="contactPhone"
        name="contactPhone"
        placeholder={t.contactPhonePlaceholder}
      />
      <span class="error-text" data-error="contactPhone"></span>
    </div>

    <div class="form-group">
      <label for="contactEmail">{t.contactEmail} <span class="required">*</span></label>
      <input
        type="email"
        id="contactEmail"
        name="contactEmail"
        placeholder={t.contactEmailPlaceholder}
      />
      <span class="error-text" data-error="contactEmail"></span>
    </div>

    <div class="form-group">
      <label for="businessLicense">{t.businessLicense}</label>
      <input
        type="text"
        id="businessLicense"
        name="businessLicense"
        placeholder={t.businessLicensePlaceholder}
      />
    </div>

    <div class="form-group checkbox-terms">
      <label class="checkbox-label">
        <input
          type="checkbox"
          id="agreeTerms"
          name="agreeTerms"
        />
        <span>
          {t.agreeTerms}
          <a href="/terms/partnership" target="_blank" class="terms-link">{t.agreeTermsLink1}</a>
          {t.agreeTermsAnd}
          <a href="/terms/service" target="_blank" class="terms-link">{t.agreeTermsLink2}</a>
        </span>
      </label>
      <span class="error-text" data-error="agreeTerms"></span>
    </div>
  </div>

  <!-- Step 4: Summary -->
  <div class="form-step" data-step-panel="4" style="display:none;">
    <div class="summary-card">
      <div class="summary-section">
        <div class="summary-section-title">{t.step1Title}</div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryStationName}</span>
          <span class="summary-value" id="sum-stationName"></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryStationType}</span>
          <span class="summary-value" id="sum-stationType"></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryLocation}</span>
          <span class="summary-value" id="sum-location"></span>
        </div>
      </div>
      <div class="summary-section">
        <div class="summary-section-title">{t.step2Title}</div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryServices}</span>
          <span class="summary-value" id="sum-services"></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryDescription}</span>
          <span class="summary-value" id="sum-description"></span>
        </div>
      </div>
      <div class="summary-section">
        <div class="summary-section-title">{t.step3Title}</div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryContactName}</span>
          <span class="summary-value" id="sum-contactName"></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryContactPhone}</span>
          <span class="summary-value" id="sum-contactPhone"></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">{t.summaryContactEmail}</span>
          <span class="summary-value" id="sum-contactEmail"></span>
        </div>
      </div>
    </div>
  </div>

  <!-- Navigation buttons -->
  <div class="form-navigation" id="form-navigation">
    <button type="button" class="btn-back" id="btn-back" style="display:none;">{t.back}</button>
    <button type="button" class="btn-next" id="btn-next">{t.next}</button>
    <button type="submit" class="submit-button" id="submitBtn" style="display:none;">{t.submit}</button>
  </div>
</form>

<style>
  .station-apply-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Stepper */
  .form-stepper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .step-indicator {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.06);
    color: #6b7280;
    font-size: 0.82rem;
    transition: all 0.2s;
    user-select: none;
  }

  .step-indicator.active {
    background: var(--primary, #0b4f6c);
    color: #fff;
  }

  .step-indicator.completed {
    background: rgba(11, 79, 108, 0.15);
    color: var(--primary, #0b4f6c);
  }

  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    background: rgba(0,0,0,0.08);
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1;
  }

  .step-indicator.active .step-number {
    background: rgba(255,255,255,0.25);
  }

  .step-indicator.completed .step-number {
    background: var(--primary, #0b4f6c);
    color: #fff;
  }

  .step-connector {
    width: 20px;
    height: 2px;
    background: rgba(15, 23, 42, 0.1);
    flex-shrink: 0;
  }

  /* Form groups */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-weight: 500;
    font-size: 0.9rem;
  }

  .required {
    color: #dc2626;
  }

  input[type="text"],
  input[type="email"],
  input[type="tel"],
  select,
  textarea {
    padding: 0.625rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    transition: border-color 0.15s, box-shadow 0.15s;
    width: 100%;
    box-sizing: border-box;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary, #0b4f6c);
    box-shadow: 0 0 0 3px rgba(11, 79, 108, 0.1);
  }

  textarea {
    resize: vertical;
    min-height: 80px;
  }

  .checkbox-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    cursor: pointer;
    font-weight: normal;
  }

  .checkbox-label input[type="checkbox"] {
    width: 1rem;
    height: 1rem;
    cursor: pointer;
  }

  .checkbox-terms {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e5e7eb;
  }

  .terms-link {
    color: var(--primary, #0b4f6c);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .terms-link:hover {
    opacity: 0.8;
  }

  .error-text {
    color: #dc2626;
    font-size: 0.8rem;
    display: none;
  }

  /* Status banners */
  .form-success {
    padding: 1rem;
    background-color: #dcfce7;
    border: 1px solid #86efac;
    border-radius: 6px;
    color: #166534;
  }

  .form-error {
    padding: 1rem;
    background-color: #fee2e2;
    border: 1px solid #fca5a5;
    border-radius: 6px;
    color: #991b1b;
  }

  /* Summary card */
  .summary-card {
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
  }

  .summary-section {
    padding: 0.875rem 1rem;
    border-bottom: 1px solid #e5e7eb;
  }

  .summary-section:last-child {
    border-bottom: none;
  }

  .summary-section-title {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--primary, #0b4f6c);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .summary-row {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9rem;
    padding: 0.2rem 0;
  }

  .summary-label {
    color: #6b7280;
    flex-shrink: 0;
    min-width: 5rem;
  }

  .summary-value {
    color: #111827;
    word-break: break-all;
  }

  /* Navigation */
  .form-navigation {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }

  .btn-back {
    padding: 0.625rem 1.25rem;
    background: transparent;
    color: #374151;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .btn-back:hover {
    background: #f3f4f6;
    border-color: #9ca3af;
  }

  .btn-next {
    padding: 0.625rem 1.5rem;
    background-color: var(--primary, #0b4f6c);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .btn-next:hover {
    background-color: var(--primary-strong, #083d54);
  }

  .submit-button {
    padding: 0.75rem 1.5rem;
    background-color: var(--primary, #0b4f6c);
    color: white;
    border: none;
    border-radius: 6px;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.15s;
  }

  .submit-button:hover:not(:disabled) {
    background-color: var(--primary-strong, #083d54);
  }

  .submit-button:disabled {
    background-color: #9ca3af;
    cursor: not-allowed;
  }
</style>

<script is:inline define:vars={{ t }}>
  const TOTAL_STEPS = 4;
  let currentStep = 1;

  const form = document.getElementById('station-apply-form');
  const submitBtn = document.getElementById('submitBtn');
  const btnNext = document.getElementById('btn-next');
  const btnBack = document.getElementById('btn-back');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const serviceOtherGroup = document.getElementById('serviceOtherGroup');
  const servicesCheckboxes = form.querySelectorAll('input[name="services"]');

  // Show/hide other service input when last option is checked
  servicesCheckboxes.forEach((checkbox) => {
    checkbox.addEventListener('change', () => {
      const otherService = Array.from(servicesCheckboxes).find(
        (cb) => cb.value === t.serviceOptions[t.serviceOptions.length - 1]
      );
      serviceOtherGroup.style.display = (otherService && otherService.checked) ? 'flex' : 'none';
    });
  });

  // Clear error on input
  form.querySelectorAll('input, textarea, select').forEach((input) => {
    input.addEventListener('input', () => {
      const errorEl = form.querySelector(`[data-error="${input.name}"]`);
      if (errorEl) errorEl.style.display = 'none';
    });
    input.addEventListener('change', () => {
      const errorEl = form.querySelector(`[data-error="${input.name}"]`);
      if (errorEl) errorEl.style.display = 'none';
    });
  });

  function showError(fieldName, message) {
    const errorEl = form.querySelector(`[data-error="${fieldName}"]`);
    if (errorEl) {
      errorEl.textContent = message;
      errorEl.style.display = 'block';
    }
  }

  function clearErrors() {
    form.querySelectorAll('.error-text').forEach((el) => (el.style.display = 'none'));
  }

  function validateStep(step) {
    clearErrors();
    let ok = true;

    if (step === 1) {
      const stationName = form.querySelector('#stationName').value.trim();
      const stationType = form.querySelector('#stationType').value;
      const location = form.querySelector('#location').value.trim();

      if (!stationName) { showError('stationName', t.required); ok = false; }
      if (!stationType) { showError('stationType', t.required); ok = false; }
      if (!location) { showError('location', t.required); ok = false; }
    }

    if (step === 2) {
      const selected = Array.from(form.querySelectorAll('input[name="services"]:checked'));
      if (selected.length === 0) { showError('services', t.required); ok = false; }
    }

    if (step === 3) {
      const contactName = form.querySelector('#contactName').value.trim();
      const contactPhone = form.querySelector('#contactPhone').value.trim();
      const contactEmail = form.querySelector('#contactEmail').value.trim();
      const agreeTerms = form.querySelector('#agreeTerms').checked;

      if (!contactName) { showError('contactName', t.required); ok = false; }

      if (!contactPhone) {
        showError('contactPhone', t.required); ok = false;
      } else if (!/^1[3-9]\d{9}$/.test(contactPhone)) {
        showError('contactPhone', t.invalidPhone); ok = false;
      }

      if (!contactEmail) {
        showError('contactEmail', t.required); ok = false;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(contactEmail)) {
        showError('contactEmail', t.invalidEmail); ok = false;
      }

      if (!agreeTerms) { showError('agreeTerms', t.termsRequired); ok = false; }
    }

    return ok;
  }

  function buildSummary() {
    const notFilled = t.summaryNotFilled;
    const val = (id) => {
      const el = form.querySelector(`#${id}`);
      return el ? (el.value.trim() || notFilled) : notFilled;
    };

    const services = Array.from(form.querySelectorAll('input[name="services"]:checked'))
      .map((cb) => cb.value).join('、') || notFilled;

    document.getElementById('sum-stationName').textContent = val('stationName');
    document.getElementById('sum-stationType').textContent = val('stationType');
    document.getElementById('sum-location').textContent = val('location');
    document.getElementById('sum-services').textContent = services;
    document.getElementById('sum-description').textContent = val('description');
    document.getElementById('sum-contactName').textContent = val('contactName');
    document.getElementById('sum-contactPhone').textContent = val('contactPhone');
    document.getElementById('sum-contactEmail').textContent = val('contactEmail');
  }

  function renderStep(step) {
    // Update step panels
    form.querySelectorAll('.form-step').forEach((panel) => {
      const panelStep = parseInt(panel.dataset.stepPanel);
      panel.style.display = panelStep === step ? 'flex' : 'none';
      if (panelStep === step) panel.style.flexDirection = 'column';
    });

    // Update stepper indicators
    form.querySelectorAll('.step-indicator').forEach((indicator) => {
      const indicatorStep = parseInt(indicator.dataset.step);
      indicator.classList.remove('active', 'completed');
      if (indicatorStep === step) indicator.classList.add('active');
      else if (indicatorStep < step) indicator.classList.add('completed');
    });

    // Navigation buttons
    btnBack.style.display = step > 1 ? 'inline-block' : 'none';

    if (step < TOTAL_STEPS) {
      btnNext.style.display = 'inline-block';
      submitBtn.style.display = 'none';
    } else {
      btnNext.style.display = 'none';
      submitBtn.style.display = 'inline-block';
    }

    if (step === TOTAL_STEPS) {
      buildSummary();
    }
  }

  btnNext.addEventListener('click', () => {
    if (!validateStep(currentStep)) return;
    if (currentStep < TOTAL_STEPS) {
      currentStep++;
      renderStep(currentStep);
    }
  });

  btnBack.addEventListener('click', () => {
    if (currentStep > 1) {
      currentStep--;
      renderStep(currentStep);
    }
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearErrors();
    successDiv.style.display = 'none';
    errorDiv.style.display = 'none';

    // Collect data
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    const selectedServices = Array.from(form.querySelectorAll('input[name="services"]:checked')).map(
      (cb) => cb.value
    );
    data.services = selectedServices;

    submitBtn.disabled = true;
    submitBtn.textContent = t.submitting;

    try {
      const webhookUrl = import.meta.env.PUBLIC_GN_N8N_STATION_APPLY_WEBHOOK_URL || '';

      if (webhookUrl) {
        const response = await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: 'dajilin-website',
            stationApplication: {
              ...data,
              submittedAt: new Date().toISOString(),
            },
          }),
        });

        if (!response.ok) throw new Error('Webhook request failed');
      } else {
        // Mock submission when webhook is not configured
        await new Promise((resolve) => setTimeout(resolve, 1500));
      }

      successDiv.style.display = 'block';
      form.reset();
      currentStep = 1;
      renderStep(1);
    } catch (err) {
      errorDiv.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = t.submit;
    }
  });

  // Initialize
  renderStep(1);
</script>
