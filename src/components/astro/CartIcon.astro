---
interface Props {
  locale?: 'zh' | 'en' | 'ja' | 'ko';
}

const { locale = 'zh' } = Astro.props;

const labels: Record<string, { title: string; empty: string; items: string; total: string; checkout: string; continueShopping: string; remove: string; name: string; phone: string; email: string; address: string; notes: string; footerNote: string; }> = {
  zh: { title: '咨询清单', empty: '咨询清单是空的', items: '条咨询意向', total: '共', checkout: '提交咨询', continueShopping: '继续浏览', remove: '移除', name: '姓名', phone: '电话', email: '邮箱', address: '地址', notes: '备注', footerNote: '提交后将由顾问联系您' },
  en: { title: 'Inquiry List', empty: 'Your inquiry list is empty', items: 'item(s)', total: 'Total', checkout: 'Submit Inquiry', continueShopping: 'Continue Browsing', remove: 'Remove', name: 'Name', phone: 'Phone', email: 'Email', address: 'Address', notes: 'Notes', footerNote: 'A consultant will contact you after submission.' },
  ja: { title: 'カート', empty: 'カートは空です', items: '点', total: '合計', checkout: '購入手続き', continueShopping: '買い物を続ける', remove: '削除', name: '氏名', phone: '電話', email: 'メール', address: '住所', notes: 'メモ', footerNote: '後日担当者よりご連絡いたします。' },
  ko: { title: '장바구니', empty: '장바구니가 비어 있습니다', items: '개', total: '합계', checkout: '결제하기', continueShopping: '쇼핑 계속', remove: '삭제', name: '이름', phone: '전화', email: '이메일', address: '주소', notes: '메모', footerNote: '제출 후 담당자가 연락드립니다.' },
};

const t = labels[locale] || labels.zh;
---

<button type="button" class="cart-icon-btn" id="cart-icon-btn" aria-label={t.title}>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="9" cy="21" r="1"/>
    <circle cx="20" cy="21" r="1"/>
    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
  </svg>
  <span class="cart-badge" id="cart-badge" style="display: none;">0</span>
</button>

<!-- Cart Sidebar -->
<div class="cart-sidebar-overlay" id="cart-sidebar-overlay" style="display: none;">
  <div class="cart-sidebar" id="cart-sidebar">
    <div class="cart-header">
      <h2>{t.title}</h2>
      <button type="button" class="cart-close" id="cart-close-btn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="cart-body" id="cart-body">
      <!-- Cart items will be rendered here -->
    </div>
    <div class="cart-footer" id="cart-footer" style="display: none;">
      <div class="cart-total">
        <span id="cart-count-display">{t.total} <span id="cart-item-count">0</span> {t.items}</span>
      </div>
      <p class="cart-footer-note">{t.footerNote}</p>
      <a href={locale === 'zh' ? '/cooperation' : `/${locale}/cooperation`} class="cart-checkout-btn">
        {t.checkout}
      </a>
      <button type="button" class="cart-continue-btn" id="cart-continue-btn">
        {t.continueShopping}
      </button>
    </div>
  </div>
</div>

<style>
  .cart-icon-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(15, 23, 42, 0.12);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--primary-strong);
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cart-icon-btn:hover {
    background: rgba(255, 255, 255, 1);
    border-color: rgba(15, 118, 110, 0.32);
    transform: translateY(-1px);
  }

  .cart-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 999px;
    background: #ef4444;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 6px rgba(239, 68, 68, 0.4);
  }

  .cart-sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 100;
    display: flex;
    justify-content: flex-end;
  }

  .cart-sidebar {
    width: min(420px, 100vw);
    height: 100%;
    background: #fff;
    display: flex;
    flex-direction: column;
    box-shadow: -4px 0 24px rgba(0, 0, 0, 0.15);
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.1);
  }

  .cart-header h2 {
    margin: 0;
    font-size: 1.2rem;
    color: var(--text-strong);
  }

  .cart-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    border-radius: 50%;
    background: rgba(15, 23, 42, 0.06);
    color: var(--muted);
    cursor: pointer;
  }

  .cart-close:hover {
    background: rgba(15, 23, 42, 0.12);
  }

  .cart-body {
    flex: 1;
    overflow-y: auto;
    padding: 16px 24px;
  }

  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 48px 24px;
    color: var(--muted);
  }

  .cart-empty p {
    margin: 0;
    font-size: 0.95rem;
  }

  .cart-items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .cart-item {
    padding: 16px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    border-radius: 16px;
    background: #fff;
  }

  .cart-item-info {
    margin-bottom: 12px;
  }

  .cart-item-info h3 {
    margin: 0 0 4px;
    font-size: 0.95rem;
    color: var(--text-strong);
  }

  .cart-item-price {
    margin: 0;
    font-size: 0.9rem;
    color: var(--primary);
    font-weight: 600;
  }

  .cart-item-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .quantity-control {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 999px;
    padding: 4px 8px;
  }

  .quantity-control button {
    width: 24px;
    height: 24px;
    border: none;
    border-radius: 50%;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .quantity-control button:hover:not(:disabled) {
    background: rgba(15, 118, 110, 0.1);
    color: var(--primary);
  }

  .quantity-control button:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .quantity-control span {
    min-width: 24px;
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-strong);
  }

  .cart-item-remove {
    padding: 6px 12px;
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 999px;
    background: transparent;
    color: #ef4444;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .cart-item-remove:hover {
    background: rgba(239, 68, 68, 0.1);
  }

  .cart-footer {
    padding: 20px 24px;
    border-top: 1px solid rgba(15, 23, 42, 0.1);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .cart-total span {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .cart-total strong {
    font-size: 1.2rem;
    color: var(--text-strong);
  }

  .cart-checkout-btn {
    width: 100%;
    padding: 14px 20px;
    border: none;
    border-radius: 999px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cart-checkout-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 20px rgba(15, 118, 110, 0.3);
  }

  .cart-continue-btn {
    width: 100%;
    padding: 12px 20px;
    border: 1px solid rgba(15, 23, 42, 0.15);
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font-size: 0.9rem;
    cursor: pointer;
  }

  .cart-continue-btn:hover {
    border-color: rgba(15, 23, 42, 0.25);
    color: var(--muted);
  }
</style>

<script define:vars={{ locale }} is:inline>
  const CART_KEY = 'dajilin_cart';

  function getCart() {
    try {
      const raw = localStorage.getItem(CART_KEY);
      if (!raw) return { items: [], updatedAt: Date.now() };
      return JSON.parse(raw);
    } catch {
      return { items: [], updatedAt: Date.now() };
    }
  }

  function saveCart(cart) {
    try {
      localStorage.setItem(CART_KEY, JSON.stringify(cart));
    } catch {}
  }

  function updateQuantity(productId, quantity) {
    const cart = getCart();
    const item = cart.items.find(i => i.productId === productId);
    if (item) {
      if (quantity <= 0) {
        cart.items = cart.items.filter(i => i.productId !== productId);
      } else {
        item.quantity = quantity;
      }
    }
    cart.updatedAt = Date.now();
    saveCart(cart);
    renderCart();
    dispatchCartUpdate();
  }

  function removeFromCart(productId) {
    const cart = getCart();
    cart.items = cart.items.filter(i => i.productId !== productId);
    cart.updatedAt = Date.now();
    saveCart(cart);
    renderCart();
    dispatchCartUpdate();
  }

  function getCartTotal(cart) {
    return cart.items.reduce((sum, item) => sum + item.price * item.quantity, 0);
  }

  function getCartItemCount(cart) {
    return cart.items.reduce((sum, item) => sum + item.quantity, 0);
  }

  function dispatchCartUpdate() {
    window.dispatchEvent(new Event('cart_updated'));
  }

  function renderCart() {
    const cart = getCart();
    const cartBody = document.getElementById('cart-body');
    const cartFooter = document.getElementById('cart-footer');
    const cartBadge = document.getElementById('cart-badge');
    const cartTotalValue = document.getElementById('cart-total-value');

    if (!cartBody) return;

    const itemCount = getCartItemCount(cart);
    const cartItemCountEl = document.getElementById('cart-item-count');
    if (cartItemCountEl) cartItemCountEl.textContent = String(itemCount);

    // Update badge
    if (cartBadge) {
      if (itemCount > 0) {
        cartBadge.textContent = itemCount > 99 ? '99+' : String(itemCount);
        cartBadge.style.display = 'flex';
      } else {
        cartBadge.style.display = 'none';
      }
    }

    // Show/hide footer
    if (cartFooter) {
      cartFooter.style.display = cart.items.length > 0 ? 'flex' : 'none';
    }

    if (cart.items.length === 0) {
      cartBody.innerHTML = `
        <div class="cart-empty">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
            <circle cx="9" cy="21" r="1"/>
            <circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          <p>${locale === 'zh' ? '购物车是空的' : locale === 'ja' ? 'カートは空です' : locale === 'ko' ? '장바구니가 비어 있습니다' : 'Your cart is empty'}</p>
        </div>
      `;
      return;
    }

    const itemLabels = {
      zh: { remove: '删除' },
      en: { remove: 'Remove' },
      ja: { remove: '削除' },
      ko: { remove: '삭제' },
    };
    const t = itemLabels[locale] || itemLabels.zh;

    cartBody.innerHTML = `
      <ul class="cart-items">
        ${cart.items.map(item => `
          <li class="cart-item">
            <div class="cart-item-info">
              <h3>${item.name}</h3>
              <p class="cart-item-price">
                ${item.price === 0 ? '价格待定' : `¥${item.price.toFixed(2)}`}
              </p>
            </div>
            <div class="cart-item-actions">
              <div class="quantity-control">
                <button type="button" onclick="window.updateCartQty('${item.productId}', ${item.quantity - 1})" ${item.quantity <= 1 ? 'disabled' : ''}>-</button>
                <span>${item.quantity}</span>
                <button type="button" onclick="window.updateCartQty('${item.productId}', ${item.quantity + 1})">+</button>
              </div>
              <button type="button" class="cart-item-remove" onclick="window.removeCartItem('${item.productId}')">${t.remove}</button>
            </div>
          </li>
        `).join('')}
      </ul>
    `;
  }

  function openCart() {
    const overlay = document.getElementById('cart-sidebar-overlay');
    if (overlay) {
      overlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      renderCart();
    }
  }

  function closeCart() {
    const overlay = document.getElementById('cart-sidebar-overlay');
    if (overlay) {
      overlay.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  // Global functions for inline handlers
  window.updateCartQty = updateQuantity;
  window.removeCartItem = removeFromCart;

  // Event listeners
  document.addEventListener('DOMContentLoaded', () => {
    renderCart();

    const cartIconBtn = document.getElementById('cart-icon-btn');
    const cartCloseBtn = document.getElementById('cart-close-btn');
    const cartContinueBtn = document.getElementById('cart-continue-btn');
    const cartOverlay = document.getElementById('cart-sidebar-overlay');

    if (cartIconBtn) {
      cartIconBtn.addEventListener('click', openCart);
    }

    if (cartCloseBtn) {
      cartCloseBtn.addEventListener('click', closeCart);
    }

    if (cartContinueBtn) {
      cartContinueBtn.addEventListener('click', closeCart);
    }

    if (cartOverlay) {
      cartOverlay.addEventListener('click', (e) => {
        if (e.target === cartOverlay) {
          closeCart();
        }
      });
    }

    // Listen for cart updates from other parts of the page
    window.addEventListener('cart_updated', renderCart);
  });
</script>