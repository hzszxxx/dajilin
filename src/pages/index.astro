const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': 'https://dajilin.net/#organization',
    name: 'dajilin.net',
    url: 'https://dajilin.net',
    description: orgDescriptionMap[locale],
    areaServed: 'CN',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': 'https://dajilin.net/#website',
    url: 'https://dajilin.net',
    name: 'dajilin.net',
    publisher: { '@id': 'https://dajilin.net/#organization' },
    inLanguage: languageTagMap[locale],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': `https://dajilin.net${Astro.url.pathname}#webpage`,
    url: `https://dajilin.net${Astro.url.pathname}`,
    name: siteName,
    description,
    inLanguage: languageTagMap[locale],
    isPartOf: { '@id': 'https://dajilin.net/#website' },
    about: { '@id': 'https://dajilin.net/#organization' },
  },
  buildCollectionPageSchema('/guides', guidesNameMap[locale], description, locale),
];

