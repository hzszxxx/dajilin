const heroPlans = localizedBlock[locale].heroPlans;
const heroHighlights = localizedBlock[locale].heroHighlights;
const trustFacts = localizedBlock[locale].trustFacts;
const quickChannels = localizedBlock[locale].quickChannels;
const discoveryTags = localizedBlock[locale].discoveryTags;
const editorialCards = localizedBlock[locale].editorialCards;
const eventCards = localizedBlock[locale].eventCards;
const seasonCards = localizedBlock[locale].seasonCards;
const aiQuestions = localizedBlock[locale].aiQuestions;
const topicCards = localizedBlock[locale].topicCards;
const localizeIfAvailable = (href: string) => localizePath(href, locale);

---

<BaseLayout title={title} description={description} schemas={schemas} locale={locale} ogImage="/images/home/hero-jilin.jpg">
  <Header />

  <main class="vs-home">
    <section class="vs-hero section-animate">
      <div class="container vs-hero-inner">
        <p class="vs-kicker">{copy.heroKicker}</p>
        <h1>{copy.heroTitle}</h1>
        <p class="vs-lead">{copy.heroLead}</p>
        <div class="vs-actions">
          <a class="button" href={localizePath('/destinations', locale)}>{copy.heroPrimary}</a>
          <button class="button-secondary" type="button" data-open-ai-widget data-ai-question={aiQuestions[0]}>
            {copy.heroSecondary}
          </button>
        </div>
        <div class="vs-highlights">
          {heroHighlights.map((item) => (
            <span>{item}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section vs-channels">
      <div class="container">
        <header class="vs-head">
          <h2>{copy.sectionAHeading}</h2>
          <p>{copy.sectionADesc}</p>
        </header>
        <div class="vs-channel-grid stagger-children">
          {quickChannels.map((item) => (
            <a class="vs-channel-card" href={localizeIfAvailable(item.href)}>
              <div class="vs-channel-image"><img src={item.image} alt={item.title} loading="lazy" /></div>
              <div class="vs-channel-body">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section vs-discovery">
      <div class="container vs-discovery-inner">
        <div>
          <h2>{copy.sectionBHeading}</h2>
          <p>{copy.sectionBDesc}</p>
        </div>
        <div class="vs-tag-row">
          {discoveryTags.map((tag) => (
            <a href="/themes">{tag}</a>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section">
      <div class="container">
        <header class="vs-head">
          <h2>{copy.sectionCHeading}</h2>
          <p>{copy.sectionCDesc}</p>
        </header>
        <div class="vs-plan-grid stagger-children">
          {heroPlans.map((plan) => (
            <a class="vs-plan-card" href={localizeIfAvailable(plan.href)}>
              <span>{plan.tag}</span>
              <h3>{plan.title}</h3>
              <p>{plan.summary}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section vs-map">
      <div class="container vs-map-inner">
        <div class="vs-map-copy">
          <h2>{copy.mapHeading}</h2>
          <p>{copy.mapDesc}</p>
          <div class="vs-actions">
            <a class="button" href={localizePath('/destinations', locale)}>{copy.mapPrimary}</a>
            <a class="button-secondary" href="/self-drive">{copy.mapSecondary}</a>
          </div>
        </div>
        <div class="vs-map-facts">
          {trustFacts.map((fact) => (
            <article>
              <strong>{fact.value}</strong>
              <p>{fact.label}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section">
      <div class="container">
        <header class="vs-head">
          <h2>{copy.seasonHeading}</h2>
          <p>{copy.seasonDesc}</p>
        </header>
        <div class="vs-season-grid stagger-children">
          {seasonCards.map((card) => (
            <article class="vs-season-card">
              <h3>{locale === 'zh' ? `${card.season}季` : card.season}</h3>
              <p>{card.summary}</p>
              <div class="vs-season-links">
                {card.links.map((link) => (
                  <a href={localizeIfAvailable(link.href)}>{link.label}</a>
                ))}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section">
      <div class="container">
        <header class="vs-head">
          <h2>{copy.editorialHeading}</h2>
          <p>{copy.editorialDesc}</p>
        </header>
        <div class="vs-editorial-grid">
          {editorialCards.map((card) => (
            <a class="vs-editorial-card" href={localizeIfAvailable(card.href)}>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </a>
          ))}
        </div>
        <div class="vs-editorial-grid vs-editorial-grid-secondary">
          {eventCards.map((card) => (
            <a class="vs-editorial-card" href={localizeIfAvailable(card.href)}>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section vs-ai">
      <div class="container vs-ai-inner">
        <div>
          <h2>{copy.aiHeading}</h2>
          <p>{copy.aiDesc}</p>
          <div class="vs-actions">
            <button class="button" type="button" data-open-ai-widget>{copy.aiPrimary}</button>
            <a class="button-secondary" href="/cooperation">{copy.aiSecondary}</a>
          </div>
        </div>
        <div class="vs-ai-questions">
          {aiQuestions.map((q) => (
            <button type="button" class="button-secondary" data-open-ai-widget data-ai-question={q}>
              {q}
            </button>
          ))}
        </div>
      </div>
    </section>

    <section class="vs-section">
      <div class="container">
        <header class="vs-head">
          <h2>{copy.exploreHeading}</h2>
        </header>
        <div class="vs-topic-grid">
          {topicCards.map((card) => (
            <a class="vs-topic-card" href={localizeIfAvailable(card.href)}>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
