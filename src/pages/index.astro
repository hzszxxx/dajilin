      { season: '여름', summary: '피서와 산악 체험의 최적 시즌.', color: 'lake-blue', links: [{ label: '창바이산 루트', href: '/destinations/changbai-mountain' }, { label: '自驾攻略概览', href: '/self-drive/overview' }] },
      { season: '가을', summary: '단풍, 도로 경관, 촬영 드라이브에 적합.', color: 'maple-red', links: [{ label: '自驾攻略', href: '/self-drive/how-to-travel' }, { label: '옌볜 체험', href: '/destinations/yanbian' }] },
