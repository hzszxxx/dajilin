const quickChannels = localizedBlock[locale].quickChannels;
const hotServices = localizedBlock[locale].hotServices;
const discoveryTags = localizedBlock[locale].discoveryTags;
const heroPlans = localizedBlock[locale].heroPlans;
const seasonCards = localizedBlock[locale].seasonCards;
const aiQuestions = localizedBlock[locale].aiQuestions;
const topicCards = localizedBlock[locale].topicCards;
const trustFacts = copy.trustFacts;

const localizeIfAvailable = (href: string) => localizePath(href, locale);
---

<BaseLayout title={title} description={description} schemas={schemas} locale={locale} ogImage="/images/home/hero-jilin.jpg">
  <Header />

  <main class="home-shell">

    <!-- ═══════════════════════════════════════
         HERO: 5图轮播
    ═══════════════════════════════════════ -->
    <section class="home-hero" aria-label="首页主视觉">
      <div class="hero-carousel" id="heroCarousel" aria-label="吉林风光轮播">
        <div class="hero-track">
          <div class="hero-slide" aria-hidden="true">
            <img src="/images/home/carousel/1-mountain.jpg" alt="" loading="eager" />
            <div class="slide-overlay"></div>
          </div>
          <div class="hero-slide" aria-hidden="true">
            <img src="/images/home/carousel/2-lake.jpg" alt="" loading="lazy" />
            <div class="slide-overlay"></div>
          </div>
          <div class="hero-slide" aria-hidden="true">
            <img src="/images/home/carousel/3-forest.jpg" alt="" loading="lazy" />
            <div class="slide-overlay"></div>
          </div>
          <div class="hero-slide" aria-hidden="true">
            <img src="/images/home/carousel/4-sunrise.jpg" alt="" loading="lazy" />
            <div class="slide-overlay"></div>
          </div>
          <div class="hero-slide" aria-hidden="true">
            <img src="/images/home/carousel/5-portrait.jpg" alt="" loading="lazy" />
            <div class="slide-overlay"></div>
          </div>
        </div>
        <!-- 指示器 -->
        <div class="hero-dots" role="tablist" aria-label="轮播页码">
          <button class="dot active" role="tab" aria-selected="true" aria-label="第1页" data-slide="0"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="第2页" data-slide="1"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="第3页" data-slide="2"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="第4页" data-slide="3"></button>
          <button class="dot" role="tab" aria-selected="false" aria-label="第5页" data-slide="4"></button>
        </div>
      </div>

      <!-- 文字叠加层 -->
      <div class="home-hero-copy">
        <p class="home-hero-eyebrow">{copy.heroKicker}</p>
        <h1 class="home-hero-title">{copy.heroTitle}</h1>
        <p class="home-hero-lead">{copy.heroLead}</p>
        <div class="home-hero-actions">
          <a class="btn-primary" href={localizePath('/cooperation', locale)}>
            <span class="btn-dot pine-green"></span>{copy.heroPrimary}
          </a>
          <button class="btn-secondary" type="button" data-open-ai-widget data-ai-question={aiQuestions[0]}>
            {copy.heroSecondary}
          </button>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         SECTION A: 四大核心入口
    ═══════════════════════════════════════ -->
    <section class="home-section" aria-labelledby="section-a-heading">
      <div class="home-section-header">
        <div class="section-accent accent-pine"></div>
        <div>
          <h2 id="section-a-heading">{copy.sectionAHeading}</h2>
          <p>{copy.sectionADesc}</p>
        </div>
      </div>
      <div class="home-channel-grid stagger-children">
        {quickChannels.map((ch) => (
          <a class="home-channel-card" href={localizeIfAvailable(ch.href)} data-color={ch.color}>
            <div class="home-channel-image">
              <img src={ch.image} alt={ch.title} loading="lazy" />
            </div>
            <div class="home-channel-body">
              <h3>{ch.title}</h3>
              <p>{ch.body}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         热门服务: 四大服务卡片
    ═══════════════════════════════════════ -->
    <section class="home-section home-hot-services" aria-labelledby="hot-services-heading">
      <div class="home-section-header">
        <div class="section-accent accent-lake"></div>
        <div>
          <h2 id="hot-services-heading">{copy.hotServicesHeading}</h2>
          <p>{copy.hotServicesDesc}</p>
        </div>
      </div>
      <div class="home-hot-grid stagger-children">
        {hotServices.map((svc) => (
          <a class="home-hot-card" href={localizeIfAvailable(svc.href)} data-color={svc.color}>
            <div class="home-hot-card-inner">
              <h3>{svc.title}</h3>
              <p>{svc.body}</p>
              <span class="home-hot-cta">{svc.cta}</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         DISCOVERY: 主题标签云
    ═══════════════════════════════════════ -->
    <section class="home-discovery" aria-labelledby="section-b-heading">
      <div class="home-discovery-inner">
        <div class="home-discovery-copy">
          <h2 id="section-b-heading">{copy.sectionBHeading}</h2>
          <p>{copy.sectionBDesc}</p>
        </div>
        <div class="home-tag-row">
          {discoveryTags.map((tag) => (
            <a class="home-tag" href="/themes">{tag}</a>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         SECTION B: 推荐路线
    ═══════════════════════════════════════ -->
    <section class="home-section" aria-labelledby="section-c-heading">
      <div class="home-section-header">
        <div class="section-accent accent-lake"></div>
        <div>
          <h2 id="section-c-heading">{copy.sectionCHeading}</h2>
          <p>{copy.sectionCDesc}</p>
        </div>
      </div>
      <div class="home-plan-grid stagger-children">
        {heroPlans.map((plan) => (
          <a class="home-plan-card" href={localizeIfAvailable(plan.href)} data-color={plan.color}>
            <span class="home-plan-tag">{plan.tag}</span>
            <h3>{plan.title}</h3>
            <p>{plan.summary}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         为什么通过大吉林咨询
    ═══════════════════════════════════════ -->
    <section class="home-trust-section" aria-labelledby="trust-heading">
      <div class="home-trust-inner">
        <div class="home-trust-header">
          <h2 id="trust-heading">{copy.trustHeading}</h2>
          <p>{copy.trustDesc}</p>
        </div>
        <div class="home-trust-grid">
          {trustFacts.map((fact) => (
            <div class="home-trust-item">
              <strong>{fact.value}</strong>
              <p>{fact.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         SEASON: 四季规划
    ═══════════════════════════════════════ -->
    <section class="home-section" aria-labelledby="season-heading">
      <div class="home-section-header">
        <div class="section-accent accent-maple"></div>
        <div>
          <h2 id="season-heading">{copy.seasonHeading}</h2>
          <p>{copy.seasonDesc}</p>
        </div>
      </div>
      <div class="home-season-grid stagger-children">
        {seasonCards.map((card) => (
          <article class="home-season-card" data-color={card.color}>
            <h3>{locale === 'zh' ? `${card.season}季` : card.season}</h3>
            <p>{card.summary}</p>
            <div class="home-season-links">
              {card.links.map((link) => (
                <a href={localizeIfAvailable(link.href)}>{link.label}</a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         AI 导览
    ═══════════════════════════════════════ -->
    <section class="home-ai" aria-labelledby="ai-heading">
      <div class="home-ai-inner">
        <div class="home-ai-copy">
          <h2 id="ai-heading">{copy.aiHeading}</h2>
          <p>{copy.aiDesc}</p>
          <div class="home-ai-actions">
            <button class="btn-primary" type="button" data-open-ai-widget>{copy.aiPrimary}</button>
            <a class="btn-secondary" href="/cooperation">{copy.aiSecondary}</a>
          </div>
        </div>
        <div class="home-ai-questions">
          {aiQuestions.map((q) => (
            <button type="button" class="btn-question" data-open-ai-widget data-ai-question={q}>{q}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════
         继续探索: 五大主题入口
    ═══════════════════════════════════════ -->
    <section class="home-explore" aria-labelledby="explore-heading">
      <div class="home-section-header">
        <div class="section-accent accent-golden"></div>
        <div>
          <h2 id="explore-heading">{copy.exploreHeading}</h2>
        </div>
      </div>
      <div class="home-topic-grid stagger-children">
