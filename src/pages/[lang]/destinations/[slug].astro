---
import DestinationDetailPage from '@/pages/destinations/[slug].astro';
import { supportedLocales } from '@/lib/i18n';
import { destinationPages } from '@/lib/content-pages';

export const getStaticPaths = () =>
  supportedLocales
    .filter((locale) => locale !== 'zh')
    .flatMap((lang) =>
      destinationPages.map((page) => ({
        params: { lang, slug: page.slug },
        props: { page },
      })),
    );
---

<DestinationDetailPage page={Astro.props.page} />
