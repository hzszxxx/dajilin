---
import GuideDetailPage from '@/pages/guides/[slug].astro';
import { supportedLocales } from '@/lib/i18n';
import { guidePages } from '@/lib/content-pages';

export const getStaticPaths = () =>
  supportedLocales
    .filter((locale) => locale !== 'zh')
    .flatMap((lang) =>
      guidePages.map((page) => ({
        params: { lang, slug: page.slug },
      })),
    );
---

<GuideDetailPage page={{} as any} />
