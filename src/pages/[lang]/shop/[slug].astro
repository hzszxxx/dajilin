---
import ShopDetailPage from '@/pages/shop/[slug].astro';
import { supportedLocales } from '@/lib/i18n';
import { shopPages } from '@/lib/content-pages';

export const getStaticPaths = () =>
  supportedLocales
    .filter((locale) => locale !== 'zh')
    .flatMap((lang) =>
      shopPages.map((page) => ({
        params: { lang, slug: page.slug },
      })),
    );
---

<ShopDetailPage />
