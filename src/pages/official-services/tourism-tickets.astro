---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildCollectionPageSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname);

interface OfficialPortal {
  name: string;
  url: string;
  description: string;
  category: 'ticket' | 'culture' | 'transport' | 'info';
}

interface Copy {
  title: string;
  description: string;
  schemaName: string;
  heading: string;
  intro: string;
  ticketPortalsTitle: string;
  ticketPortalsDesc: string;
  culturePortalsTitle: string;
  culturePortalsDesc: string;
  bookingTitle: string;
  bookingSteps: { step: string; desc: string }[];
  precautionsTitle: string;
  precautions: string[];
  faqTitle: string;
  faqs: { q: string; a: string }[];
  relatedTitle: string;
}

const copy: Record<Locale, Copy> = {
  zh: {
    title: '吉林官方文旅与票务入口说明 | dajilin.net',
