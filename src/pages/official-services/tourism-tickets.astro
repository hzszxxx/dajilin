      { step: '관광지와 날짜 확인', desc: '공식 발표로 개방 상태와 인원 제한 규정을 사전 확인.' },
      { step: '공식 채널 선택', desc: '아래 공식 입구에서 예약 페이지에 접속.' },
      { step: '여행 정보 입력', desc: '신분증, 인원, 날짜 등 필요 정보를 기입.' },
      { step: '결제 및 확인 완료', desc: '결제 후 확인서를 보관. 일부 관광지는 현장에서 신분증 확인 필요.' },
    ],
    precautionsTitle: '주의사항',
    precautions: [
      '공식 티켓 정보는 실시간 업데이트됩니다. 성수기에는 3~7일 전에 예약 권장.',
      '일부 관광지는 시간대별 예약을 실시합니다. 예약 시간대에 맞춰 입장해 주세요.',
      '할인 정책(학생, 노인, 군인 등)은 현장에서 유효한 신분증 확인이 필요합니다.',
      '플랫폼은 공식 예약을 대체하지 않습니다. 질문이 있으시면 공식 고객센터에 연락하세요.',
      '티켓 분쟁이 발생하면 공식 채널에서 항소하는 것을 권장합니다.',
    ],
    faqTitle: '주요 질문',
    faqs: [
      { q: '플랫폼에서 직접 티켓 구매 가능한가요?', a: '현재 플랫폼은 티켓 판매를 하지 않으며, 공식 입구 설명과 예약 안내가 주요 업무입니다.' },
      { q: '왜 공식 입구からの 예약을 해야 하나요?', a: '공식 입구는 정보의 실시간성과 정확성을 보장하며, 애프터서비스와 환불에 유일한 채널입니다.' },
      { q: '예약 후 티켓을 수령해야 하나요?', a: '대부분의 관광지는 신분증으로 직접 입장이 가능합니다. 공식 안내를 따르세요.' },
      { q: '어린이도 예약이 필요한가요?', a: '일부 관광지는 어린이 무료 또는 할인 정책이 있습니다. 사전 확인을 권장합니다.' },
    ],
    relatedTitle: '관련 서비스',
  },
};

const t = copy[locale];

const ticketPortals: OfficialPortal[] = [
  {
    name: '吉林省文化和旅游厅',
    url: 'https://www.jlsgh.gov.cn',
    description: locale === 'zh' ? '吉林省文化和旅游厅官方网站，提供文旅政策、公告和公共服务信息。' : 'Official website of Jilin Provincial Department of Culture and Tourism.',
    category: 'culture',
  },
  {
    name: '长白山官方票务平台',
    url: 'https://www.wbcbs.com',
    description: locale === 'zh' ? '长白山景区官方票务预约平台，支持分时预约和电子票务。' : 'Official ticketing platform for Changbai Mountain scenic area with time-slot booking.',
    category: 'ticket',
  },
  {
    name: '全国旅游监管服务平台',
    url: 'https://lxs.mct.gov.cn',
    description: locale === 'zh' ? '文化和旅游部官方监管平台，提供团队游和导游信息查询。' : 'Ministry of Culture and Tourism supervision platform for group tours and guides.',
    category: 'info',
  },
  {
    name: '12301旅游投诉热线',
    url: 'tel:12301',
    description: locale === 'zh' ? '全国旅游投诉服务热线，可处理旅游纠纷和咨询。' : 'National tourism complaint hotline for disputes and inquiries.',
    category: 'info',
  },
];

const culturePortals: OfficialPortal[] = [
  {
    name: '吉林省文化和旅游厅',
    url: 'https://www.jlsgh.gov.cn',
    description: locale === 'zh' ? '文旅政策发布、公告通知和公共服务事项办理入口。' : 'Policy releases, announcements, and public service portals.',
    category: 'culture',
  },
  {
    name: '长春市文化广播电视和旅游局',
    url: 'http://wgxj.changchun.gov.cn',
    description: locale === 'zh' ? '长春市文旅信息发布和行业管理入口。' : 'Changchun culture, broadcasting and tourism information portal.',
    category: 'culture',
  },
  {
    name: '延边州文化广播电视和旅游局',
    url: 'http://whgdxzf.yanbian.gov.cn',
    description: locale === 'zh' ? '延边州文旅资源介绍和服务信息。' : 'Yanbian cultural and tourism resource guide and service information.',
    category: 'culture',
  },
];

const getPortalIcon = (category: OfficialPortal['category']): string => {
  const icons: Record<string, string> = {
    ticket: '🎫',
    culture: '🏛️',
    transport: '🚌',
    info: 'ℹ️',
  };
  return icons[category] || '🔗';
};
---

<BaseLayout
  title={t.title}
  description={t.description}
  schemas={[buildCollectionPageSchema('/official-services/tourism-tickets', t.schemaName, t.description, locale)]}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-copy">
          <div class="eyebrow">Official Services</div>
          <h1>{t.heading}</h1>
          <p class="lead">{t.intro}</p>
        </div>

        <div class="info-section">
          <h2>{t.ticketPortalsTitle}</h2>
          <p class="section-desc">{t.ticketPortalsDesc}</p>
          <div class="portal-grid">
            {ticketPortals.map((portal) => (
              <a class="portal-card" href={portal.url} target="_blank" rel="noopener noreferrer">
                <span class="portal-icon">{getPortalIcon(portal.category)}</span>
                <div class="portal-body">
                  <h3>{portal.name}</h3>
                  <p>{portal.description}</p>
                </div>
                <span class="portal-arrow">↗</span>
              </a>
            ))}
          </div>
        </div>

        <div class="info-section">
          <h2>{t.culturePortalsTitle}</h2>
          <p class="section-desc">{t.culturePortalsDesc}</p>
          <div class="portal-grid">
            {culturePortals.map((portal) => (
              <a class="portal-card" href={portal.url} target="_blank" rel="noopener noreferrer">
                <span class="portal-icon">{getPortalIcon(portal.category)}</span>
                <div class="portal-body">
                  <h3>{portal.name}</h3>
                  <p>{portal.description}</p>
                </div>
                <span class="portal-arrow">↗</span>
              </a>
            ))}
          </div>
        </div>

        <div class="info-section">
          <h2>{t.bookingTitle}</h2>
          <ol class="booking-steps">
            {t.bookingSteps.map((item) => (
              <li class="booking-step">
                <span class="step-number">{t.bookingSteps.indexOf(item) + 1}</span>
                <div>
                  <strong>{item.step}</strong>
                  <p>{item.desc}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>

        <div class="info-section">
          <h2>{t.precautionsTitle}</h2>
          <ul class="precautions-list">
            {t.precautions.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </section>

      <aside class="page-card">
        <h3>{t.faqTitle}</h3>
        <dl class="faq-list">
          {t.faqs.map((faq) => (
            <div class="faq-item">
              <dt>{faq.q}</dt>
              <dd>{faq.a}</dd>
            </div>
          ))}
        </dl>

        <h3>{t.relatedTitle}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/official-services', locale)}>{locale === 'zh' ? '官方服务总览' : 'Official Services Overview'}</a></li>
          <li><a href={localizePath('/destinations', locale)}>{locale === 'zh' ? '吉林目的地' : 'Jilin Destinations'}</a></li>
          <li><a href={localizePath('/ai-assistant', locale)}>{locale === 'zh' ? 'AI 助手' : 'AI Assistant'}</a></li>
          <li><a href={localizePath('/cooperation', locale)}>{locale === 'zh' ? '合作咨询' : 'Cooperation'}</a></li>
        </ul>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .info-section {
    margin-block: 2.5rem;
  }

  .info-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-block-end: 0.75rem;
  }

  .section-desc {
    color: var(--color-muted);
    margin-block-end: 1.25rem;
    font-size: 0.9375rem;
  }

  .portal-grid {
    display: grid;
    gap: 1rem;
  }

  .portal-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.125rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .portal-card:hover {
    border-color: var(--color-primary);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .portal-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    line-height: 1;
  }

  .portal-body {
    flex: 1;
    min-width: 0;
  }

  .portal-body h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-block-end: 0.25rem;
  }

  .portal-body p {
    font-size: 0.875rem;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.5;
  }

  .portal-arrow {
    color: var(--color-primary);
    font-size: 1.125rem;
    flex-shrink: 0;
  }

  .booking-steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  .booking-step {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .step-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-primary);
    color: white;
    border-radius: 50%;
    font-weight: 600;
    font-size: 0.875rem;
    flex-shrink: 0;
  }

  .booking-step strong {
    display: block;
    margin-block-end: 0.25rem;
  }

  .booking-step p {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }

  .precautions-list {
    list-style: none;
    padding: 0;
