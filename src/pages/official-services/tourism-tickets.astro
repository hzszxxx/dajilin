    culturePortalsDesc: '官方文旅厅、文化活动和旅游服务平台，提供权威信息和在线预约功能。',
    bookingTitle: '预约购票说明',
    bookingSteps: [
      { step: '确认景区与日期', desc: '提前查阅官方公告，了解开放状态和限流规则。' },
      { step: '选择官方渠道', desc: '通过下方列出的官方入口进入预约页面。' },
      { step: '填写出行信息', desc: '按要求填写身份证、人数、日期等必要信息。' },
      { step: '完成支付与确认', desc: '支付后保留凭证，部分景区需现场核验身份证。' },
    ],
    precautionsTitle: '注意事项',
    precautions: [
      '官方票务以实时发布为准，高峰期建议提前 3-7 天预约。',
