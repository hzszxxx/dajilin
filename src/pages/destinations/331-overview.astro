---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildWebPageSchema, buildCollectionPageSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname) as Locale;
const isZh = locale === 'zh';

const pageTitle = '吉林331国道路线概览';
const pageDescription = '建立331吉林段作为重要线路资源的总入口，帮助用户先理解线路逻辑，再继续看驿站、自驾与补给内容。';
const pagePath = '/destinations/331-overview';

const copy: Record<Locale, {
  eyebrow: string;
  intro: string;
  whatIsThis: string;
  whatIsThisBody: string;
  audience: string;
  audienceList: string[];
  highlights: string;
  highlightsList: string[];
  howToPlan: string;
  howToPlanBody: string;
  howToPlanList: string[];
  officialEntry: string;
  officialEntryBody: string;
  notes: string;
  notesList: string[];
  consultEntry: string;
  faqTitle: string;
  faqs: { q: string; a: string }[];
}> = {
  zh: {
    eyebrow: '331国道',
