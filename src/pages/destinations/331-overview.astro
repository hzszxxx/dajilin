const t = copy[locale];
const schemas = [
  buildWebPageSchema(pagePath, pageTitle, pageDescription, locale),
  buildCollectionPageSchema(pagePath, pageTitle, pageDescription, locale),
];
---

<BaseLayout title={`${pageTitle} | dajilin.net`} description={pageDescription} schemas={schemas} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">{t.eyebrow}</div>
            <h1>{isZh ? pageTitle : t.eyebrow}</h1>
            <p>{isZh ? pageDescription : t.intro}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.whatIsThis}</h2>
          <p>{t.whatIsThisBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.audience}</h2>
          <ul>
            {t.audienceList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlights}</h2>
          <ul>
            {t.highlightsList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.howToPlan}</h2>
          <p>{t.howToPlanBody}</p>
          <ul>
            {t.howToPlanList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.officialEntry}</h2>
          <p>{t.officialEntryBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.notes}</h2>
          <ul>
            {t.notesList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{isZh ? '建议继续浏览' : 'Continue Reading'}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/self-drive', locale)}>{isZh ? '查看自驾攻略主页' : 'View Self-Drive Guide main page'}</a></li>
          <li><a href={localizePath('/self-drive/play', locale)}>{isZh ? '查看自驾攻略怎么玩' : 'View how to travel Self-Drive'}</a></li>
          <li><a href={localizePath('/self-drive/stations', locale)}>{isZh ? '查看驿站服务说明' : 'View station services'}</a></li>
          <li><a href={localizePath('/self-drive/supplies', locale)}>{isZh ? '查看补给与住宿建议' : 'View supplies and stays'}</a></li>
        </ul>

        <div class="detail-side-card">
          <h3>{t.consultEntry}</h3>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-page-url={pagePath}>
              {isZh ? '先问 AI 助手' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {isZh ? '提交咨询' : 'Submit Consultation'}
            </a>
          </div>
        </div>

</aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
