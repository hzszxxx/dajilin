      { q: '331국도에 며칠이 필요한가요?', a: '지린 구간全程에는 약 5-7일이 필요합니다. 연변 정석 구간（연길-두만-훈춘）만 경우에는 2-3일이면 됩니다.' },
      { q: '331국도에 가장 좋은 계절은?', a: '6-9월이 최적이며（여름과 초가을）, 9월 중하순 가을빛이 가장 아름답습니다. 겨울에는 눈雾凇과 눈 경관이 있지만保暖과 도로状況에 주의가 필요합니다.' },
      { q: '331국도와「가장 아름다운 국경길」의 관계는?', a: '331국도 지린 구간은「가장 아름다운 국경길」（228국도）의 지린 구간의 일부로, 두 노선은 部分的に重合하며, 331은より国境 체험에 중점을 두고 있습니다.' },
    ],
  },
};

const t = copy[locale];
const schemas = [
  buildWebPageSchema(pagePath, pageTitle, pageDescription, locale),
  buildTouristDestinationSchema(pagePath, pageTitle, pageDescription, locale),
];
---

<BaseLayout title={`${pageTitle} | dajilin.net`} description={pageDescription} schemas={schemas} locale={locale} ogImage="/images/home/yanbian.jpg">
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">{t.eyebrow}</div>
            <h1>{isZh ? pageTitle : t.eyebrow}</h1>
            <p>{isZh ? pageDescription : t.intro}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.whatIsThis}</h2>
          <p>{t.whatIsThisBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.route}</h2>
          <ul>
            {t.routeList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlights}</h2>
          <ul>
            {t.highlightsList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.nodes}</h2>
          <div class="node-cards">
            {t.nodesList.map((node) => (
              <article class="node-card">
                <h3>{node.name}</h3>
                <p>{node.desc}</p>
                <a href={localizePath(`/self-drive/nodes/${node.name.toLowerCase().replace('节点','').replace('node','')}`, locale)} class="node-link">
                  {isZh ? '查看详情 →' : 'View details →'}
                </a>
              </article>
            ))}
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.howToPlan}</h2>
          <p>{t.howToPlanBody}</p>
          <ul>
            {t.howToPlanList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.officialEntry}</h2>
          <p>{t.officialEntryBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.notes}</h2>
          <ul>
            {t.notesList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{isZh ? '建议继续浏览' : 'Continue Reading'}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/self-drive/overview', locale)}>{isZh ? '331国道吉林段概览' : 'Route 331 Jilin Overview'}</a></li>
          <li><a href={localizePath('/self-drive/nodes/yanji', locale)}>{isZh ? '延吉节点' : 'Yanji Node'}</a></li>
          <li><a href={localizePath('/self-drive/nodes/hunchun', locale)}>{isZh ? '珲春节点' : 'Hunchun Node'}</a></li>
          <li><a href={localizePath('/self-drive/nodes/tumen', locale)}>{isZh ? '图们节点' : 'Tumen Node'}</a></li>
          <li><a href={localizePath('/self-drive/nodes/changbai', locale)}>{isZh ? '长白节点' : 'Changbai Node'}</a></li>
          <li><a href={localizePath('/themes/roadtrip-331', locale)}>{isZh ? '331主题游' : 'Route 331 Theme'}</a></li>
        </ul>

        <div class="detail-side-card">
          <h3>{t.consultEntry}</h3>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-page-url={pagePath}>
              {isZh ? '先问 AI 助手' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {isZh ? '提交咨询' : 'Submit Consultation'}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .node-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .node-card {
    background: var(--color-surface, #f8f9fa);
    padding: 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--color-border, #e5e7eb);
  }
  .node-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--primary);
  }
  .node-card p {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #666);
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }
  .node-link {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--primary);
    text-decoration: none;
  }
  .node-link:hover {
    text-decoration: underline;
  }
</style>
