---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import DetailPage from '@/components/astro/DetailPage.astro';
import { buildCollectionPageSchema, buildWebPageSchema, buildTouristDestinationSchema, buildItemListSchema } from '@/lib/schema';
import { destinationPages, findDetailPage, getPageLocalization } from '@/lib/content-pages';
import type { Locale } from '@/lib/i18n';
import { getLocaleFromPathname, localizePath } from '@/lib/i18n';

export function getStaticPaths() {
  return destinationPages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page: staticPage } = Astro.props;
const page = staticPage ?? findDetailPage('destinations', Astro.params.slug ?? '');
const locale = getLocaleFromPathname(Astro.url.pathname) as Locale;
const localizedPath = localizePath(page?.pathname ?? '/destinations', locale);
const localized = getPageLocalization(page, locale);
const localizedTitle = localized.title;
const localizedDescription = localized.description;

if (!page) {
  throw new Error(`Unknown destination page: ${Astro.params.slug}`);
}

const schemas = [
  buildWebPageSchema(localizedPath, localizedTitle, localizedDescription, locale),
  buildCollectionPageSchema(localizedPath, localizedTitle, localizedDescription, locale),
  buildTouristDestinationSchema(localizedPath, localizedTitle, localizedDescription, locale),
  buildItemListSchema(
    localizedPath,
    locale === 'zh' ? '相关目的地' : 'Related Destinations',
    destinationPages
      .filter((p) => p.slug !== page.slug)
      .slice(0, 3)
      .map((p) => ({
        url: localizePath(p.pathname, locale),
        name: locale === 'zh' ? p.title : p.eyebrow,
      })),
    locale,
  ),
];
---

<BaseLayout title={`${localizedTitle} | dajilin.net`} description={localizedDescription} schemas={schemas} locale={locale}>
  <Header />
  <main class="page-shell">
    <DetailPage page={page} />
  </main>
  <Footer />
</BaseLayout>
