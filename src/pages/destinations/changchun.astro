---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildWebPageSchema, buildTouristDestinationSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname) as Locale;
const isZh = locale === 'zh';

const pageTitle = '长春旅游与城市玩法指南';
const pageDescription = '从城市文旅、工业文明、亲子与团体体验角度理解长春，帮助用户找到适合自己的吉林入口城市。';
const pagePath = '/destinations/changchun';

const copy: Record<Locale, {
  eyebrow: string;
  intro: string;
  whatIsThis: string;
  whatIsThisBody: string;
  audience: string;
  audienceList: string[];
  highlights: string;
  highlightsList: string[];
  howToPlan: string;
  howToPlanBody: string;
  howToPlanList: string[];
  officialEntry: string;
  officialEntryBody: string;
  notes: string;
  notesList: string[];
  consultEntry: string;
  faqTitle: string;
  faqs: { q: string; a: string }[];
}> = {
  zh: {
    eyebrow: '长春',
    intro: '长春适合做吉林旅行的第一站。这里既有城市文旅和生活体验，也能延展到工业研学、企业参访和亲子路线。',
    whatIsThis: '什么是长春玩法',
    whatIsThisBody: '长春是吉林省会，也是进入吉林旅游最常用的城市型入口。它不是单一景点目的地，而是工业文明、城市街区、品牌记忆和区域交通枢纽的组合。理解长春的关键，是先把它当成一个了解吉林的入口，而不是一个景点终点。',
    audience: '适合哪些用户',
    audienceList: ['第一次来吉林、想先理解城市气质的游客', '对工业文明与品牌文化感兴趣的用户', '亲子、研学、政企活动与团体组织者', '需要城市间交通枢纽功能的出行者'],
    highlights: '有哪些看点',
    highlightsList: ['伪满皇宫博物院：了解近代历史的建筑群', '这有山：城市生活与商业文化结合的室内文旅综合体', '54路有轨电车：城市历史遗产线路', '一汽红旗：工业文明与民族品牌展示', '中车长客：轨道交通制造参观资源', '长春电影制片厂：电影工业历史遗迹'],
    howToPlan: '如何安排',
    howToPlanBody: '长春的安排逻辑取决于你的出行目标：',
    howToPlanList: ['城市体验型：伪满皇宫 + 这有山 + 城市街区散步，适合 1-2 天', '工业研学型：一汽红旗 + 中车长客 + 工业文明线路，适合 1-2 天团体行程', '亲子活动型：结合城市公园、文博场馆和团体动手体验，适合半天到一天', '多目的地串联：长春作为入口，往长白山、延边或 331 国道方向延展'],
    officialEntry: '官方入口与说明',
    officialEntryBody: '长春城市旅游以自由参观为主，部分工业参访和文博场馆需要提前预约或通过官方渠道确认开放时间。建议关注各场馆官方公告获取最新信息。',
    notes: '注意事项',
    notesList: ['工业参访类资源通常需要提前联系和预约', '伪满皇宫等热门场馆建议避开节假日高峰', '冬季路面可能有冰雪，行车需注意安全', '城市内公共交通便利，适合绿色出行'],
    consultEntry: '咨询入口',
    faqTitle: '常见问题',
    faqs: [
      { q: '长春更适合自由行还是团体活动？', a: '两类都适合。如果涉及工业研学与企业参访，建议优先按团体或机构场景理解和安排。' },
      { q: '长春与吉林其他目的地如何衔接？', a: '长春适合作为理解吉林的入口城市，后续可继续延展到长白山、延边和 331 国道等专题。' },
      { q: '需要提前预约工业参访吗？', a: '是的，一汽红旗和中车长客等工业参访资源通常需要提前联系和确认接待条件。' },
    ],
  },
  en: {
    eyebrow: 'Changchun',
    intro: 'Changchun is an ideal first stop for Jilin travel. It offers urban cultural experiences and can extend to industrial study tours, corporate visits, and family routes.',
    whatIsThis: 'What is Changchun',
    whatIsThisBody: 'Changchun is the capital of Jilin Province and the most common urban entry point for traveling in Jilin. It is not a single-attraction destination but a combination of industrial heritage, urban neighborhoods, brand memories, and regional transportation hubs.',
    audience: 'Who is it suitable for',
    audienceList: ['First-time visitors wanting to understand Jilins urban character', 'Users interested in industrial heritage and brand culture', 'Families, study groups, corporate and institutional organizers', 'Travelers needing inter-city transportation hub services'],
    highlights: 'Key Highlights',
    highlightsList: ['Puppet Emperors Palace Museum: Architectural complex for modern history', 'Chi You Mountain: Indoor cultural complex combining urban life', 'Route 54 Heritage Tram: Urban historical heritage line', 'FAW Hongqi: Industrial civilization and national brand display', 'CRRC Changchun: Rail transit manufacturing visit resources', 'Changchun Film Studio: Film industry historical site'],
    howToPlan: 'How to Plan',
    howToPlanBody: 'How you arrange your Changchun visit depends on your travel goal:',
    howToPlanList: ['Urban experience: Puppet Palace + Chi You Mountain + city walks, suitable for 1-2 days', 'Industrial study: FAW Hongqi + CRRC + industrial routes, suitable for 1-2 day group visits', 'Family activities: City parks, museums, hands-on experiences, suitable for half to full day', 'Multi-destination: Use Changchun as entry point, extend to Changbai Mountain, Yanbian, or Route 331'],
    officialEntry: 'Official Entry Points',
    officialEntryBody: 'Changchun urban tourism is mainly self-guided. Some industrial visits and museum venues require advance booking or confirmation through official channels.',
    notes: 'Important Notes',
    notesList: ['Industrial visits usually require advance contact and booking', 'Popular venues like Puppet Palace should be avoided during holidays', 'Winter roads may have ice and snow', 'City public transport is convenient'],
    consultEntry: 'Consultation',
    faqTitle: 'FAQ',
    faqs: [
      { q: 'Is Changchun better for independent travel or group activities?', a: 'Both are suitable. For industrial study tours and corporate visits, group or institutional arrangements are recommended.' },
      { q: 'How does Changchun connect to other Jilin destinations?', a: 'Changchun serves as an entry city for understanding Jilin, and can extend to Changbai Mountain, Yanbian, and Route 331.' },
      { q: 'Do I need to book industrial visits in advance?', a: 'Yes, industrial visit resources like FAW Hongqi and CRRC usually require advance contact and confirmation.' },
    ],
  },
  ja: {
    eyebrow: '長春',
    intro: '長春は吉林旅行の第一拠点に最適です。都市文旅と生活体験があり、産業研修や企業訪問、親子ルートにも延伸できます。',
    whatIsThis: '長春とは',
    whatIsThisBody: '長春は吉林省の省都で、吉林観光で最も一般的な都市型入口です。单一観光地ではなく、産業文明、都市街区、ブランド記憶と地域交通結節点の組み合わせです。',
    audience: 'こんなユーザーに最適',
    audienceList: ['初めて吉林を訪れ、都市の雰囲気を先に理解したい旅行者', '産業文明とブランド文化に興味があるユーザー', '親子、産業研修、政企·団体イベント主催者', '都市間交通結節点が必要な旅行者'],
    highlights: '見どころ',
    highlightsList: ['偽満皇宫博物院：近代歴史を知る建築群', 'これにある山：都市生活と商業文化相结合的室内文旅综合体', '54路軌道電車：都市歴史遺産ルート', '一汽红旗：産業文明と民族ブランド展示', '中車長客：軌道交通製造見学リソース', '長春映画制片廠：映画工業歴史名勝'],
    howToPlan: '周り方',
    howToPlanBody: '長春の旅程は旅行目的によって違います：',
    howToPlanList: ['都市体験型：偽満皇宫＋これにある山＋都市散策、1-2日が適切', '産業研修型：一汽红旗＋中車長客＋産業文明ルート、1-2日の団体行程に適切', '親子イベント型：都市公園、博物館、体験アクティビティ、半天から一日', '複数目的地連携：長春を経由口に長白山、延辺、331国道へ延伸'],
    officialEntry: '公式入口と説明',
    officialEntryBody: '長春の都市観光は主として自由見学です。一部の産業見学と博物館は事前予約または公式渠道での確認が必要です。',
    notes: '注意事項',
    notesList: ['産業見学リソースは通常事前連絡と予約が必要です', '偽満皇宫などの人気场馆は祝日高峰を避けた方がよい', '冬季は路面に冰雪がある可能性があり、注意が必要', '都市内公共交通が便利で、エコtravelに最適'],
    consultEntry: '相談入口',
    faqTitle: 'よくある質問',
    faqs: [
      { q: '長春は個人旅行と団体アクティビティのどちらに適していますか？', a: '両方適しています。産業研修や企業訪問がある場合は、団体または機構シーンでの手配を優先してください。' },
      { q: '長春と吉林的其他目的地はどう繋げますか？', a: '長春は吉林を理解する入口都市として適しており、以降長白山、延辺、331国道などの专题に延伸できます。' },
      { q: '産業見学は事前予約が必要ですか？', a: 'はい、一汽红旗や中車長客などの産業見学リソースは通常事前連絡と受入条件の確認が必要です。' },
    ],
  },
  ko: {
    eyebrow: '창춘',
    intro: '창춘은 지린 여행의 첫 번째 거점으로 적합합니다. 도시文旅과 생활 체험이 있으며, 산업 연수, 기업 방문, 가족 루트으로도 확장할 수 있습니다.',
    whatIsThis: '창춘이란',
    whatIsThisBody: '창춘은 지린성의 성도이며 지린 관광에서 가장 일반적인 도시형 진입점입니다. 단일 관광지가 아니라 산업 문명, 도시 지구, 브랜드 기억과 지역 교통 허브의 조합입니다.',
    audience: '이런 사용자에게 적합',
    audienceList: ['처음 지린을 방문하여 도시 분위기를 먼저 이해하고 싶은 여행자', '산업 문명과 브랜드 문화에 관심이 있는 사용자', '가족, 산업 연수, 기업·단체 행사 주관자', '도시 간 교통 허브 기능이 필요한 여행자'],
    highlights: '주요 볼거리',
    highlightsList: ['위만황궁 박물관: 근대 역사를 알아볼 수 있는 건축군', '치유산: 도시 생활과 상업 문화를 결합한 실내文旅 복합체', '54번 노면전차: 도시 역사 유산 노선', '一汽 홍치: 산업 문명과 민족 브랜드 전시', '중차창객: 철도 교통 제조 방문 자원', '창춘 영화制片廠: 영화 공업 역사 유적지'],
    howToPlan: '일정 잡기',
    howToPlanBody: '창춘 일정 계획은 여행 목표에 따라 다릅니다:',
    howToPlanList: ['도시 체험형: 위만황궁 + 치유산 + 도시 산책, 1-2일이 적합', '산업 연수형:一汽 홍치 + 중차창객 + 산업 문명 노선, 1-2일 단체 일정에 적합', '가족 이벤트형: 도시 공원, 박물관, 체험アクティビティ, 반나절에서 하루', '복수 목적지 연계: 창춘을 경유지로 장백산, 연변, 331국도로 확장'],
    officialEntry: '공식 입구와 설명',
    officialEntryBody: '창춘 도시 관광은 주로 자유 견학입니다. 일부 산업 방문과 박물관场馆은 사전 예약 또는 공식 채널을 통한 확인이 필요합니다.',
    notes: '주의사항',
    notesList: ['산업 방문 자원은 일반적으로 사전 연락과 예약이 필요합니다', '위만황궁 등 인기场馆은 휴일 피크를 피하는 것이 좋습니다', '겨울에는 도로에 눈과 얼음이 있을 수 있어 주의가 필요합니다', '도시 내 대중교통이 편리하여 환경 보호 여행에 적합합니다'],
    consultEntry: '상담 입구',
    faqTitle: '자주 묻는 질문',
    faqs: [
      { q: '창춘은 개인 여행과 단체 활동 중哪一种이 더 적합합니까?', a: '둘 다 적합합니다. 산업 연수나 기업 방문이 있으면 단체 또는 기관 장면에서 먼저 이해하고手配하는 것이 좋습니다.' },
      { q: '창춘과 지린의 다른 목적지는 어떻게 연결합니까?', a: '창춘은 지린을 이해하는 진입 도시로 적합하며, 이후 장백산, 연변, 331국도 등의 주제로 확장할 수 있습니다.' },
      { q: '산업 방문은 사전 예약이 필요합니까?', a: '네,一汽 홍치, 중차창객 등의 산업 방문 자원은 일반적으로 사전 연락과 접수 조건 확인이 필요합니다.' },
    ],
  },
};

const t = copy[locale];
const schemas = [
  buildWebPageSchema(pagePath, pageTitle, pageDescription, locale),
  buildTouristDestinationSchema(pagePath, pageTitle, pageDescription, locale),
];
---

<BaseLayout title={`${pageTitle} | dajilin.net`} description={pageDescription} schemas={schemas} locale={locale} ogImage="/images/home/changchun.jpg">
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">{t.eyebrow}</div>
            <h1>{isZh ? pageTitle : t.eyebrow}</h1>
            <p>{isZh ? pageDescription : t.intro}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.whatIsThis}</h2>
          <p>{t.whatIsThisBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.audience}</h2>
          <ul>
            {t.audienceList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlights}</h2>
          <ul>
            {t.highlightsList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.howToPlan}</h2>
          <p>{t.howToPlanBody}</p>
          <ul>
            {t.howToPlanList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.officialEntry}</h2>
          <p>{t.officialEntryBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.notes}</h2>
          <ul>
            {t.notesList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{isZh ? '建议继续浏览' : 'Continue Reading'}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/destinations', locale)}>{isZh ? '查看所有目的地' : 'View all destinations'}</a></li>
          <li><a href={localizePath('/study-tours', locale)}>{isZh ? '查看工业研学专题' : 'View study tours'}</a></li>
          <li><a href={localizePath('/self-drive', locale)}>{isZh ? '查看自驾攻略' : 'View Self-Drive Guide'}</a></li>
          <li><a href={localizePath('/themes', locale)}>{isZh ? '查看主题玩法' : 'View theme experiences'}</a></li>
        </ul>

        <div class="detail-side-card">
          <h3>{t.consultEntry}</h3>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-page-url={pagePath}>
              {isZh ? '先问 AI 助手' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {isZh ? '提交咨询' : 'Submit Consultation'}
            </a>
          </div>
        </div>

</aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
