---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildWebPageSchema, buildTouristDestinationSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname) as Locale;
const isZh = locale === 'zh';

const pageTitle = '延边旅游与边境文化体验指南';
const pageDescription = '围绕延边的边境文化、美食体验和路线延展能力，建立更适合内容引流与主题玩法的区域入口。';
const pagePath = '/destinations/yanbian';

const copy: Record<Locale, {
  eyebrow: string;
  intro: string;
  whatIsThis: string;
  whatIsThisBody: string;
  audience: string;
  audienceList: string[];
  highlights: string;
  highlightsList: string[];
  howToPlan: string;
  howToPlanBody: string;
  howToPlanList: string[];
  officialEntry: string;
  officialEntryBody: string;
  notes: string;
  notesList: string[];
  consultEntry: string;
  faqTitle: string;
  faqs: { q: string; a: string }[];
}> = {
  zh: {
    eyebrow: '延边',
    intro: '延边适合做边境文化、美食与线路体验的专题型目的地。它不是单点游览，更适合和主题玩法、自驾路线一起理解。',
    whatIsThis: '什么是延边体验',
    whatIsThisBody: '延边地区最独特的价值不是单一景点，而是边境文化、朝鲜族民俗、美食体验和连续线路感的组合。这里靠近朝鲜半岛边境，有独特的地域文化和饮食传统。它更适合被理解为一个区域体验型目的地，而不是景点型目的地。',
    audience: '适合哪些用户',
    audienceList: ['对边境文化与民族风情感兴趣的用户', '喜欢美食与地方特色餐饮的旅行者', '自驾与线路型深度体验追求者', '希望与 331 国道、边境公路联动的用户', '内容型旅行者（摄影、纪录片、人文探索）'],
    highlights: '有哪些看点',
    highlightsList: ['图们口岸：边境口岸景观，可远眺对面城市', '延吉市：延边朝鲜族自治州首府，城市生活与朝鲜族文化中心', '朝鲜族民俗村：体验朝鲜族传统生活方式的区域', '金达莱花海：春季特色花卉景观', '珲春防川：最东端边境点，可一眼望三国', '延边美食：冷面、烤肉、泡菜等朝鲜族特色餐饮'],
    howToPlan: '如何安排',
    howToPlanBody: '延边的安排逻辑以区域体验和线路联动为核心：',
    howToPlanList: ['延吉中心型：以延吉市为据点，辐射周边景点和美食，适合 2-3 天', '边境线型：沿着边境线路游览，串联图们、珲春等节点', '联动 331 国道：延边是 331 国道吉林段的重要组成部分，可作为路线一部分', '季节选择：春季看金达莱花，夏季凉爽适合避暑，秋季看边境色彩'],
