    notes: '注意事项',
    notesList: ['边境地区需遵守相关规定，不得拍摄军事设施', '部分边境景区需要提前预约和身份登记', '朝鲜族饮食文化独特，可提前了解饮食习惯', '冬季边境地区气温较低，需做好保暖', '延吉市区交通便利，但景点较分散，建议自驾或包车'],
    consultEntry: '咨询入口',
    faqTitle: '常见问题',
    faqs: [
      { q: '延边更适合什么样的旅行者？', a: '更适合希望体验区域文化、美食、边境氛围和线路感的用户。它不是单点游览型目的地。' },
      { q: '延边和 331 国道有什么关系？', a: '延边地区是 331 国道吉林段的重要组成部分，两者可以联动理解，适合边境自驾主题。' },
      { q: '去边境地区需要注意什么？', a: '需遵守边境管理规定，不得拍摄军事设施，部分区域需要预约和身份核验。' },
      { q: '延边美食有什么推荐？', a: '冷面、烤肉、泡菜、米肠、打糕等朝鲜族特色餐饮是延边美食的代表，建议在延吉市的传统餐厅体验。' },
    ],
  },
  en: {
    eyebrow: 'Yanbian',
    intro: 'Yanbian is ideal for themed destination experiences focused on border culture, cuisine, and route-based activities. Its not a single attraction but works best combined with themed activities and self-driving routes.',
    whatIsThis: 'What is Yanbian Experience',
    whatIsThisBody: 'Yanbian regions most unique value is not a single attraction but the combination of border culture, Korean ethnic customs, culinary experiences, and continuous route appeal. Located near the Korean Peninsula border, it has unique regional culture and culinary traditions.',
    audience: 'Who is it suitable for',
    audienceList: ['Travelers interested in border culture and ethnic customs', 'Food lovers seeking local and ethnic cuisine', 'Self-drive and route-based deep experience seekers', 'Users wanting to connect with Route 331 and border roads', 'Content travelers (photography, documentaries, cultural exploration)'],
    highlights: 'Key Highlights',
    highlightsList: ['Tumen Port: Border port scenery with views of the opposite city', 'Yanji City: Capital of Yanbian Korean Autonomous Prefecture, urban life and Korean culture center', 'Korean Ethnic Villages: Areas to experience traditional Korean lifestyle', 'Korean Rhododendron Blooms: Spring floral scenery', 'Hunchun Fangchuan: Easternmost border point, can see three countries', 'Yanbian Cuisine: Cold noodles, BBQ, kimchi and other Korean specialties'],
    howToPlan: 'How to Plan',
