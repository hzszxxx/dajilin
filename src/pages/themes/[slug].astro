---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import DetailPage from '@/components/astro/DetailPage.astro';
import { buildCollectionPageSchema, buildFAQPageSchema } from '@/lib/schema';
import { findDetailPage, themePages } from '@/lib/content-pages';
import { getLocaleFromPathname, localizePath } from '@/lib/i18n';

export function getStaticPaths() {
  return themePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const staticPage = Astro.props.page;
const page = staticPage ?? findDetailPage('themes', Astro.params.slug ?? '');
const locale = getLocaleFromPathname(Astro.url.pathname);

if (!page) {
  return Astro.redirect(localizePath('/themes', locale));
}

const localizedPath = localizePath(page.pathname, locale);
const localizedTitle = locale === 'zh' ? page.title : page.eyebrow;
const localizedDescription = locale === 'zh' ? page.description : `Details for ${localizedTitle}.`;
const schemas: any[] = [buildCollectionPageSchema(localizedPath, localizedTitle, localizedDescription, locale)];
if (page.faqs && page.faqs.length > 0) {
  schemas.push(buildFAQPageSchema(localizedPath, localizedTitle, page.faqs, locale));
}
---

<BaseLayout
  title={`${localizedTitle} | dajilin.net`}
  description={localizedDescription}
  schemas={schemas}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <DetailPage page={page} />
  </main>
  <Footer />
</BaseLayout>
