---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildCollectionPageSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';
import { products, toShopProduct } from '@/lib/products';

const locale = getLocaleFromPathname(Astro.url.pathname);

const copy: Record<
  Locale,
  {
    title: string;
    description: string;
    schemaName: string;
    heading: string;
    categories: {
      tourism: string;
      creative: string;
      specialty: string;
    };
    addToCart: string;
    inStock: string;
    outOfStock: string;
    viewDetails: string;
  }
> = {
  zh: {
    title: '商城 | dajilin.net',
    description: '商城展示文旅产品、地方文创和东北特产，支持购物车和咨询功能。',
    schemaName: '商城',
    heading: '吉林文旅好物',
    categories: {
      tourism: '文旅产品',
      creative: '文创产品',
      specialty: '东北特产',
    },
    addToCart: '加入购物车',
    inStock: '有货',
    outOfStock: '暂时缺货',
    viewDetails: '查看详情',
  },
  en: {
    title: 'Shop | dajilin.net',
    description: 'Shop showcasing tourism services, local creative products, and northeast specialties.',
    schemaName: 'Shop',
    heading: 'Jilin Travel Shop',
    categories: {
      tourism: 'Tourism Products',
      creative: 'Creative Products',
      specialty: 'Northeast Specialties',
    },
    addToCart: 'Add to Cart',
    inStock: 'In Stock',
    outOfStock: 'Out of Stock',
    viewDetails: 'View Details',
  },
  ja: {
    title: 'ショップ | dajilin.net',
    description: '観光サービス、地域文創、東北特産を取り扱うショップです。',
    schemaName: 'ショップ',
    heading: '吉林 旅のセレクト',
    categories: {
      tourism: '観光商品',
      creative: '文創商品',
      specialty: '東北特産',
    },
    addToCart: 'カートに追加',
    inStock: '在庫あり',
    outOfStock: '在庫切れ',
    viewDetails: '詳細を見る',
  },
  ko: {
    title: '샵 | dajilin.net',
    description: '관광 서비스, 지역 굿즈, 동북 특산품을 취급하는 샵입니다.',
    schemaName: '샵',
    heading: '지린 여행 셀렉션',
    categories: {
      tourism: '관광 상품',
      creative: '문창 상품',
      specialty: '동북 특산',
    },
    addToCart: '장바구니에 추가',
    inStock: '재고있음',
    outOfStock: '품절',
    viewDetails: '상세 보기',
  },
};

const t = copy[locale];

// Group products by category (food → specialty, service → tourism)
const tourismProducts = products.filter((p) => p.category === 'service').map(toShopProduct);
const creativeProducts = products.filter((p) => p.category === 'creative').map(toShopProduct);
const specialtyProducts = products.filter((p) => p.category === 'food').map(toShopProduct);

const categoryProducts = [
  { key: 'tourism', label: t.categories.tourism, products: tourismProducts },
  { key: 'creative', label: t.categories.creative, products: creativeProducts },
  { key: 'specialty', label: t.categories.specialty, products: specialtyProducts },
].filter((c) => c.products.length > 0);
---

<BaseLayout title={t.title} description={t.description} schemas={[buildCollectionPageSchema('/shop', t.schemaName, t.description, locale)]} locale={locale}>
  <Header />
  <main class="page-shell shop-shell">
    <div class="container">
      <div class="page-copy">
        <div class="eyebrow">Shop</div>
        <h1>{t.heading}</h1>
        <p>{t.description}</p>
      </div>

      <div class="shop-categories">
        {categoryProducts.map((category) => (
          <section class="category-section">
            <h2 class="category-title">{category.label}</h2>
            <div class="product-grid">
              {category.products.map((product) => (
                <article class="product-card">
                  <div class="product-visual">
                    <img
                      src={product.imageUrl}
                      alt={locale === 'zh' ? product.name : product.nameEn}
                      class="product-image"
                      loading="lazy"
                    />
                    {!product.inStock && (
                      <span class="product-out-badge">{t.outOfStock}</span>
                    )}
                  </div>
                  <div class="product-content">
                    <h3 class="product-name">{locale === 'zh' ? product.name : product.nameEn}</h3>
                    <p class="product-desc">{locale === 'zh' ? product.description : product.descriptionEn}</p>
                    <div class="product-footer">
                      <div class="product-price">
                        {product.price === 0 ? (
                          <span class="price-note">{locale === 'zh' ? '价格待定' : 'Price TBD'}</span>
                        ) : (
                          <span class="price-value">¥{product.price.toFixed(2)}</span>
                        )}
                        <span class="price-unit">/{product.unit}</span>
                      </div>
                      <div class="product-actions">
                        <a href={localizePath(`/shop/${product.slug}`, locale)} class="product-detail-link">
                          {t.viewDetails}
                        </a>
                        <button
                          type="button"
                          class="add-to-cart-btn"
                          data-product-id={product.id}
                          data-product-slug={product.slug}
                          data-product-name={product.name}
                          data-product-name-en={product.nameEn}
                          data-product-price={product.price}
                          data-product-category={product.category}
                          disabled={!product.inStock}
                        >
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2">
                            <circle cx="9" cy="21" r="1" />
                            <circle cx="20" cy="21" r="1" />
                            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                          </svg>
                          {t.addToCart}
                        </button>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>
  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.add-to-cart-btn');
      buttons.forEach((btn) => {
        btn.addEventListener('click', (e) => {
          const target = e.currentTarget as HTMLButtonElement;
          const productId = target.dataset.productId || '';
          const slug = target.dataset.productSlug || '';
          const name = target.dataset.productName || '';
          const nameEn = target.dataset.productNameEn || '';
          const price = parseFloat(target.dataset.productPrice || '0');
          const category = target.dataset.productCategory || 'tourism';

          // Get existing cart
          const cartKey = 'dajilin_cart';
          let cart = { items: [], updatedAt: Date.now() };
          try {
            const raw = localStorage.getItem(cartKey);
            if (raw) cart = JSON.parse(raw);
          } catch {}

          // Check if item already in cart
          const existing = cart.items.find((i: any) => i.productId === productId);
          if (existing) {
            existing.quantity += 1;
          } else {
            cart.items.push({ productId, slug, name, nameEn, price, quantity: 1, category });
          }
          cart.updatedAt = Date.now();

          try {
            localStorage.setItem(cartKey, JSON.stringify(cart));
          } catch {}

          // Dispatch update event
          window.dispatchEvent(new Event('cart_updated'));

          // Visual feedback
          target.classList.add('is-added');
          target.textContent = locale === 'zh' ? '已添加' : 'Added';
          setTimeout(() => {
            target.classList.remove('is-added');
            target.innerHTML = `
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1" />
                <circle cx="20" cy="21" r="1" />
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
              </svg>
              ${locale === 'zh' ? '加入购物车' : 'Add to Cart'}
            `;
          }, 2000);
        });
      });
    });

    // Get locale for button text
    const locale = document.documentElement.lang?.startsWith('zh') ? 'zh' :
                    document.documentElement.lang?.startsWith('ja') ? 'ja' :
                    document.documentElement.lang?.startsWith('ko') ? 'ko' : 'en';
  </script>

  <style>
    .shop-shell {
      padding-bottom: 80px;
    }

    .shop-categories {
      margin-top: 32px;
      display: flex;
      flex-direction: column;
      gap: 48px;
    }

    .category-section {
      background: var(--surface);
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 28px;
      box-shadow: var(--shadow);
    }

    .category-title {
      margin: 0 0 20px;
      font-size: 1.4rem;
      color: var(--text-strong);
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
    }

    .product-card {
      border: 1px solid var(--line);
      border-radius: 20px;
      overflow: hidden;
      background: #fff;
      transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    }

    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 32px rgba(15, 23, 42, 0.1);
      border-color: rgba(15, 118, 110, 0.2);
    }

    .product-visual {
      position: relative;
      height: 160px;
      background: linear-gradient(145deg, #e8f5f3 0%, #e0f2fe 56%, #f0fdf4 100%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .product-image-placeholder.travel {
      background: linear-gradient(145deg, #dbeafe 0%, #e0f2fe 50%, #f0fdf4 100%);
    }

    .product-image-placeholder.creative {
      background: linear-gradient(145deg, #fce7f3 0%, #fdf2f8 50%, #faf5ff 100%);
    }

    .product-image-placeholder.specialty {
      background: linear-gradient(145deg, #fef3c7 0%, #fffbeb 50%, #fef9c3 100%);
    }

    .product-out-badge {
      position: absolute;
      top: 12px;
      right: 12px;
      padding: 4px 10px;
      border-radius: 999px;
      background: rgba(239, 68, 68, 0.9);
      color: #fff;
      font-size: 0.75rem;
      font-weight: 600;
    }

    .product-content {
      padding: 18px;
    }

    .product-name {
      margin: 0 0 8px;
      font-size: 1.05rem;
      color: var(--text-strong);
    }

    .product-desc {
      margin: 0 0 14px;
      font-size: 0.88rem;
      color: var(--muted);
      line-height: 1.6;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-footer {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: 12px;
    }

    .product-price {
      display: flex;
      align-items: baseline;
      gap: 4px;
    }

    .price-value {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--primary);
    }

    .price-note {
      font-size: 0.9rem;
      color: var(--muted);
    }

    .price-unit {
      font-size: 0.8rem;
      color: var(--muted);
    }

    .product-actions {
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .product-detail-link {
      padding: 8px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--muted);
      font-size: 0.82rem;
      transition: all 0.2s ease;
    }

    .product-detail-link:hover {
      border-color: rgba(15, 118, 110, 0.32);
      color: var(--primary);
    }

    .add-to-cart-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 14px;
      border: none;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
      color: #fff;
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .add-to-cart-btn:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(15, 118, 110, 0.3);
    }

    .add-to-cart-btn:disabled {
      background: var(--muted);
      cursor: not-allowed;
    }

    .add-to-cart-btn.is-added {
      background: #059669;
    }

    .product-image {
      width: 100%;
      height: 200px;
      object-fit: cover;
      border-radius: 8px;
    }

    @media (max-width: 768px) {
      .product-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>