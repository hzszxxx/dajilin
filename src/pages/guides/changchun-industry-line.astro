---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import DetailPage from '@/components/astro/DetailPage.astro';
import { buildCollectionPageSchema, buildArticleSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';
import type { DetailPage as DetailPageType } from '@/lib/content-pages';

const locale = getLocaleFromPathname(Astro.url.pathname);

const page: DetailPageType = {
  section: 'study-tours',
  slug: 'changchun-industry-line',
  pathname: '/guides/changchun-industry-line',
  title: '长春工业文明线路说明页',
  shortTitle: '工业文明线路',
  description: '把长春工业研学和城市体验之间搭桥，形成可阅读、可理解、可咨询的线路型内容页。',
  eyebrow: 'Changchun Industrial Route',
  intro: '这条页面不是卖路线，而是帮助用户理解长春工业文明线路可以如何组织、适合什么对象、可结合哪些资源。线路核心是将一汽红旗、中车长客等工业研学资源与长春城市体验相结合，形成有深度的文旅组合。',
  audience: [
    '学校与机构路线组织者',
    '企业与政企考察用户',
    '想理解长春工业文明体验的内容型用户',
    '亲子与家庭研学团体组织者',
  ],
  highlights: [
    '给工业研学和城市体验搭桥',
    '适合做半日与一日结构说明',
    '可与一汽、红旗、中车长客和城市玩法联动',
    '形成长春工业文明整体认知框架',
  ],
  sections: [
    {
      title: '线路适合什么用户',
      body: '适合对工业文明有兴趣、需要团体组织或希望把城市体验与研学结合起来的用户。长春工业文明线路不是单一企业参访，而是将多个工业资源点串联成线的深度体验。',
      bullets: [
        '研学机构：需要完整的线路方案与资源组合',
        '学校教师：寻找适合学生的工业科普线路',
        '企业HR与行政部门：组织员工团建与学习活动',
        '自由行用户：希望深入了解长春工业文化',
      ],
    },
    {
      title: '线路说明',
      body: '长春工业文明线路以一汽红旗、中车长客为核心节点，结合长春城市工业历史遗迹与现代产业景观，形成半日、一日或多日组合。',
      bullets: [
        '半日精华线路：红旗文化展+城市工业景观',
        '一日深度线路：增加中车长客企业参访+生产车间',
        '多日研学线路：工业主题+城市文旅+互动体验',
      ],
    },
    {
      title: '参访类型',
      body: '根据参访目的和对象，线路可分为科普教育型、商务交流型、文化体验型和综合研学型四种。',
      bullets: [
        '科普教育型：偏重知识传授与互动体验',
        '商务交流型：偏重行业对标与深度座谈',
        '文化体验型：偏重品牌故事与工业美学',
        '综合研学型：内容+互动+座谈的组合安排',
      ],
    },
    {
      title: '可结合哪些资源',
      body: '长春工业文明线路可以结合多类资源，形成丰富的体验内容。',
      bullets: [
        '一汽红旗：汽车工业文化与品牌发展',
        '中车长客：轨道交通装备与先进制造',
        '伪满时期工业遗迹：历史与工业遗产',
        '长春城市其他景点：文化、美食与生活体验',
      ],
    },
    {
      title: '注意事项',
      body: '线路型参访涉及多个资源点，需要提前做好协调与安排。',
      bullets: [
        '多个企业参访需分别预约确认',
        '线路节奏需考虑交通时间与休息安排',
        '研学团体需配备足够的带队人员',
        '部分资源点可能有季节性或临时性调整',
        '平台前期以线路说明与咨询引导为主',
      ],
    },
  ],
  notes: [
    '不直接承诺固定产品线路',
    '更适合做线路说明和咨询入口',
    '适合作为专题联动页',
    '可与一汽红旗、中车长客页面互相导流',
  ],
  faqs: [
    {
      question: '这条线路是标准产品吗？',
      answer: '当前更适合作为线路说明页，用于帮助用户理解资源组合和咨询方向，而非标准化售卖的旅游产品。',
    },
    {
      question: '能和城市观光一起安排吗？',
      answer: '可以，长春工业文明线路本身就适合与城市体验结合理解，平台上已有长春目的地页面可供参考。',
    },
    {
      question: '线路时长如何选择？',
      answer: '半日线路适合时间紧凑的参访；一日线路可以更深度地体验多个资源点；多日线路适合研学与系统性学习。',
    },
    {
      question: '可以只选择其中一个企业参访吗？',
      answer: '可以，单一企业参访也是常见的安排方式，平台各企业参访页面均有单独说明。',
    },
  ],
  ctas: [
    { label: '查看一汽红旗研学', href: '/guides/hongqi' },
    { label: '查看中车长客参访', href: '/guides/crrc' },
    { label: '查看长春城市玩法', href: '/destinations/changchun' },
    { label: '咨询线路定制', href: '/cooperation' },
  ],
};

const localizedPath = localizePath(page.pathname, locale);
const localizedTitle = locale === 'zh' ? page.title : page.eyebrow;
const localizedDescription = locale === 'zh' ? page.description : `Changchun industrial civilization route overview connecting FAW Hongqi, CRRC, and city experiences.`;

const schemas = [
  buildCollectionPageSchema(localizedPath, localizedTitle, localizedDescription, locale),
  buildArticleSchema(localizedPath, localizedTitle, localizedDescription, 'dajilin.net', '2026-01-01', locale),
];
---

<BaseLayout
  title={`${localizedTitle} | dajilin.net`}
  description={localizedDescription}
  schemas={schemas}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <DetailPage page={page} />
  </main>
  <Footer />
</BaseLayout>
