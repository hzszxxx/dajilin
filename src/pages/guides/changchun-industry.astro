---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import DetailPage from '@/components/astro/DetailPage.astro';
import { buildCollectionPageSchema } from '@/lib/schema';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';
import type { DetailPage as DetailPageType } from '@/lib/content-pages';

const locale = getLocaleFromPathname(Astro.url.pathname);

const page: DetailPageType = {
  section: 'study-tours',
  slug: 'changchun-industry',
  pathname: '/guides/changchun-industry',
  title: '长春工业研学介绍页',
  shortTitle: '长春工业研学',
  description: '把长春工业文明、一汽红旗、中车长客和企业参访资源整理成一个工业研学总入口。',
  eyebrow: 'Changchun Industrial Study',
  intro: '这不是单一产品页，而是工业研学总入口，帮助学校、机构和团队先理解长春为什么适合做工业研学。长春具备工业文明、品牌文化和高辨识度资源，适合做说明型、路线型和定制型内容。',
  audience: [
    '学校和研学机构',
    '企业与商协会参访',
    '政企考察与城市工业体验用户',
    '对工业文明有兴趣的亲子与个人用户',
  ],
  highlights: [
    '工业文明与品牌资源集中',
    '适合学生、企业和政企多种对象',
    '可拆成公开说明页与定制咨询页',
    '一汽、红旗、中车长客等知名企业资源覆盖',
  ],
  sections: [
    {
      title: '为什么长春适合工业研学',
      body: '长春是吉林省会，也是中国重要的工业城市之一。这里拥有完整的汽车工业链、先进的轨道交通制造基地，以及深厚的品牌文化积淀。',
      bullets: [
        '一汽集团总部所在地，红旗品牌诞生地',
        '中车长客是中国轨道交通装备制造龙头',
        '工业历史悠久，可追溯至伪满时期',
        '城市配套完善，适合多日研学安排',
      ],
    },
    {
      title: '线路说明',
      body: '长春工业研学线路通常以一汽红旗、中车长客为核心资源点，结合城市工业历史遗迹和现代化生产车间参观，形成半日、一日或多日组合。',
      bullets: [
        '半日线路：红旗文化展+现代化车间参观',
        '一日线路：增加中车长客企业展厅+互动体验',
        '多日线路：可结合长春城市其他景点与工业主题串联',
      ],
    },
    {
      title: '参访类型',
      body: '根据对象不同，工业研学可分为学生研学、企业参访、政企考察和公众开放日等不同类型。',
      bullets: [
        '学生研学：偏教育性与互动体验',
        '企业参访：偏行业交流与商务对接',
        '政企考察：偏政策了解与产业调研',
        '公众开放日：偏品牌展示与公众参与',
      ],
    },
    {
      title: '适合人群分析',
      body: '不同人群对工业研学的需求差异明显，平台前期重点帮助用户判断自身适合哪种参访类型。',
      bullets: [
        'K12学生：适合偏科普与互动的一汽红旗线路',
        '大学生与职业院校：适合产业调研与职业认知类参访',
        '企业与商会：适合商务交流与行业对标类参访',
        '政府与机构：适合产业政策与区域发展类考察',
      ],
    },
    {
      title: '注意事项',
      body: '工业研学涉及企业内部参观，需提前确认接待安排与安全规定。',
      bullets: [
        '企业参访需提前预约，具体以官方安排为准',
        '部分生产线区域可能不对外开放',
        '研学团体需配备带队老师或负责人',
        '注意保护企业商业机密与生产隐私',
        '平台前期以说明与咨询引导为主',
      ],
    },
  ],
  notes: [
    '以介绍说明与咨询引导为主',
    '资源开放方式以合作安排为准',
    '适合作为一汽与中车等页面的上位入口',
    '不默认写立即预订',
  ],
  faqs: [
    {
      question: '长春工业研学适合多大的学生？',
      answer: '根据线路不同，小学高年级以上学生均可参加。具体需结合线路内容与互动环节来判断。',
    },
    {
      question: '需要提前多久预约？',
      answer: '通常建议提前1-2周预约，企业参访涉及内部流程，具体以合作方回复为准。',
    },
    {
      question: '平台当前能提供什么帮助？',
      answer: '前期重点提供资源说明、线路理解和咨询承接，不直接承诺统一售卖。',
    },
    {
      question: '可以只参访一个企业还是需要多个组合？',
      answer: '可以根据需求选择单一企业参访或多个企业组合线路，半日可单选，一日及以上建议组合。',
    },
  ],
  ctas: [
    { label: '查看一汽红旗研学', href: '/study-tours/faw-hongqi' },
    { label: '查看中车长客参访', href: '/study-tours/crrc-changchun' },
    { label: '查看工业文明线路', href: '/study-tours/changchun-industrial-route' },
    { label: '咨询定制线路', href: '/cooperation' },
  ],
};

const localizedPath = localizePath(page.pathname, locale);
const localizedTitle = locale === 'zh' ? page.title : page.eyebrow;
const localizedDescription = locale === 'zh' ? page.description : `Industrial study tour overview for ${page.eyebrow}.`;
---

<BaseLayout
  title={`${localizedTitle} | dajilin.net`}
  description={localizedDescription}
  schemas={[buildCollectionPageSchema(localizedPath, localizedTitle, localizedDescription, locale)]}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <DetailPage page={page} />
  </main>
  <Footer />
</BaseLayout>
