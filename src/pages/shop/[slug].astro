---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildCollectionPageSchema } from '@/lib/schema';
import { findDetailPage, shopPages } from '@/lib/content-pages';
import { getLocaleFromPathname, localizePath, type Locale } from '@/lib/i18n';
import {
  products,
  getCategoryLabel,
  type Product,
  type ConversionType,
} from '@/lib/products';

export function getStaticPaths() {
  const contentPaths = shopPages.map((page) => ({
    params: { slug: page.slug },
    props: { contentPage: page },
  }));

  const productPaths = products.map((p) => ({
    params: { slug: p.slug },
    props: { contentPage: null },
  }));

  return [...contentPaths, ...productPaths];
}

const slug = Astro.params.slug ?? '';
const locale = getLocaleFromPathname(Astro.url.pathname);

// Product is always the primary route
const product = products.find((p) => p.slug === slug);

// Content-page fallback (说明页)
const contentPage = !product ? findDetailPage('shop', slug) : null;

// No match → redirect
if (!product && !contentPage) {
  return Astro.redirect(localizePath('/shop', locale));
}

const isProduct = !!product;

// ── Copy ────────────────────────────────────────────────────────────────────
const copy: Record<
  Locale,
  {
    consultCta: string;
    formCta: string;
    externalCta: string;
    inStock: string;
    outOfStock: string;
    priceTbd: string;
    suitableFor: string;
    features: string;
    bookingNotes: string;
    backToShop: string;
    productDetail: string;
    conversionTitle: string;
    conversionDesc: string;
    depositTitle: string;
    depositDesc: string;
    depositBtn: string;
    wechatPay: string;
    alipay: string;
    transferNote: string;
  }
> = {
  zh: {
    consultCta: '咨询详情',
    formCta: '填写需求',
    externalCta: '立即预订',
    inStock: '可预约',
    outOfStock: '暂不可预约',
    priceTbd: '价格待定',
    suitableFor: '适合人群',
    features: '产品亮点',
    bookingNotes: '预约说明',
    backToShop: '返回产品馆',
    productDetail: '产品详情',
    conversionTitle: '如何获取这个产品',
    conversionDesc: '点击下方按钮，填写您的需求，专业顾问将在24小时内联系您。',
    depositTitle: '预付定金锁定名额',
    depositDesc: '支付定金后，顾问将在2小时内与您确认档期。定金可抵扣尾款，如临时取消提前5天告知可全额退还。',
    depositBtn: '微信/支付宝转账定金',
    wechatPay: '微信支付',
    alipay: '支付宝',
    transferNote: '转账时请备注「研学+日期+人数」，顾问核实后与您联系',
  },
  en: {
    consultCta: 'Inquire Now',
    formCta: 'Fill Form',
    externalCta: 'Book Now',
    inStock: 'Available',
    outOfStock: 'Unavailable',
    priceTbd: 'Price TBD',
    suitableFor: 'Suitable For',
    features: 'Highlights',
    bookingNotes: 'Booking Notes',
    backToShop: 'Back to Shop',
    productDetail: 'Product Details',
    conversionTitle: 'How to Get This Product',
    conversionDesc: 'Click below to submit your needs. A consultant will contact you within 24 hours.',
    depositTitle: 'Pay Deposit to Secure Your Spot',
    depositDesc: 'After payment, our consultant will confirm availability within 2 hours. Deposit applies to final payment. Full refund if cancelled 5+ days in advance.',
    depositBtn: 'WeChat / Alipay Transfer',
    wechatPay: 'WeChat Pay',
    alipay: 'Alipay',
    transferNote: 'Include "Study Tour + Date + Group Size" in payment note',
  },
  ja: {
    consultCta: '詳細を相談',
    formCta: '必要情報を記入',
    externalCta: '今すぐ予約',
    inStock: '予約可',
    outOfStock: '予約不可',
    priceTbd: '価格待定',
    suitableFor: 'こんな方におすすめ',
    features: '製品のハイライト',
    bookingNotes: '予約の説明',
    backToShop: '商品館に戻る',
    productDetail: '製品の詳細',
    conversionTitle: 'この製品の申し込み方法',
    conversionDesc: '下のボタンをクリックして必要情報を記入してください。專業カウンセラが24時間以内にご連絡します。',
    depositTitle: '予約金をお支払いして場所を確保',
    depositDesc: 'お支払い後、カウンセラーが2時間以内にご連絡します。予約金は残額に充てられます。5日前までにキャンセルされた場合、全額返金可能です。',
    depositBtn: 'WeChat / Alipay 予約金位移',
    wechatPay: 'WeChat Pay',
    alipay: 'Alipay',
    transferNote: 'お振込み時に「研学+日程+人数」をご記入ください',
  },
  ko: {
    consultCta: '상담하기',
    formCta: '요구사항 기입',
    externalCta: '즉시 예약',
    inStock: '예약 가능',
    outOfStock: '예약 불가',
    priceTbd: '가격 미정',
    suitableFor: '이런 분들에게 적합',
    features: '제품 하이라이트',
    bookingNotes: '예약 안내',
    backToShop: '상품관으로 돌아가기',
    productDetail: '제품 상세',
    conversionTitle: '이 제품을 신청하는 방법',
    conversionDesc: '아래 버튼을 클릭하여 필요 정보를 입력하세요. 전문 카운슬러가 24시간 내에 연락드립니다.',
    depositTitle: '예약을 확정하려면 보증금을 지불하세요',
    depositDesc: '결제 후 상담사가 2시간 이내에 연락드립니다. 보증금은 최종 결제에 적용되며, 5일 이전 취소 시 전액 환불 가능합니다.',
    depositBtn: 'WeChat / Alipay 보증금 이체',
    wechatPay: 'WeChat Pay',
    alipay: 'Alipay',
    transferNote: '이체 시「연수+날짜+인원」を 메모에 기입해 주세요',
  },
};

const t = copy[locale];
const p = product as Product;
const categoryLabel = p ? getCategoryLabel(p.category, locale) : '';

function getCtaLabel(type: ConversionType): string {
  if (type === 'consult') return t.consultCta;
  if (type === 'form') return t.formCta;
  return t.externalCta;
}

function getCtaHref(product: Product): string {
  if (product.conversionType === 'external' && product.externalUrl) {
    return product.externalUrl;
  }
  return localizePath('/cooperation', locale);
}
---

{isProduct ? (
  <BaseLayout
    title={`${p.name} | 大吉林`}
    description={p.description}
    locale={locale}
    schemas={[buildCollectionPageSchema(
      localizePath(`/shop/${p.slug}`, locale),
      p.name,
      p.description,
      locale
    )]}
  >
    <Header />
    <main class="page-shell product-detail-shell">
      <div class="container">

        <!-- Breadcrumb -->
        <div class="breadcrumb">
          <a href={localizePath('/shop', locale)}>{t.backToShop}</a>
          <span>/</span>
          <span>{categoryLabel}</span>
          <span>/</span>
          <span>{p.name}</span>
        </div>

        <!-- Main Grid -->
        <div class="product-detail-grid">
          <!-- Left: Image -->
          <div class="product-image-panel">
            <img src={p.imageUrl} alt={p.name} class="product-detail-image" />
            {p.badge && (
              <span class={`product-badge ${p.badge.toLowerCase()}`}>{p.badge}</span>
            )}
            {!p.inStock && (
              <span class="product-out-badge">{t.outOfStock}</span>
            )}
          </div>

          <!-- Right: Info -->
          <div class="product-info-panel">
            <div class="product-eyebrow">
              <span class="category-tag">{categoryLabel}</span>
              <span class="product-tag-text">{p.tag}</span>
            </div>
            <h1 class="product-title">{p.name}</h1>
            <p class="product-desc-full">{p.description}</p>

            <!-- Features -->
            {p.features && p.features.length > 0 && (
              <div class="product-section">
                <h2>{t.features}</h2>
                <ul class="feature-list">
                  {p.features.map((f) => (
                    <li>
                      <span class="feature-check">✓</span>
                      {f}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Suitable For -->
            {p.suitableFor && p.suitableFor.length > 0 && (
              <div class="product-section">
                <h2>{t.suitableFor}</h2>
                <div class="tag-list">
                  {p.suitableFor.map((s) => (
                    <span class="tag-chip">{s}</span>
                  ))}
                </div>
              </div>
            )}

            <!-- Booking Notes -->
            {p.bookingNotes && (
              <div class="product-section booking-notes">
                <h2>{t.bookingNotes}</h2>
                <p>{p.bookingNotes}</p>
              </div>
            )}

            <!-- OTA 直达购买区（仅 external 产品） -->
            {p.conversionType === 'external' ? (
              <div class="ota-purchase-panel">
                <div class="ota-header">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <span>通过合作平台直达购买</span>
                </div>
                <p class="ota-desc">
                  {locale === 'zh'
                    ? '长白山景区门票通过携程/去哪网官方合作渠道发售，官方实名预约，确保入园名额。价格以平台实际为准。'
                    : 'Tickets available via Ctrip/Ly.com official channels. Real-name booking required. Prices on platform.'}
                </p>
                <a
                  href={p.externalUrl}
                  class="purchase-cta external"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {t.externalCta}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                    <polyline points="15 3 21 3 21 9"/>
                    <line x1="10" y1="14" x2="21" y2="3"/>
                  </svg>
                </a>
                <p class="ota-note">
                  {locale === 'zh' ? '点击后跳转到携程/去哪网完成购买，票务问题由平台客服处理' : 'Redirects to Ctrip/Ly.com. Support handled by platform.'}
                </p>
              </div>
            ) : (
              <div class="product-purchase-panel">
                <div class="price-row">
                  {p.inStock ? (
                    <span class="stock-badge in">{t.inStock}</span>
                  ) : (
                    <span class="stock-badge out">{t.outOfStock}</span>
                  )}
                  <div class="price-display">
                    <span class="price-value">
                      {p.priceType === 'consultation'
                        ? '¥199'
                        : p.price === 0
                          ? (locale === 'zh' ? '咨询获取' : 'Ask')
                          : `¥${product.price.toFixed(0)}`}
                    </span>
                    <span class="price-unit">/{p.priceUnit}</span>
                  </div>
                </div>

                <div class="purchase-actions">
                  <a
                    href={getCtaHref(p)}
                    class={`purchase-cta ${p.conversionType}`}
                    target="_self"
                    rel={undefined}
                  >
                    {getCtaLabel(p.conversionType)}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                  <a href={localizePath('/cooperation', locale)} class="secondary-btn">
                    {locale === 'zh' ? '联系顾问' : 'Contact Us'}
                  </a>
                </div>

                <p class="conversion-note">{t.conversionDesc}</p>
              </div>
            )}
            <!-- 定金预付区（有 paymentInfo 时显示） -->
            {p.paymentInfo ? (
              <div class="deposit-panel">
                <div class="deposit-header">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  {t.depositTitle}
                </div>
                {p.depositAmount ? (
                  <div class="deposit-amount">
                    ¥{p.depositAmount}<span>/人</span>
                  </div>
                ) : null}
                <p class="deposit-desc">{t.depositDesc}</p>
                {p.paymentInfo.method === 'both' || p.paymentInfo.method === 'wechat' ? (
                  <div class="payment-methods">
                    <button class="payment-btn wechat" disabled>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8.5 11.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/><path d="M15.5 11.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/><path d="M12 2C6.48 2 2 6.48 2 12c0 2.17.7 4.18 1.88 5.82L2 22l4.18-1.88C7.82 21.3 9.83 22 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
                      {t.wechatPay}
                      <span class="coming-soon">待开通</span>
                    </button>
                    <button class="payment-btn alipay" disabled>
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15H9v-2h2v2zm0-4H9V7h2v6zm4 4h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
                      {t.alipay}
                      <span class="coming-soon">待开通</span>
                    </button>
                  </div>
                ) : null}
                <p class="transfer-note">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  {t.transferNote}
                </p>
              </div>
            ) : null}
          </div>
        </div>

      </div>
    </main>
    <Footer />

    <style>
      .product-detail-shell { padding: 40px 0 80px; }

      .breadcrumb {
        display: flex; align-items: center; gap: 8px;
        margin-bottom: 32px; font-size: 0.875rem; color: var(--muted);
      }
      .breadcrumb a { color: var(--primary); text-decoration: none; }
      .breadcrumb a:hover { text-decoration: underline; }

      .product-detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 56px;
        align-items: start;
      }

      @media (max-width: 768px) {
        .product-detail-grid { grid-template-columns: 1fr; gap: 28px; }
      }

      /* Image Panel */
      .product-image-panel {
        position: relative;
        border-radius: 20px;
        overflow: hidden;
        background: linear-gradient(145deg, #e8f5f3 0%, #e0f2fe 56%, #f0fdf4 100%);
      }
      .product-detail-image {
        width: 100%; height: 400px; object-fit: cover; display: block;
      }
      .product-badge {
        position: absolute; top: 16px; left: 16px;
        padding: 5px 12px; border-radius: 999px;
        font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em;
      }
      .product-badge.hot { background: #ef4444; color: #fff; }
      .product-badge.new { background: #3b82f6; color: #fff; }
      .product-out-badge {
        position: absolute; top: 16px; right: 16px;
        padding: 6px 14px; border-radius: 999px;
        background: rgba(239, 68, 68, 0.9); color: #fff;
        font-size: 0.85rem; font-weight: 600;
      }

      /* Info Panel */
      .product-info-panel { display: flex; flex-direction: column; gap: 20px; }

      .product-eyebrow {
        display: flex; align-items: center; gap: 10px;
      }
      .category-tag {
        font-size: 0.72rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: 0.06em; color: var(--primary);
        background: var(--primary-bg); padding: 4px 10px; border-radius: 6px;
      }
      .product-tag-text { font-size: 0.85rem; color: var(--muted); }

      .product-title {
        font-size: 1.9rem; font-weight: 800;
        color: var(--text-strong); margin: 0; line-height: 1.3;
      }

      .product-desc-full {
        font-size: 0.95rem; color: var(--muted);
        line-height: 1.75; margin: 0;
      }

      /* Sections */
      .product-section h2 {
        font-size: 0.9rem; font-weight: 700;
        color: var(--text-strong); margin: 0 0 10px;
        text-transform: uppercase; letter-spacing: 0.05em;
      }

      .feature-list {
        list-style: none; padding: 0; margin: 0;
        display: flex; flex-direction: column; gap: 8px;
      }
      .feature-list li {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.9rem; color: var(--text-strong);
      }
      .feature-check { color: var(--primary); font-weight: 700; }

      .tag-list { display: flex; flex-wrap: wrap; gap: 8px; }
      .tag-chip {
        padding: 5px 12px; border-radius: 999px;
        background: var(--primary-bg); color: var(--primary);
        font-size: 0.82rem; font-weight: 500;
      }

      .booking-notes p {
        font-size: 0.88rem; color: var(--muted);
        line-height: 1.65; margin: 0;
        padding: 12px 16px;
        background: #fffbeb; border-left: 3px solid #f59e0b;
        border-radius: 0 8px 8px 0;
      }

      /* Purchase Panel */
      .product-purchase-panel {
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 24px;
        background: #fafafa;
        display: flex; flex-direction: column; gap: 16px;
      }

      .price-row {
        display: flex; align-items: center; justify-content: space-between;
      }

      .stock-badge {
        padding: 4px 12px; border-radius: 999px;
        font-size: 0.82rem; font-weight: 600;
      }
      .stock-badge.in { background: #d1fae5; color: #065f46; }
      .stock-badge.out { background: #fee2e2; color: #991b1b; }

      .price-display { display: flex; align-items: baseline; gap: 4px; }
      .price-value { font-size: 1.8rem; font-weight: 800; color: var(--primary); }
      .price-unit { font-size: 0.85rem; color: var(--muted); }

      .purchase-actions { display: flex; gap: 12px; flex-wrap: wrap; }

      .purchase-cta {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 14px 28px; border-radius: 999px;
        font-size: 0.95rem; font-weight: 700;
        text-decoration: none; transition: all 0.2s ease;
        color: #fff;
      }
      .purchase-cta.consult,
      .purchase-cta.consultation {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
      }
      .purchase-cta.consult:hover,
      .purchase-cta.consultation:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(15, 118, 110, 0.35);
      }
      .purchase-cta.form {
        background: #3b82f6;
      }
      .purchase-cta.form:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(59, 130, 246, 0.35);
      }
      .purchase-cta.external {
        background: #7c3aed;
      }
      .purchase-cta.external:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(124, 58, 237, 0.35);
      }

      .ota-purchase-panel {
        border: 2px solid #7c3aed;
        border-radius: 20px;
        padding: 24px;
        background: #faf5ff;
        display: flex; flex-direction: column; gap: 14px;
      }

      .ota-header {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.9rem; font-weight: 700;
        color: #7c3aed;
        text-transform: uppercase; letter-spacing: 0.04em;
      }

      .ota-desc {
        font-size: 0.88rem; color: #4b5563;
        line-height: 1.7; margin: 0;
        background: #fff;
        padding: 12px 16px;
        border-radius: 10px;
        border: 1px solid #ede9fe;
      }

      .ota-note {
        font-size: 0.78rem; color: #9ca3af;
        text-align: center; margin: 0;
      }

      .deposit-panel {
        border: 2px solid #10b981;
        border-radius: 20px;
        padding: 24px;
        background: #f0fdf4;
        display: flex; flex-direction: column; gap: 12px;
      }

      .deposit-header {
        display: flex; align-items: center; gap: 8px;
        font-size: 0.95rem; font-weight: 700;
        color: #10b981;
      }

      .deposit-amount {
        font-size: 1.8rem; font-weight: 800; color: #10b981;
        font-family: 'Tencent', 'PingFang SC', sans-serif;
      }
      .deposit-amount span { font-size: 0.9rem; font-weight: 400; color: #6b7280; margin-left: 2px; }

      .deposit-desc {
        font-size: 0.87rem; color: #374151; line-height: 1.7; margin: 0;
        background: #fff; padding: 10px 14px;
        border-radius: 10px; border: 1px solid #d1fae5;
      }

      .payment-methods {
        display: flex; gap: 12px; flex-wrap: wrap;
      }

      .payment-btn {
        flex: 1; min-width: 130px;
        display: flex; align-items: center; justify-content: center; gap: 8px;
        padding: 12px 16px; border-radius: 12px;
        font-size: 0.9rem; font-weight: 600;
        cursor: not-allowed; opacity: 0.55;
        border: 2px solid transparent;
      }

      .payment-btn.wechat {
        background: #f0f9f0; color: #06c149;
        border-color: #06c149;
      }

      .payment-btn.alipay {
        background: #f0f5ff; color: #1677ff;
        border-color: #1677ff;
      }

      .payment-btn .coming-soon {
        font-size: 0.72rem;
        background: #d1d5db; color: #fff;
        padding: 2px 6px; border-radius: 6px;
        margin-left: 4px;
      }

      .transfer-note {
        display: flex; align-items: center; gap: 5px;
        font-size: 0.78rem; color: #9ca3af; margin: 0;
      }

      .product-purchase-panel {
        display: inline-flex; align-items: center;
        padding: 14px 24px; border-radius: 999px;
        border: 1px solid var(--line);
        color: var(--text-strong); font-size: 0.95rem; font-weight: 600;
        text-decoration: none; transition: all 0.2s ease;
      }
      .secondary-btn:hover {
        border-color: var(--primary); color: var(--primary);
      }

      .conversion-note {
        font-size: 0.8rem; color: var(--muted);
        line-height: 1.6; margin: 0;
        text-align: center;
      }
    </style>
  </BaseLayout>
) : (
  // Content-page fallback
  contentPage ? (
    <BaseLayout
      title={`${locale === 'zh' ? contentPage.title : contentPage.eyebrow} | 大吉林`}
      description={locale === 'zh' ? contentPage.description : `Details for ${contentPage.eyebrow}.`}
      schemas={[buildCollectionPageSchema(
        localizePath(contentPage.pathname, locale),
        locale === 'zh' ? contentPage.title : contentPage.eyebrow,
        locale === 'zh' ? contentPage.description : `Details for ${contentPage.eyebrow}.`,
        locale
      )]}
      locale={locale}
    >
      <Header />
      <main class="page-shell">
        {/* DetailPage component would be imported if needed */}
        <div class="container" style="padding: 80px 0; text-align: center;">
          <h1>{contentPage.title}</h1>
          <p>{contentPage.description}</p>
          <a href={localizePath('/shop', locale)}>{locale === 'zh' ? '返回产品馆' : 'Back to Shop'}</a>
        </div>
      </main>
      <Footer />
    </BaseLayout>
  ) : null
)}
