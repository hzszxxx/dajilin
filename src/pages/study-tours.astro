<style>
.study-tour-cta-section {
  margin-top: 48px;
  padding: 40px;
  background: linear-gradient(135deg, #f8fafc 0%, #eff6ff 100%);
  border: 1px solid rgba(15, 118, 110, 0.12);
  border-radius: 24px;
}

.cta-container {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  flex-wrap: wrap;
}

.cta-text h3 {
  font-size: 1.4rem;
  color: var(--text-strong, #1e293b);
  margin: 0 0 8px;
}

.cta-text p {
  color: var(--muted, #64748b);
  margin: 0;
  font-size: 0.95rem;
}

.cta-actions {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
}

.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border-radius: 999px;
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.2s ease;
  border: none;
}

.cta-btn-primary {
  background: linear-gradient(135deg, #c47d1a 0%, #b45309 100%);
  color: #fff;
}

.cta-btn-primary:hover {
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(196, 125, 26, 0.3);
}

.cta-btn-secondary {
  background: transparent;
  color: var(--primary, #0f766e);
  border: 1.5px solid var(--primary, #0f766e);
}

.cta-btn-secondary:hover {
  background: rgba(15, 118, 110, 0.06);
}

/* ── Service Cards ──────────────────────────── */
.study-service-cards {
  margin: 36px 0;
}

.service-cards-header {
  margin-bottom: 24px;
}

.service-cards-header h2 {
  font-size: 1.3rem;
  font-weight: 800;
  color: var(--text-strong, #1e293b);
  margin: 0 0 6px;
}

.service-cards-header p {
  font-size: .88rem;
  color: var(--muted, #64748b);
  margin: 0;
}

.service-cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.service-card {
  border-radius: 20px;
  border: 1.5px solid var(--line, #e2e8f0);
  background: var(--surface, #fff);
  box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.04);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform .22s ease, box-shadow .22s ease;
}

.service-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 28px rgba(0,0,0,.1);
}

.service-card[data-color="lake-blue"]  { border-top: 4px solid var(--lake-blue, #1e5f8a); }
.service-card[data-color="maple-red"]   { border-top: 4px solid var(--maple-red, #b5451b); }
.service-card[data-color="golden"]      { border-top: 4px solid var(--golden, #c47d1a); }

.service-card-header {
  padding: 18px 20px 12px;
}

.service-card-header h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-strong, #1e293b);
  margin: 0;
  line-height: 1.4;
}

.service-card-body {
  padding: 0 20px 14px;
  font-size: .83rem;
  color: var(--muted, #64748b);
  margin: 0;
  line-height: 1.65;
  flex: 1;
}

.service-card-details {
  padding: 14px 20px;
  background: var(--paper, #fafaf8);
  border-top: 1px solid var(--line-light, #f1f5f9);
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin: 0;
}

.service-card-details > div {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: 8px;
}

.service-card-details dt {
  font-size: .72rem;
  font-weight: 600;
  color: var(--muted, #64748b);
  text-transform: uppercase;
  letter-spacing: .04em;
}

.service-card-details dd {
  font-size: .8rem;
  color: var(--text, #334155);
  margin: 0;
}

.service-card-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 12px 20px;
  font-size: .85rem;
  font-weight: 700;
  text-decoration: none;
  border-top: 1px solid var(--line, #e2e8f0);
  transition: background .2s, color .2s;
}

.service-card[data-color="lake-blue"] .service-card-cta  { color: var(--lake-blue, #1e5f8a); }
.service-card[data-color="maple-red"] .service-card-cta   { color: var(--maple-red, #b5451b); }
.service-card[data-color="golden"] .service-card-cta      { color: var(--golden, #c47d1a); }

.service-card-cta:hover {
  background: var(--paper, #fafaf8);
}

.service-note {
  margin-top: 14px;
  font-size: .75rem;
  color: var(--muted, #64748b);
  font-style: italic;
  padding: 10px 14px;
  background: var(--paper, #fafaf8);
  border-radius: 10px;
  border: 1px dashed var(--line, #e2e8f0);
}
</style>

<BaseLayout
  title={t.title}
  description={t.description}
  schemas={[
    buildCollectionPageSchema('/study-tours', t.schemaName, t.description, locale),
    buildTouristTripSchema('/study-tours', t.schemaName, t.description, locale),
  ]}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-copy">
          <div class="eyebrow">{t.eyebrow}</div>
          <h1>{t.heading}</h1>
          <p>{t.description}</p>
        </div>

        <!-- Service Cards -->
        <section class="study-service-cards">
          <div class="service-cards-header">
            <h2>{t.serviceCardsHeading}</h2>
            <p>{t.serviceCardsDesc}</p>
          </div>
          <div class="service-cards-grid">
            {studyServiceCards[locale].map((card, idx) => (
              <article class="service-card" data-color={['lake-blue', 'maple-red', 'golden'][idx]}>
                <div class="service-card-header">
                  <h3>{card.title}</h3>
                </div>
                <p class="service-card-body">{card.body}</p>
                <dl class="service-card-details">
                  <div>
                    <dt>{t.suitableFor}</dt>
                    <dd>{card.suitableFor}</dd>
                  </div>
                  <div>
                    <dt>{t.suggestedSize}</dt>
                    <dd>{card.suggestedSize}</dd>
                  </div>
                  <div>
                    <dt>{t.suggestedDuration}</dt>
                    <dd>{card.suggestedDuration}</dd>
                  </div>
                  <div>
                    <dt>{t.optionalResources}</dt>
                    <dd>{card.optionalResources}</dd>
                  </div>
                  <div>
                    <dt>{t.deliverables}</dt>
                    <dd>{card.deliverables}</dd>
                  </div>
                </dl>
                <a href={localizePath('/cooperation', locale)} class="service-card-cta">
                  {card.cta}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </article>
            ))}
          </div>
          <p class="service-note">{t.note}</p>
        </section>

        <div class="enterprise-grid">
          {ent.map((item) => (
            <a class="enterprise-card" href={item.href} target="_blank" rel="noopener noreferrer">
              <div class="enterprise-card-inner">
                <span class="enterprise-category">{item.category}</span>
                <h3>{item.name}</h3>
                <p>{item.desc}</p>
              </div>
              <div class="enterprise-card-arrow" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>

        <section class="study-tour-cta-section">
          <div class="cta-container">
            <div class="cta-text">
              <h3>需要定制研学行程？</h3>
              <p>告诉 AI 你的团队规模和兴趣方向，30秒生成专属方案</p>
            </div>
            <div class="cta-actions">
              <button type="button" class="cta-btn cta-btn-primary" id="open-study-tour-ai">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                </svg>
                AI 帮我规划研学路线
              </button>
              <a href={localizePath('/cooperation', locale)} class="cta-btn cta-btn-secondary">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                  <circle cx="9" cy="7" r="4"/>
                  <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                  <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                </svg>
                驿站合作咨询
              </a>
            </div>
          </div>
        </section>
      </section>
      <aside class="page-card">
        <h3>{t.sideTitle}</h3>
        <ul class="page-list page-list-full">
          {ent.map((item) => (
            <li><a href={item.href} target="_blank" rel="noopener noreferrer">{item.name}</a></li>
          ))}
        </ul>
      </aside>
    </div>
  </main>
  <Footer />

  <script>
    document.getElementById('open-study-tour-ai')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('open-ai-widget', {
        detail: { context: 'study-tour', module: 'study-tours' }
      }));
    });
  </script>
</BaseLayout>
