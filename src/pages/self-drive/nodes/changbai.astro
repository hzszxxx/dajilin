    faqs: [
      { q: '장천산 천지는 어떤状況が наиболее価値のあるですか？', a: '천지는晴れた日に 가장 장관하고, 시정이 높을 때 호수 물이 짙은青색을 띱니다. 9월 중하순 방문을 권장하며, 가을빛과 천지가 어우러져 경관의层次가 가장 풍부합니다. 겨울의 눈雾凇과 눈 경관도 독특하지만, 천지는 날씨에 따라 폐쇄될 수 있습니다.' },
      { q: '장천산은 예약이 필요합니까?', a: '필요합니다. 장천산景区는 예약제를 시행하며, 성수기(7-9월)에는 반드시 공식 플랫폼에서 사전 예약이 필요합니다. 3-5일 전부터 공식 플랫폼의 티켓 정보를주시하기 바랍니다.' },
      { q: '장천산 북파와 서파는 어떻게 다릅니까?', a: '북파는 주 입구로 시설이 가장 완비되어 있고, 천지, 폭포, 흑풍구 등 핵심 관광지가 북파에 있습니다. 서파는 천지 전경을 볼 수 있어 시야가 넓지만 관광지가 상대적으로 적어, 긴 노선을기고 싶지 않은 관광객에게 적합합니다.' },
      { q: '연길에서 장천산까지 이동이 편리합니까?', a: '비교적 편리합니다. 연길에서 장천산 이도백하 진까지 약 280km, 차로 약 3.5-4시간입니다. 장거리 버스와 관광 직통 버스도 있어, 사전에的时刻표를 확인하기 바랍니다.' },
    ],
  },
};

const t = copy[locale];
const schemas = [
  buildWebPageSchema(pagePath, pageTitle, pageDescription, locale),
  buildTouristDestinationSchema(pagePath, pageTitle, pageDescription, locale),
  buildFAQPageSchema(pagePath, pageTitle, t.faqs.map((f: { q: string; a: string }) => ({ question: f.q, answer: f.a })), locale),
];
---

<BaseLayout title={`${pageTitle} | 大吉林`} description={pageDescription} schemas={schemas} locale={locale} ogImage="/images/home/changbai.jpg">
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">{t.eyebrow}</div>
            <h1>{isZh ? pageTitle : t.eyebrow}</h1>
            <p>{isZh ? pageDescription : t.intro}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.whatIsThis}</h2>
          <p>{t.whatIsThisBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.audience}</h2>
          <ul>
            {t.audienceList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlights}</h2>
          <ul>
            {t.highlightsList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.howToPlan}</h2>
          <p>{t.howToPlanBody}</p>
          <ul>
            {t.howToPlanList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.officialEntry}</h2>
          <p>{t.officialEntryBody}</p>
        </div>

        <div class="detail-block">
          <h2>{t.notes}</h2>
          <ul>
            {t.notesList.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{isZh ? '建议继续浏览' : 'Continue Reading'}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/self-drive/overview', locale)}>{isZh ? '331国道吉林段概览' : 'Route 331 Jilin Overview'}</a></li>
          <li><a href={localizePath('/self-drive/how-to-travel', locale)}>{isZh ? '自驾攻略' : 'Self-Drive Guide'}</a></li>
          <li><a href={localizePath('/destinations/changbai-mountain', locale)}>{isZh ? '长白山目的地页' : 'Changbaishan Destination'}</a></li>
          <li><a href={localizePath('/themes/ice-snow', locale)}>{isZh ? '冰雪吉林主题' : 'Ice & Snow Jilin Theme'}</a></li>
        </ul>

        <div class="detail-side-card">
          <h3>{t.consultEntry}</h3>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-page-url={pagePath}>
              {isZh ? '先问 AI 助手' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {isZh ? '提交咨询' : 'Submit Consultation'}
            </a>
          </div>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
