const pageDescription = '延吉是331国道吉林段的核心节点，朝鲜族文化中心，也是延边地区最重要的旅游集散地。';
const pagePath = '/self-drive/nodes/yanji';

const copy: Record<Locale, {
  eyebrow: string;
  intro: string;
  whatIsThis: string;
