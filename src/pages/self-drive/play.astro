      '중국-북조선 국경 도로 경험과 국경 문화',
      '연변 지역 조선족 미식과的人文',
      '투먼, 훔친 등 국경 도시风貌',
      '사계절 변화하는 자연과 농촌 경관',
    ],
    routePlanning: '일정 계획 제안',
    routePlanningItems: [
      '반일 체험: 연길 주변 단거리 여행, 미식',
      '2-3일 일정: 연길+투먼+훔친 국경선 깊이 탐방',
      '4-5일 일정: G331 지린 구간 전체+장백산 연계',
    ],
    notesTitle: '주의사항',
    notesItems: [
      '국경 지역은 신분증 필수, 일부 지역은 국경 통과증 필요',
      '산간 도로 구간은 안전 운전 주의',
      '여행 성수기에는 사전 숙박 예약 필요',
      '현지 민족 풍속 습관 존중',
    ],
    faqTitle: '자주 묻는 질문',
    faqs: [
      { q: '자가운전 가이드 전체 길이는?', a: 'G331 지린 구간은 약 600km로, 연변 지역 연길에서 훔친 방천까지, 여러 현시를 지나갑니다.' },
      { q: '沿선 주유와 보급이 편리한가요?', a: '연길, 투먼, 훔친 등 주요 마을에는 주유소와 기본 보급 시설이 있으나, 일부 구간은 간격이 길어 사전 계획이 필요합니다.' },
      { q: '겨울에自驾 주의점은?', a: '겨울에는 일부 구간에 눈과 결빙이 있을 수 있어 겨울용 타이어나 사륜駆動 차량 사용, 실시간路况 확인을 권장합니다.' },
      { q: '국경 통과증이 필요한가요?', a: '훔친 방천 등 국경 민감区域 방문 시 신분증이 필요하며, 일부는 사전 통과증 신청이 필요합니다.' },
    ],
    ctaTitle: '계속 알아보기',
    ctaItems: [
      { label: '거점 서비스 보기', href: '/self-drive/stations' },
      { label: '보급·숙박 보기', href: '/self-drive/supplies' },
      { label: '노선 상담하기', href: '/cooperation' },
    ],
  },
};

const t = localized[locale];
const thisPath = '/self-drive/play';
const schemas = [
  buildWebPageSchema(thisPath, t.pageTitle, t.description, locale),
  buildCollectionPageSchema(thisPath, t.pageTitle, t.description, locale),
];
---

<BaseLayout title={t.title} description={t.description} schemas={schemas} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">Self-Drive Guide</div>
            <h1>{t.pageTitle}</h1>
            <p>{t.pageDesc}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.routeHighlights}</h2>
          <p>{t.routeContent}</p>
        </div>

        <div class="detail-block">
          <h2>{t.highlightsTitle}</h2>
          <ul>
            {t.highlightsItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.selfDriveTips}</h2>
          <ul>
            {t.selfDriveTipsItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.seasonalAdvice}</h2>
          <ul>
            {t.seasonalAdviceItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.audienceTitle}</h2>
          <ul>
            {t.audienceItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.routePlanning}</h2>
          <ul>
            {t.routePlanningItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.notesTitle}</h2>
          <ul>
            {t.notesItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{t.ctaTitle}</h3>
        <ul class="page-list">
          {t.ctaItems.map((cta) => (
            <li><a href={cta.href}>{cta.label}</a></li>
          ))}
        </ul>

        <div class="detail-side-card">
          <h3>{locale === 'zh' ? '快速咨询' : locale === 'ja' ? '快速相談' : locale === 'ko' ? '빠른 상담' : 'Quick Consultation'}</h3>
          <div class="cta-row">
            <button
              class="button"
              type="button"
              data-open-ai-widget
              data-ai-page-url={thisPath}
            >
              {locale === 'zh' ? '先问 AI 助手' : locale === 'ja' ? '先に AIアシスタントへ' : locale === 'ko' ? 'AI 도우미 먼저' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href="/cooperation">
              {locale === 'zh' ? '提交咨询' : locale === 'ja' ? '相談を送信' : locale === 'ko' ? '상담 제출' : 'Submit Consultation'}
            </a>
          </div>
        </div>

</aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
