    ],
    audienceTitle: '이런 분들께 추천',
    audienceItems: [
      '자가운전 여행 애호가와 사진 촬영 사용자',
      '국경 문화와 미식 체험형 관광객',
      '複数일 일정 계획하는 심층 여행 사용자',
