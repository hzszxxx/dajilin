const t = localized[locale];
const thisPath = '/self-drive/stations';
const schemas = [
  buildWebPageSchema(thisPath, t.pageTitle, t.description, locale),
  buildCollectionPageSchema(thisPath, t.pageTitle, t.description, locale),
];
---

<BaseLayout title={t.title} description={t.description} schemas={schemas} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">Self-Drive Guide</div>
            <h1>{t.pageTitle}</h1>
            <p>{t.pageDesc}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.serviceOverview}</h2>
          <p>{locale === 'zh' ? '驿站是自驾攻略上的重要服务节点，为自驾用户和团队提供多样化的旅途支持服务。' : locale === 'ja' ? '驛站は自驾攻略上の重要なサービス节点として、レンタカー用户と団体に多种多様な旅途支援サービスを提供します。' : locale === 'ko' ? '거점은 자가운전 가이드의 중요한 서비스 노드로, 자가운전 사용자와 단체에 다양한 여행 지원을 제공합니다.' : 'Stations are important service nodes on self-drive routes, providing diverse travel support services for self-drive users and groups.'}</p>
        </div>

        <div class="detail-block">
          <h2>{t.serviceTypes}</h2>
          <ul>
            {t.serviceItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.stopScenarios}</h2>
          <ul>
            {t.scenarioItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.cooperationInfo}</h2>
          <ul>
            {t.cooperationItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.audienceTitle}</h2>
          <ul>
            {t.audienceItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlightsTitle}</h2>
          <ul>
            {t.highlightsItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.notesTitle}</h2>
          <ul>
            {t.notesItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{t.ctaTitle}</h3>
        <ul class="page-list">
          {t.ctaItems.map((cta) => (
            <li><a href={cta.href}>{cta.label}</a></li>
          ))}
        </ul>

        <div class="detail-side-card">
          <h3>{locale === 'zh' ? '快速咨询' : locale === 'ja' ? '快速相談' : locale === 'ko' ? '빠른 상담' : 'Quick Consultation'}</h3>
          <div class="cta-row">
            <button
              class="button"
              type="button"
              data-open-ai-widget
              data-ai-page-url={thisPath}
            >
              {locale === 'zh' ? '先问 AI 助手' : locale === 'ja' ? '先に AIアシスタントへ' : locale === 'ko' ? 'AI 도우미 먼저' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href="/cooperation">
              {locale === 'zh' ? '提交咨询' : locale === 'ja' ? '相談を送信' : locale === 'ko' ? '상담 제출' : 'Submit Consultation'}
            </a>
          </div>
        </div>

<div class="detail-side-card station-cta-card">
          <h3>{t.viewStationsCta}</h3>
          <p>{t.viewStationsDesc}</p>
          <a class="button" href="/stations">
            {locale === 'zh' ? '查看合作驿站' : locale === 'ja' ? '驛站を見る' : locale === 'ko' ? '거점 보기' : 'View Stations'}
          </a>
        </div>

        <div class="detail-side-card apply-cta-card">
          <h3>{locale === 'zh' ? '成为驿站合作伙伴' : locale === 'ja' ? '驛站パートナーを目指す' : locale === 'ko' ? '거점 파트너가 되세요' : 'Become a Station Partner'}</h3>
          <p>{locale === 'zh' ? '欢迎沿线驿站、住宿、餐饮、补给和团队服务商加入我们。' : locale === 'ja' ? '沿線の驛站、宿泊、飲食、補給、団体サービス事業者の皆様のご参加をお勧めします。' : locale === 'ko' ? '연선 거점, 숙박, 식음, 보급, 단체 서비스 사업자의 여러분의 참가를 권장합니다.' : 'Welcome station operators, accommodation, dining, supply and team service providers to join us.'}</p>
          <a class="button" href="/stations/cooperation">
            {t.applyStationCta}
          </a>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
