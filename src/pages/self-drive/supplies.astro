      { q: '자가운전에 어떤 준비가 필요합니까?', a: '노선, 계절, 정차 리듬, 보급 방식, 숙박安排의 이해를 우선시할 것을 권장합니다. 출발 전 차량 검사 と 기본 물자 준비도 매우 중요합니다.' },
      { q: '단체出行과 개인 자가운전의 차이는?', a: '단체는 정차 노드, 통일 보급, 숙박 조직, 연속 서비스에 더 주의를 기울여야 합니다. 사전에 관련처와 단체受入能力를 확인할 것을 권장합니다.' },
      { q: '沿선 숙박 조건은 어떻습니까?', a: '연길의 숙박 조건이 가장 좋고, 훔친과 투먼에는 기본적인 선택이 있으며,沿선 향진에는 민박과 농가 민박이 주를 이룹니다. 노선 리듬에 따라 선택할 것을 권장합니다.' },
      { q: '주유소의沿선 분포 상황은?', a: '주요 마을에는 주유소가 있지만 일부 구간은 간격이 길다. 주유소가 있는 곳에서时就로 보충하고 연료량이 너무 낮아서까지 기다리지 말 것을 권장합니다.' },
    ],
    ctaTitle: '계속 알아보기',
    ctaItems: [
      { label: '거점 서비스 보기', href: '/self-drive/stations' },
      { label: '자가운전 가이드 여행 방법 보기', href: '/self-drive/play' },
      { label: '노선 상담 제출', href: '/cooperation' },
    ],
  },
};

const t = localized[locale];
const thisPath = '/self-drive/supplies';
const schemas = [
  buildWebPageSchema(thisPath, t.pageTitle, t.description, locale),
  buildCollectionPageSchema(thisPath, t.pageTitle, t.description, locale),
];
---

<BaseLayout title={t.title} description={t.description} schemas={schemas} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">Self-Drive Guide</div>
            <h1>{t.pageTitle}</h1>
            <p>{t.pageDesc}</p>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.preTripPrep}</h2>
          <ul>
            {t.preTripItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.alongRoute}</h2>
          <ul>
            {t.alongRouteItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.teamNotes}</h2>
          <ul>
            {t.teamItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.accommodationAdvice}</h2>
          <ul>
            {t.accommodationItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.audienceTitle}</h2>
          <ul>
            {t.audienceItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.highlightsTitle}</h2>
          <ul>
            {t.highlightsItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.notesTitle}</h2>
          <ul>
            {t.notesItems.map((item) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.faqTitle}</h2>
          <div class="faq-list">
            {t.faqs.map((faq) => (
              <article class="faq-item">
                <h3>{faq.q}</h3>
                <p>{faq.a}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{t.ctaTitle}</h3>
        <ul class="page-list">
          {t.ctaItems.map((cta) => (
            <li><a href={cta.href}>{cta.label}</a></li>
          ))}
        </ul>

        <div class="detail-side-card">
          <h3>{locale === 'zh' ? '快速咨询' : locale === 'ja' ? '快速相談' : locale === 'ko' ? '빠른 상담' : 'Quick Consultation'}</h3>
          <div class="cta-row">
            <button
              class="button"
              type="button"
              data-open-ai-widget
              data-ai-page-url={thisPath}
            >
              {locale === 'zh' ? '先问 AI 助手' : locale === 'ja' ? '先に AIアシスタントへ' : locale === 'ko' ? 'AI 도우미 먼저' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href="/cooperation">
              {locale === 'zh' ? '提交咨询' : locale === 'ja' ? '相談を送信' : locale === 'ko' ? '상담 제출' : 'Submit Consultation'}
            </a>
          </div>
        </div>

</aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
