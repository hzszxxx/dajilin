      { title: '文旅資源協力', body: '景区、施設、ルート事業者、コンテンツ協力者向け。' },
    ],
    submitTitle: '提出推奨情報',
    submitItems: ['属性：学校・機関・企業・資源提供者', '相談テーマ：研修・訪問・驛站・ルート・協力', '時期、人数規模、資源位置', '先に判断してほしい内容'],
    sideTitle: '協力の流れ',
    sideDesc: 'ページから相談を送信した後 Suitable のリソースとマッチングします。',
    entryTitle: '推奨入口',
    askAi: '先に AIガイドへ',
    askAiQuestion: '協業相談をしたい場合、先に何を準備すべきですか？',
    studyLink: '産業研修を見る',
  },
  ko: {
