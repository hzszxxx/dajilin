    studyLink: 'View Study Tours',
  },
  ja: {
    title: '協業相談 | dajilin.net',
    description: '観光機関、驛站サービス、研修協力、企業訪問、団体需要向けの協業相談入口です。',
    schemaName: '協業相談',
    heading: '協業相談',
    needsTitle: '対応可能な相談',
    needsItems: ['産業研修協力', '企業訪問・政企視察', '331 驛站協力', '団体カスタムルート相談'],
    cards: [
      { title: '学校・研修機関', body: '一汽紅旗研修、産業文明ルート、団体研修の初期相談に対応。' },
      { title: '企業・機関訪問', body: '中車長客、産業文明ルート、政企視察型訪問の相談に対応。' },
