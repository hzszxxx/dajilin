</style>

<script is:inline define:vars={{ t }}>
  const form = document.getElementById('cooperationForm');
  const submitBtn = document.getElementById('submitBtn');
  const successState = document.getElementById('successState');
  const submittedAtEl = document.getElementById('submittedAt');

  function getField(id) {
    return document.getElementById(id);
  }

  function setError(fieldId, show) {
    const group = getField(fieldId)?.closest('.form-group');
    if (group) group.classList.toggle('has-error', show);
  }

  function validatePhone(phone) {
    return /^1[3-9]\d{9}$/.test(phone.trim());
  }

  function validateForm() {
    let valid = true;

    const identityType = getField('identityType')?.value;
    setError('identityType', !identityType);
    if (!identityType) valid = false;

    const needType = getField('needType')?.value;
    setError('needType', !needType);
    if (!needType) valid = false;

    const contactName = getField('contactName')?.value.trim();
    setError('contactName', !contactName);
    if (!contactName) valid = false;

    const contactPhone = getField('contactPhone')?.value.trim();
    const phoneError = getField('contactPhoneError');
    if (!contactPhone) {
      setError('contactPhone', true);
      if (phoneError) phoneError.textContent = t.required;
      valid = false;
    } else if (!validatePhone(contactPhone)) {
      setError('contactPhone', true);
      if (phoneError) phoneError.textContent = t.invalidPhone;
      valid = false;
    }

    return valid;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validateForm()) return;

    submitBtn.disabled = true;
    submitBtn.textContent = t.submittingBtn;

    if (submittedAtEl) {
      submittedAtEl.value = new Date().toISOString();
    }

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    try {
      const webhookUrl = import.meta.env.PUBLIC_GN_N8N_COOPERATION_WEBHOOK_URL || '';
      if (webhookUrl) {
        await fetch(webhookUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...data,
            submittedAt: new Date().toISOString(),
          }),
        });
      }
    } catch (err) {
      // Proceed to success even if webhook fails (for demo/dev)
    }

    form.style.display = 'none';
    if (successState) successState.style.display = 'flex';
  });

  // Clear error on input
  ['identityType', 'needType', 'contactName', 'contactPhone', 'contactWechat'].forEach((id) => {
    const el = getField(id);
    el?.addEventListener('change', () => setError(id, false));
    el?.addEventListener('input', () => setError(id, false));
  });
</script>
