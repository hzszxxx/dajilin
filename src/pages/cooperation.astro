    submitTitle: '建议提交哪些信息',
    submitItems: ['你的身份：学校、机构、企业或资源方', '希望咨询的主题：研学、参访、驿站、路线或合作', '时间范围、人数规模或资源位置', '希望平台先帮助你判断什么'],
    sideTitle: '合作方式',
    sideDesc: '通过页面提交咨询后，平台会尽快与您对接，评估需求并匹配合适的资源方。',
    entryTitle: '建议入口',
    askAi: '先问 AI 导览',
    askAiQuestion: '我有合作需求，应该先准备哪些信息？',
    studyLink: '查看工业研学',
  },
  en: {
    title: 'Cooperation | dajilin.net',
    description: 'Consultation and cooperation for tourism institutions, station partners, study-tour partners, enterprise visits, and group travel demands.',
    schemaName: 'Cooperation',
    heading: 'Cooperation',
    needsTitle: 'Suitable Requests',
    needsItems: ['Industrial study-tour cooperation', 'Enterprise visits and government delegation tours', 'Route 331 station cooperation', 'Group custom itinerary requests'],
    cards: [
      { title: 'Schools & Study Institutions', body: 'Submit initial requests for FAW Hongqi study tours and industrial heritage routes.' },
      { title: 'Enterprise & Institutional Visits', body: 'Submit CRRC and industrial civilization visit requests for organizations.' },
      { title: 'Route 331 Station Partners', body: 'For station, stay, dining, supply, and team-service providers along the route.' },
      { title: 'Tourism Resource Partners', body: 'For scenic spots, venues, route providers, and content partners.' },
    ],
    submitTitle: 'Recommended Information to Submit',
    submitItems: ['Your role: school, institution, enterprise, or resource provider', 'Request type: study tour, visit, station, route, or cooperation', 'Time range, group size, or resource location', 'What you want us to evaluate first'],
    sideTitle: 'Cooperation Process',
    sideDesc: 'After submitting your inquiry through the page, we will match you with the appropriate resource partners.',
    entryTitle: 'Recommended Entry',
    askAi: 'Ask AI Guide First',
