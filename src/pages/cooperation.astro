      { title: '331 거점 협력', body: '연선 거점, 숙박, 식음, 보급, 팀 서비스 파트너 대상.' },
      { title: '문여 자원 협력', body: '관광지, 시설, 루트 운영사, 콘텐츠 파트너 대상.' },
    ],
    submitTitle: '제출 권장 정보',
    submitItems: ['역할: 학교, 기관, 기업, 자원 파트너', '문의 주제: 연수, 방문, 거점, 루트, 협업', '일정 범위, 인원 규모, 자원 위치', '플랫폼이 먼저 판단해야 할 항목'],
    sideTitle: '협업 절차',
    sideDesc: '페이지를 통해 문의를 제출하면 적합한 자원 파트너와 매칭해 드립니다.',
    entryTitle: '권장 입구',
    askAi: 'AI 가이드 먼저',
    askAiQuestion: '협업 문의를 하려면 어떤 정보를 먼저 준비해야 하나요?',
    studyLink: '산업 연수 보기',
  },
};
const t = copy[locale];
---

<BaseLayout title={t.title} description={t.description} schemas={[buildCollectionPageSchema('/cooperation', t.schemaName, t.description, locale)]} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-copy">
          <div class="eyebrow">Cooperation</div>
          <h1>{t.heading}</h1>
          <p>{t.description}</p>
        </div>
        <h2>{t.needsTitle}</h2>
        <ul>
          {t.needsItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>

        <div class="detail-grid">
          {t.cards.map((card) => (
            <article class="detail-link-card">
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>

        <div class="detail-block">
          <h2>{t.submitTitle}</h2>
          <ul>
            {t.submitItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </section>
      <aside class="page-card">
        <h3>{t.sideTitle}</h3>
        <p>{t.sideDesc}</p>
        <div class="detail-side-card">
          <h3>{t.entryTitle}</h3>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-module="cooperation" data-ai-question={t.askAiQuestion}>{t.askAi}</button>
            <a class="button-secondary" href={localizePath('/study-tours', locale)}>{t.studyLink}</a>
          </div>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>
