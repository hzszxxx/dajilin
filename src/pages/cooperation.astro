    description: string;
    schemaName: string;
    heading: string;
    needsTitle: string;
    needsItems: string[];
    cards: { title: string; body: string }[];
    submitTitle: string;
    submitItems: string[];
    sideTitle: string;
    sideDesc: string;
    entryTitle: string;
    askAi: string;
    askAiQuestion: string;
    studyLink: string;
  }
> = {
  zh: {
    title: '合作咨询 | dajilin.net',
    description: '承接文旅机构、驿站服务方、研学合作方、企业参访需求方和团体用户的咨询与合作对接。',
    schemaName: '合作咨询',
    heading: '合作咨询',
    needsTitle: '适合对接的需求',
