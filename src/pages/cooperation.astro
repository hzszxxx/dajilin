---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/astro/Header.astro';
import Footer from '@/components/astro/Footer.astro';
import { buildCollectionPageSchema } from '@/lib/schema';
import { getLocaleFromPathname, type Locale } from '@/lib/i18n';

const locale = getLocaleFromPathname(Astro.url.pathname);

const copy: Record<
  Locale,
  {
    title: string;
    description: string;
    schemaName: string;
    pageHeading: string;
    pageSubheading: string;
    identityType: string;
    identityOptions: string[];
    needType: string;
    needOptions: string[];
    timeLabel: string;
    timePlaceholder: string;
    groupSize: string;
    groupSizePlaceholder: string;
    contactName: string;
    contactNamePlaceholder: string;
    contactPhone: string;
    contactPhonePlaceholder: string;
    contactWechat: string;
    contactWechatPlaceholder: string;
    descriptionLabel: string;
    descriptionPlaceholder: string;
    submitBtn: string;
    submittingBtn: string;
    successTitle: string;
    successDesc: string;
    privacyNote: string;
    required: string;
    invalidPhone: string;
    invalidWechat: string;
    selectOption: string;
  }
> = {
  zh: {
    title: '合作咨询  | 大吉林',
    description: '提交你的需求，我们帮你判断适合的吉林文旅服务与合作路径。',
    schemaName: '合作咨询',
    pageHeading: '合作咨询',
    pageSubheading: '提交你的需求，我们帮你判断适合的吉林文旅服务与合作路径。',
    identityType: '你的身份是',
    identityOptions: ['游客/个人', '学校/教育机构', '研学机构', '企业/公司', '驿站资源方', '景区或文旅资源方', '其他'],
    needType: '需要的服务类型',
    needOptions: ['工业研学', '企业参访/政企考察', '331 自驾服务', '吉林行程定制', '资源合作入驻', '其他'],
    timeLabel: '出行或合作时间',
    timePlaceholder: '如：2025年6月、7月中旬、随时可约',
    groupSize: '人数或规模',
    groupSizePlaceholder: '如：40人团队、5人自驾、200人研学',
    contactName: '联系人姓名',
    contactNamePlaceholder: '请输入联系人姓名',
    contactPhone: '手机号码',
    contactPhonePlaceholder: '请输入手机号码',
    contactWechat: '微信（选填）',
    contactWechatPlaceholder: '方便更快联系可填写',
    descriptionLabel: '需求描述',
    descriptionPlaceholder: '请简要描述你的需求：出行日期、人数偏好、特殊要求等，帮助顾问更快了解你的情况。',
    submitBtn: '提交需求',
    submittingBtn: '提交中...',
    successTitle: '需求已收到',
    successDesc: '顾问将在 24 小时内与您联系。如需紧急确认，可直接拨打 0431-81157356。',
    privacyNote: '您的信息仅用于顾问跟进需求，不会用于其他用途。',
    required: '此项为必填',
    invalidPhone: '请输入有效的手机号码',
    invalidWechat: '请输入有效的微信号',
    selectOption: '请选择',
  },
  en: {
    title: 'Cooperation  | 大吉林',
    description: 'Submit your needs and we will help identify the right Jilin travel service and cooperation path for you.',
    schemaName: 'Cooperation',
    pageHeading: 'Cooperation',
    pageSubheading: 'Submit your needs and we will help identify the right Jilin travel service and cooperation path for you.',
    identityType: 'Your identity',
    identityOptions: ['Individual / Tourist', 'School / Education Institution', 'Study Tour Agency', 'Enterprise / Company', 'Station Resource Partner', 'Scenic Spot / Tourism Resource Partner', 'Other'],
    needType: 'Type of service needed',
    needOptions: ['Industrial Study Tour', 'Enterprise Visit / Government Delegation', 'Route 331 Self-Drive Service', 'Jilin Trip Customization', 'Resource Cooperation', 'Other'],
    timeLabel: 'Travel or cooperation timing',
    timePlaceholder: 'e.g., June 2025, mid-July, flexible',
    groupSize: 'Group size',
    groupSizePlaceholder: 'e.g., 40-person team, 5-person self-drive, 200-person study tour',
    contactName: 'Contact name',
    contactNamePlaceholder: 'Enter contact name',
    contactPhone: 'Phone number',
    contactPhonePlaceholder: 'Enter phone number',
    contactWechat: 'WeChat (optional)',
    contactWechatPlaceholder: 'Fill if you prefer faster contact',
    descriptionLabel: 'Description of needs',
    descriptionPlaceholder: 'Briefly describe your needs: travel dates, group preferences, special requirements, etc. This helps our consultant understand your situation faster.',
    submitBtn: 'Submit Request',
    submittingBtn: 'Submitting...',
    successTitle: 'Request Received',
    successDesc: 'A consultant will contact you within 24 hours. For urgent matters, call 0431-81157356 directly.',
    privacyNote: 'Your information is used only for consultant follow-up and will not be used for other purposes.',
    required: 'Required',
    invalidPhone: 'Please enter a valid phone number',
    invalidWechat: 'Please enter a valid WeChat ID',
    selectOption: 'Please select',
  },
  ja: {
    title: '協業相談  | 大吉林',
    description: 'ニーズを送信すれば、吉林文旅サービスと協力パスを見つけるお手伝いをします。',
    schemaName: '協業相談',
    pageHeading: '協業相談',
    pageSubheading: 'ニーズを送信すれば、吉林文旅サービスと協力パスを見つけるお手伝いをします。',
    identityType: '您的身份',
    identityOptions: ['個人/旅行者', '学校/教育機関', '研修機関', '企業/会社', '驛站リソースパートナー', '景区/文旅リソースパートナー', 'その他'],
    needType: '必要とするサービス類型',
    needOptions: ['産業研修', '企業訪問/政企視察', '331 自驾サービス', '吉林旅程定制', 'リソース協力入住', 'その他'],
    timeLabel: '出行または協力時期',
    timePlaceholder: '例：2025年6月、7月中旬、随时可约',
    groupSize: '人数または規模',
    groupSizePlaceholder: '例：40人チーム、5人自驾、200人研修',
    contactName: '担当者名',
    contactNamePlaceholder: '氏名を入力',
    contactPhone: '電話番号',
    contactPhonePlaceholder: '電話番号を入力',
    contactWechat: '微信（任意）',
    contactWechatPlaceholder: ' quicker contact possible',
    descriptionLabel: 'ニーズ説明',
    descriptionPlaceholder: 'ニーズを簡単に入力：出行日程、人数の偏好、特別な要求など。コンサルタントが状況をより早く理解するのに役立ちます。',
    submitBtn: 'ニーズを送信',
    submittingBtn: '送信中...',
    successTitle: 'ニーズを受け取りました',
    successDesc: 'コンサルタントが24時間以内にご連絡します。緊急の確認が必要な場合は、0431-81157356 まで直接お電話ください。',
    privacyNote: '情報はコンサルタントのニーズ追跡のみに使用され、他の目的には使用されません。',
    required: '必須',
    invalidPhone: '有効な電話番号を入力してください',
    invalidWechat: '有効な微信IDを入力してください',
    selectOption: '選択してください',
  },
  ko: {
    title: '협업 문의  | 大吉林',
    description: '요구를 제출하면 지린 관광 서비스와 협력 경로를 찾는 것을 도와드립니다.',
    schemaName: '협업 문의',
    pageHeading: '협업 문의',
    pageSubheading: '요구를 제출하면 지린 관광 서비스와 협력 경로를 찾는 것을 도와드립니다.',
    identityType: '신분',
    identityOptions: ['개인/여행자', '학교/교육기관', '연수기관', '기업/회사', '웨이잔 리소스 파트너', '경관/관광 리소스 파트너', '기타'],
    needType: '필요 서비스 유형',
    needOptions: ['산업 연수', '기업 방문/정책 시찰', '331 自驾 서비스', '지린 일정 커스텀', '자원 협력 입주', '기타'],
    timeLabel: '출행 또는 협력 시기',
    timePlaceholder: '예: 2025년 6월, 7월 중순, 즉시 가능',
    groupSize: '인원 또는 규모',
    groupSizePlaceholder: '예: 40명 팀, 5명自驾, 200명 연수',
    contactName: '담당자 이름',
    contactNamePlaceholder: '담당자 이름을 입력하세요',
    contactPhone: '전화번호',
    contactPhonePlaceholder: '전화번호를 입력하세요',
    contactWechat: '위챗（선택）',
    contactWechatPlaceholder: '更快联系可填写',
    descriptionLabel: '요구 설명',
    descriptionPlaceholder: '요구를 간단히 입력：출행 일정, 인원 선호, 특별 요구 등. 컨설턴트가 상황을 더 빨리 이해하는 데 도움이 됩니다.',
    submitBtn: '요구 제출',
    submittingBtn: '제출 중...',
    successTitle: '요구를 받았습니다',
    successDesc: '컨설턴트가 24시간 이내에 연락드립니다. 긴급 확인이 필요하시면 0431-81157356으로 직접 전화주세요.',
    privacyNote: '정보는 컨설턴트 요구 추적 전용으로 다른 용도로 사용되지 않습니다.',
    required: '필수',
    invalidPhone: '유효한 전화번호를 입력하세요',
    invalidWechat: '유효한 위챗 ID를 입력하세요',
    selectOption: '선택하세요',
  },
};

const t = copy[locale];
---

<BaseLayout
  title={t.title}
  description={t.description}
  schemas={[buildCollectionPageSchema('/cooperation', t.schemaName, t.description, locale)]}
  locale={locale}
>
  <Header />
  <main class="page-shell">
    <div class="cooperation-layout">
      <!-- Left: Purpose + trust signals -->
      <aside class="cooperation-aside">
        <div class="cooperation-aside-inner">
          <h2 class="cooperation-aside-heading">{locale === 'zh' ? '为什么通过大吉林咨询' : locale === 'en' ? 'Why Consult Through Da Jilin' : locale === 'ja' ? 'なぜ大吉林を通じて相談か' : '왜 대지린을 통해 상담하는가'}</h2>
          <ul class="cooperation-trust-list">
            <li>
              <span class="trust-icon">&#10003;</span>
              <div>
                <strong>{locale === 'zh' ? 'AI 初筛方向' : 'AI Pre-screening'}</strong>
                <p>{locale === 'zh' ? '先通过 AI 了解适合的服务方向' : 'Understand the right service direction first with AI'}</p>
              </div>
            </li>
            <li>
              <span class="trust-icon">&#10003;</span>
              <div>
                <strong>{locale === 'zh' ? '顾问跟进细节' : 'Consultant Follow-up'}</strong>
                <p>{locale === 'zh' ? '人工确认资源档期与服务细节' : 'Human confirmation of resource availability and service details'}</p>
              </div>
            </li>
            <li>
              <span class="trust-icon">&#10003;</span>
              <div>
                <strong>{locale === 'zh' ? '全流程服务' : 'Full-Process Service'}</strong>
                <p>{locale === 'zh' ? '从咨询到出行全程有人跟进' : 'Someone follows through from inquiry to travel'}</p>
              </div>
            </li>
          </ul>

          <div class="cooperation-ai-prompt">
            <p>{locale === 'zh' ? '还不确定想要什么？' : locale === 'en' ? 'Not sure what you want yet?' : locale === 'ja' ? 'まだ何をしたいか分からない？' : '아직 무엇을 원하는지 모르시나요?'}</p>
            <button
              class="cooperation-ai-btn"
              type="button"
              data-open-ai-widget
              data-ai-module="cooperation"
              data-ai-question={locale === 'zh' ? '我有合作需求，应该先准备哪些信息？' : locale === 'en' ? 'I have a cooperation request. What information should I prepare first?' : locale === 'ja' ? '協業相談をしたい場合、先に何を準備すべきですか？' : '협업 문의를 하고 싶은데 어떤 정보를 먼저 준비해야 하나요?'}
            >
              {locale === 'zh' ? '→ 让 AI 先帮我分析方向' : locale === 'en' ? '→ Let AI analyze my direction first' : locale === 'ja' ? '→ AIにまず方向性を分析してもらう' : '→ AI가 먼저 방향을 분석하게 하기'}
            </button>
          </div>

          <p class="cooperation-privacy">{t.privacyNote}</p>
        </div>
      </aside>

      <!-- Right: Form -->
      <section class="cooperation-form-section">
        <div class="cooperation-form-header">
          <h1>{t.pageHeading}</h1>
          <p>{t.pageSubheading}</p>
        </div>

        <form id="cooperationForm" class="cooperation-form" novalidate>
          <!-- Identity Type -->
          <div class="form-group">
            <label for="identityType">{t.identityType} <span class="required-mark">*</span></label>
            <select id="identityType" name="identityType" required>
              <option value="">-- {t.selectOption} --</option>
              {t.identityOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
            <span class="field-error" id="identityTypeError">{t.required}</span>
          </div>

          <!-- Need Type -->
          <div class="form-group">
            <label for="needType">{t.needType} <span class="required-mark">*</span></label>
            <select id="needType" name="needType" required>
              <option value="">-- {t.selectOption} --</option>
              {t.needOptions.map((opt) => <option value={opt}>{opt}</option>)}
            </select>
            <span class="field-error" id="needTypeError">{t.required}</span>
          </div>

          <!-- Time + GroupSize row -->
          <div class="form-row">
            <div class="form-group">
              <label for="time">{t.timeLabel}</label>
              <input type="text" id="time" name="time" placeholder={t.timePlaceholder} />
            </div>
            <div class="form-group">
              <label for="groupSize">{t.groupSize}</label>
              <input type="text" id="groupSize" name="groupSize" placeholder={t.groupSizePlaceholder} />
            </div>
          </div>

          <!-- Contact Name -->
          <div class="form-group">
            <label for="contactName">{t.contactName} <span class="required-mark">*</span></label>
            <input type="text" id="contactName" name="contactName" placeholder={t.contactNamePlaceholder} required />
            <span class="field-error" id="contactNameError">{t.required}</span>
          </div>

          <!-- Phone + Wechat row -->
          <div class="form-row">
            <div class="form-group">
              <label for="contactPhone">{t.contactPhone} <span class="required-mark">*</span></label>
              <input type="tel" id="contactPhone" name="contactPhone" placeholder={t.contactPhonePlaceholder} required />
              <span class="field-error" id="contactPhoneError">{t.invalidPhone}</span>
            </div>
            <div class="form-group">
              <label for="contactWechat">{t.contactWechat}</label>
              <input type="text" id="contactWechat" name="contactWechat" placeholder={t.contactWechatPlaceholder} />
            </div>
          </div>

          <!-- Description -->
          <div class="form-group">
            <label for="description">{t.descriptionLabel}</label>
            <textarea id="description" name="description" rows="4" placeholder={t.descriptionPlaceholder}></textarea>
          </div>

          <!-- Hidden fields -->
          <input type="hidden" name="source_page" value="/cooperation" />
          <input type="hidden" name="module" value="cooperation_form" />
          <input type="hidden" name="locale" value={locale} />
          <input type="hidden" name="submittedAt" id="submittedAt" />

          <!-- Submit -->
          <div class="form-actions">
            <button type="submit" class="submit-btn" id="submitBtn">{t.submitBtn}</button>
          </div>
        </form>

        <!-- Success state -->
        <div id="successState" class="success-state" style="display:none;">
          <div class="success-icon">&#10003;</div>
          <h2>{t.successTitle}</h2>
          <p>{t.successDesc}</p>
          
          <div class="wechat-fast-track">
            <p><strong>不想等待回电？</strong><br/>直接扫码添加专属服务顾问微信（微信号：dajilin_service）</p>
            <div class="wechat-qr-placeholder">
              <img src="/images/wechat-qr-placeholder.jpg" alt="WeChat QR" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=\\'http://www.w3.org/2000/svg\\' viewBox=\\'0 0 100 100\\' fill=\\'%23f8fafc\\'%3E%3Crect width=\\'100\\' height=\\'100\\'/%3E%3Ctext x=\\'50\\' y=\\'50\\' text-anchor=\\'middle\\' dy=\\'.3em\\' fill=\\'%2394a3b8\\' font-size=\\'12\\' font-family=\\'sans-serif\\'%3E微信二维码%3C/text%3E%3C/svg%3E'" />
            </div>
          </div>

          <a href={locale === 'zh' ? '/' : locale === 'en' ? '/en' : locale === 'ja' ? '/ja' : '/ko'} class="success-home-link">
            {locale === 'zh' ? '← 返回首页' : locale === 'en' ? '← Back to Home' : locale === 'ja' ? '← ホームに戻る' : '← 홈페이지로 돌아가기'}
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
.cooperation-layout {
  max-width: 1100px;
  margin: 0 auto;
  padding: 48px 20px 80px;
  display: grid;
  grid-template-columns: 300px 1fr;
  gap: 40px;
  align-items: start;
}

@media (max-width: 768px) {
  .cooperation-layout {
    grid-template-columns: 1fr;
    padding: 24px 16px 60px;
    gap: 28px;
  }
}

/* Aside */
.cooperation-aside {
  position: sticky;
  top: 24px;
}

.cooperation-aside-inner {
  background: linear-gradient(135deg, #f0fdf4 0%, #f8fafc 100%);
  border: 1.5px solid rgba(11,95,66,.15);
  border-radius: 24px;
  padding: 28px 24px;
}

.cooperation-aside-heading {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--text-strong);
  margin: 0 0 20px;
  letter-spacing: -.01em;
}

.cooperation-trust-list {
  list-style: none;
  padding: 0;
  margin: 0 0 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.cooperation-trust-list li {
  display: flex;
  gap: 10px;
  align-items: flex-start;
}

.trust-icon {
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--pine-green);
  color: #fff;
  font-size: .75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

.cooperation-trust-list strong {
  display: block;
  font-size: .88rem;
  font-weight: 700;
  color: var(--text-strong);
  margin-bottom: 2px;
}

.cooperation-trust-list p {
  font-size: .8rem;
  color: var(--muted);
  margin: 0;
  line-height: 1.5;
}

.cooperation-ai-prompt {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: 14px;
  padding: 16px 18px;
  margin-bottom: 16px;
}

.cooperation-ai-prompt p {
  font-size: .83rem;
  color: var(--muted);
  margin: 0 0 10px;
}

.cooperation-ai-btn {
  width: 100%;
  padding: 10px 16px;
  border-radius: 999px;
  border: 1.5px solid var(--lake-blue);
  background: transparent;
  color: var(--lake-blue);
  font-size: .82rem;
  font-weight: 600;
  cursor: pointer;
  text-align: left;
  transition: background .2s, color .2s;
}

.cooperation-ai-btn:hover {
  background: var(--lake-blue);
  color: #fff;
}

.cooperation-privacy {
  font-size: .72rem;
  color: var(--muted);
  margin: 0;
  text-align: center;
  line-height: 1.5;
}

/* Form section */
.cooperation-form-section {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: 28px;
  padding: 36px 40px;
  box-shadow: 0 4px 20px #00000008;
}

@media (max-width: 768px) {
  .cooperation-form-section {
    padding: 24px 20px;
    border-radius: 20px;
  }
}

.cooperation-form-header {
  margin-bottom: 28px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--line-light);
}

.cooperation-form-header h1 {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--text-strong);
  margin: 0 0 8px;
  letter-spacing: -.02em;
}

.cooperation-form-header p {
  font-size: .9rem;
  color: var(--muted);
  margin: 0;
  line-height: 1.6;
}

/* Form */
.cooperation-form {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

@media (max-width: 560px) {
  .form-row { grid-template-columns: 1fr; }
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: .85rem;
  font-weight: 600;
  color: var(--text-strong);
}

.required-mark {
  color: #ef4444;
}

.form-group input,
.form-group select,
.form-group textarea {
  padding: 11px 14px;
  border: 1.5px solid var(--line);
  border-radius: 12px;
  font-size: .9rem;
  color: var(--text-strong);
  background: var(--paper);
  transition: border-color .2s, box-shadow .2s;
  font-family: inherit;
  width: 100%;
  box-sizing: border-box;
}

.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  outline: none;
  border-color: var(--pine-green);
  box-shadow: 0 0 0 3px rgba(11,95,66,.1);
}

.form-group input::placeholder,
.form-group textarea::placeholder {
  color: #c4c9d4;
}

.form-group textarea {
  resize: vertical;
  min-height: 100px;
}

