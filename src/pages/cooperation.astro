  font-size: .75rem;
  color: #ef4444;
  display: none;
}

.form-group.has-error input,
.form-group.has-error select,
.form-group.has-error textarea {
  border-color: #ef4444;
}

.form-group.has-error .field-error {
  display: block;
}

