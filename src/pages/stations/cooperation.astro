const t = localized[locale];
const thisPath = '/stations/cooperation';
const schema = buildWebPageSchema(thisPath, t.pageTitle, t.description, locale);
---

<BaseLayout title={t.title} description={t.description} schemas={[schema]} locale={locale}>
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">Station Partnership</div>
            <h1>{t.heroTitle}</h1>
            <p>{t.heroDesc}</p>
            <div class="hero-cta-group">
              <a href="#apply-form" class="btn-primary-large">
                {t.applyCta}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <a href="/ai-assistant" class="btn-secondary-large">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 16v-4M12 8h.01"/>
                </svg>
                AI 智能咨询
              </a>
            </div>
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.benefitsTitle}</h2>
          <div class="benefits-grid">
            {t.benefits.map((benefit) => (
              <article class="benefit-card">
                <span class="benefit-icon">{benefit.icon}</span>
                <h3>{benefit.title}</h3>
                <p>{benefit.desc}</p>
              </article>
            ))}
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.requirementsTitle}</h2>
          <ul class="requirements-list">
            {t.requirements.map((req) => (
              <li>{req}</li>
            ))}
          </ul>
        </div>

        <div class="detail-block">
          <h2>{t.processTitle}</h2>
          <div class="process-timeline">
            {t.process.map((item) => (
              <article class="process-step">
                <div class="step-number">{item.step}</div>
                <div class="step-content">
                  <h3>{item.title}</h3>
                  <p>{item.desc}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="detail-block">
          <h2>{t.revenueTitle}</h2>
          <p>{t.revenueDesc}</p>
          <div class="revenue-grid">
            {t.revenueItems.map((item) => (
              <article class="revenue-card">
                <h3>{item.title}</h3>
                <p>{item.desc}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <aside class="page-card">
        <div class="apply-form-container">
          <h2>{t.formTitle}</h2>
          <p>{t.formDesc}</p>
          <StationApplyForm
            locale={locale}
            formTitle={t.formTitle}
            submitLabel={t.applyCta}
          />
        </div>

        <div class="detail-side-card">
          <h3>{t.contactTitle}</h3>
          <p>{t.contactInfo}</p>
          <div class="cta-row">
            <button
              class="button"
              type="button"
              data-open-ai-widget
              data-ai-page-url={thisPath}
              data-ai-question={t.askAiQuestion}
            >
              {t.askAi}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {locale === 'zh' ? '合作咨询' : locale === 'ja' ? '協業相談' : locale === 'ko' ? '협업 문의' : 'Cooperation'}
            </a>
          </div>
        </div>

        <div class="detail-side-card">
          <h3>{locale === 'zh' ? '相关链接' : locale === 'ja' ? '関連リンク' : locale === 'ko' ? '관련 링크' : 'Related Links'}</h3>
          <ul class="page-list">
            <li><a href={localizePath('/self-drive/stations', locale)}>
              {locale === 'zh' ? '驿站服务说明' : locale === 'ja' ? '驛站サービス説明' : locale === 'ko' ? '거점 서비스 설명' : 'Station Services'}
            </a></li>
            <li><a href={localizePath('/self-drive', locale)}>
              {locale === 'zh' ? '自驾攻略介绍' : locale === 'ja' ? '自驾攻略紹介' : locale === 'ko' ? '자가운전 가이드 소개' : 'Self-Drive Guide'}
            </a></li>
          </ul>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .benefit-card {
    background: var(--color-surface, #f8f9fa);
    padding: 1.5rem;
    border-radius: 8px;
  }

  .benefit-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.5rem;
  }

  .benefit-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .benefit-card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary, #666);
  }

  .requirements-list {
    list-style: none;
    padding: 0;
  }

  .requirements-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border, #eee);
    padding-left: 1.5rem;
    position: relative;
  }

  .requirements-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-primary, var(--primary));
