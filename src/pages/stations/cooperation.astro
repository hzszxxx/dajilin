    revenueItems: [
      { title: '주문 수수료', desc: '매成交 주문에 대해 플랫폼 서비스료 5%-10% 부과' },
      { title: '회원推广비', desc: '협력 거점은 플랫폼 회원推广 계획에 참여 가능' },
      { title: '부가 서비스비', desc: '추가推广 좌, 데이터 분석 보고서 등의 서비스는 별도 청구' },
    ],
    ctaTitle: '즉시 신청',
    ctaDesc: '아래 양식을 작성하여 신청을 제출하세요. 3 영업일 이내에 연락드리겠습니다.',
    formTitle: '협력 신청서',
    formDesc: '아래 정보를 성심껏 작성하세요. 플랫폼은 제공하신 내용을 바탕으로 심사를 진행합니다.',
    applyCta: '신청 제출',
    contactTitle: '문의하기',
    contactInfo: '문의사항이 있으시면 협력 페이지에서联系我们ください',
    askAi: 'AI 도우미 먼저',
