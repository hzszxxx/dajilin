const t = copy[locale];

// Build flat FAQ list for FAQPage schema
const allFAQs = t.sections.flatMap((section) =>
  section.faqs.map((faq) => ({ question: faq.q, answer: faq.a }))
);

const breadcrumbs = [
  { name: isZh ? '首页' : 'Home', url: localizePath('/', locale) },
  { name: isZh ? '常见问题' : 'FAQ', url: localizePath('/faq', locale) },
];

const schemas = [
  buildWebPageSchema(pagePath, pageTitle, pageDescription, locale),
  buildFAQPageSchema(pagePath, pageTitle, allFAQs, locale),
  buildBreadcrumbListSchema(pagePath, breadcrumbs, locale),
];
---

<BaseLayout title={`${pageTitle} | dajilin.net`} description={pageDescription} schemas={schemas} locale={locale} ogImage="/images/home/yanbian.jpg">
  <Header />
  <main class="page-shell">
    <div class="container page-grid">
      <section class="content-card">
        <div class="page-hero">
          <div class="page-copy">
            <div class="eyebrow">{t.eyebrow}</div>
            <h1>{pageTitle}</h1>
            <p>{t.intro}</p>
          </div>
        </div>

        {t.sections.map((section) => (
          <div class="detail-block">
            <h2>{section.title}</h2>
            <div class="faq-list">
              {section.faqs.map((faq) => (
                <article class="faq-item">
                  <h3>{faq.q}</h3>
                  <p>{faq.a}</p>
                </article>
              ))}
            </div>
          </div>
        ))}

        <div class="detail-block">
          <h3>{isZh ? '没有找到答案？' : 'Did not find your answer?'}</h3>
          <p>{isZh ? '使用页面底部的AI助手提问，或提交咨询表单。' : 'Ask the AI assistant at the bottom of the page, or submit a consultation form.'}</p>
          <div class="cta-row">
            <button class="button" type="button" data-open-ai-widget data-ai-page-url={pagePath}>
              {isZh ? '先问 AI 助手' : 'Ask AI Assistant'}
            </button>
            <a class="button-secondary" href={localizePath('/cooperation', locale)}>
              {isZh ? '提交咨询' : 'Submit Consultation'}
            </a>
          </div>
        </div>
      </section>

      <aside class="page-card">
        <h3>{isZh ? '相关页面' : 'Related Pages'}</h3>
        <ul class="page-list">
          <li><a href={localizePath('/destinations/yanbian', locale)}>{isZh ? '延边目的地页' : 'Yanbian Destination'}</a></li>
          <li><a href={localizePath('/self-drive/overview', locale)}>{isZh ? '331国道概览' : 'Route 331 Overview'}</a></li>
          <li><a href={localizePath('/self-drive/how-to-travel', locale)}>{isZh ? '自驾攻略' : 'Self-Drive Guide'}</a></li>
          <li><a href={localizePath('/self-drive/stations', locale)}>{isZh ? '驿站信息' : 'Station Info'}</a></li>
          <li><a href={localizePath('/official-services', locale)}>{isZh ? '官方服务说明' : 'Official Services'}</a></li>
        </ul>
      </aside>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .faq-item {
    padding: 1rem;
    background: var(--color-surface);
    border-radius: 8px;
  }
  .faq-item h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
    color: var(--color-heading);
  }
  .faq-item p {
    color: var(--color-text);
    line-height: 1.7;
    font-size: 0.95rem;
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
</style>
