# MiniMax API Credentials (China region)
# Get from: https://platform.minimax.chat/
MINIMAX_API_KEY=your_api_key_here
MINIMAX_GROUP_ID=your_group_id_here

# Server config
PORT=3000
NODE_ENV=development

# Optional: n8n webhook for handoff (already configured in main app)
N8N_HANDOFF_WEBHOOK_URL=https://n.n8n.wang/webhook/dajilin-ai-handoff

# CORS - allowed origins
ALLOWED_ORIGINS=https://dajilin.net,http://localhost:4321
